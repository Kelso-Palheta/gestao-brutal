@using BatatasFritas.Shared.DTOs
@using BatatasFritas.Shared.Enums
@using System.Net.Http.Json
@using BatatasFritas.Web.Services
@inject HttpClient Http

<div class="admin-section">
    <div class="admin-section-header">
        <h2>Produtos do Cardápio</h2>
        <button class="admin-btn-novo" @onclick="AbrirNovoProduto">+ Novo Produto</button>
    </div>

    <!-- FORMULÁRIO de Criar/Editar -->
    @if (mostrarFormProduto)
    {
        <div class="admin-form-card">
            <h3>@(produtoEdit.Id == 0 ? "Novo Produto" : $"Editando: {produtoEdit.Nome}")</h3>
            <div class="admin-form-grid">
                <div class="admin-field">
                    <label>Nome *</label>
                    <input @bind="produtoEdit.Nome" placeholder="Ex: Batata Suprema Grande" />
                </div>
                <div class="admin-field">
                    <label>Preço Base (R$) *</label>
                    <input type="number" step="0.01" min="0" @bind="produtoEdit.PrecoBase" placeholder="0,00" />
                </div>
                <div class="admin-field">
                    <label>Categoria *</label>
                    <select @bind="produtoEdit.CategoriaId">
                        @foreach (var cat in Enum.GetValues<CategoriaEnum>())
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                </div>
                <div class="admin-field">
                    <label>URL da Imagem</label>
                    <input @bind="produtoEdit.ImagemUrl" placeholder="https://..." />
                </div>
                <div class="admin-field admin-field-full">
                    <label>Descrição</label>
                    <textarea @bind="produtoEdit.Descricao" rows="2" placeholder="Descrição opcional..."></textarea>
                </div>
                <div class="admin-field admin-field-full">
                    <label>Complementos Específicos (Molhos, Adicionais, Remoções)</label>
                    <p style="font-size:0.85rem; color:#888; margin-top:-5px; margin-bottom:10px;">
                        Se <b>NENHUM</b> for marcado, o produto aceitará todos os complementos que estejam vinculados à sua categoria (regra antiga).
                        Se você marcar itens aqui, <b>APENAS ESTES</b> itens aparecerão no cardápio/totem.
                    </p>
                    <div style="display: flex; flex-wrap: wrap; gap: 15px; background: #1a1a1a; padding: 15px; border-radius: 8px; border: 1px solid #333; max-height: 200px; overflow-y: auto;">
                        @foreach (var c in complementos)
                        {
                            <label style="display: flex; align-items: center; gap: 8px; color: #ccc; font-weight: normal; font-size: 0.9rem; background: #222; padding: 8px 12px; border-radius: 6px; border: 1px solid #444; cursor: pointer;">
                                <input type="checkbox" checked="@IsComplementoSelecionado(c.Id)" @onchange="@(e => ToggleSelecaoComplemento(c.Id, e.Value))" style="width:16px; height:16px; cursor: pointer; accent-color:#ffb347;" />
                                @c.Nome <small style="color:#ffb347">(@c.TipoAcao.ToString().Substring(0, 3)...)</small>
                            </label>
                        }
                    </div>
                </div>
            </div>
            <div class="admin-form-actions">
                <button class="admin-btn-salvar" @onclick="SalvarProduto" disabled="@salvando">
                    @(salvando ? "Salvando..." : "💾 Salvar")
                </button>
                <button class="admin-btn-cancelar" @onclick="FecharFormProduto">Cancelar</button>
            </div>
        </div>
    }

    <!-- TABELA de Produtos -->
    @if (produtos.Any())
    {
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th style="width:60px">Ordem</th>
                        <th>Nome</th>
                        <th>Categoria</th>
                        <th>Preço</th>
                        <th>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int idx = 0; idx < produtos.Count; idx++)
                    {
                        var p = produtos[idx];
                        var posicao = idx;
                        <tr class="@(!p.Ativo ? "admin-row-inativo" : "")">
                            <td class="admin-td-id">
                                <div class="admin-ordem-ctrl">
                                    <button class="admin-btn-ordem" @onclick="() => MoverCima(posicao)" disabled="@(posicao == 0 || salvandoOrdem)" title="Mover para cima">▲</button>
                                    <span>@(posicao + 1)º</span>
                                    <button class="admin-btn-ordem" @onclick="() => MoverBaixo(posicao)" disabled="@(posicao == produtos.Count - 1 || salvandoOrdem)" title="Mover para baixo">▼</button>
                                </div>
                            </td>
                            <td>
                                <strong>@p.Nome</strong>
                                @if (!string.IsNullOrEmpty(p.Descricao))
                                {
                                    <br /><small style="color:#888">@p.Descricao</small>
                                }
                            </td>
                            <td><span class="admin-badge">@p.CategoriaId</span></td>
                            <td class="admin-td-preco">R$ @p.PrecoBase.ToString("F2")</td>
                            <td>
                                @if (p.Ativo)
                                {
                                    <span class="admin-status-ativo">● Ativo</span>
                                }
                                else
                                {
                                    <span class="admin-status-inativo">● Inativo</span>
                                }
                            </td>
                            <td class="admin-td-acoes">
                                <button class="admin-btn-editar" @onclick="() => EditarProduto(p)" title="Editar">✏️</button>
                                <button class="admin-btn-editar" @onclick="() => AbrirModalReceita(p)" title="Receita (Insumos)">👨‍🍳</button>
                                @if (p.Ativo)
                                {
                                    <button class="admin-btn-toggle" @onclick="() => ToggleProduto(p, false)" title="Desativar do cardápio">🔴</button>
                                }
                                else
                                {
                                    <button class="admin-btn-toggle" @onclick="() => ToggleProduto(p, true)" title="Ativar no cardápio">🟢</button>
                                }
                                <button class="admin-btn-deletar" @onclick="() => DeletarProduto(p)" title="Excluir permanentemente">🗑️</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="admin-vazio">Nenhum produto cadastrado ainda. Clique em "+ Novo Produto" para começar.</p>
    }

    <!-- MODAL RECEITA -->
    @if (mostrarModalReceita && receitaProduto != null)
    {
        <div class="modal-overlay">
            <div class="modal-content" style="max-width: 600px;">
                <button class="modal-close-btn" @onclick="FecharModalReceita">✕</button>
                <h2>👨‍🍳 Receita: @receitaProduto.Nome</h2>
                <p style="color:#666; font-size: 0.9rem; margin-bottom: 20px;">Adicione quais insumos são consumidos do estoque a cada unidade vendida (Ex: 0.400 kg de Batata).</p>

                <div style="display:flex; gap:10px; margin-bottom:20px; align-items: flex-end;">
                    <div style="flex:2">
                        <label style="font-size:0.85rem; font-weight:bold; display:block; margin-bottom:4px;">Insumo</label>
                        <select @bind="novoInsumoId" style="width:100%; padding: 10px; border: 2px solid #ddd; border-radius: 6px;">
                            <option value="0">Selecione...</option>
                            @foreach (var insumo in todosInsumos)
                            {
                                <option value="@insumo.Id">@insumo.Nome (@insumo.Unidade)</option>
                            }
                        </select>
                    </div>
                    <div style="flex:1">
                        <label style="font-size:0.85rem; font-weight:bold; display:block; margin-bottom:4px;">Quantidade</label>
                        <input type="number" step="0.001" @bind="novaQtdeInsumo" style="width:100%; padding: 10px; border: 2px solid #ddd; border-radius: 6px;" placeholder="Ex: 0,400" />
                    </div>
                    <button @onclick="AdicionarItemReceita" style="background:#27ae60; color:#fff; border:none; padding:12px 18px; border-radius:6px; font-weight:bold; cursor:pointer;" disabled="@salvandoReceita">
                        +(In)
                    </button>
                </div>

                @if (itensReceita.Any())
                {
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Insumo</th>
                                <th>Quantidade</th>
                                <th>Remover</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in itensReceita)
                            {
                                <tr>
                                    <td>@item.InsumoNome</td>
                                    <td><strong>@item.QuantidadePorUnidade</strong> <small style="color:#888">@item.InsumoUnidade</small></td>
                                    <td>
                                        <button @onclick="() => RemoverItemReceita(item.Id)" style="background:transparent; border:none; font-size:1.2rem; cursor:pointer;" title="Remover Insumo">🗑️</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div style="padding:20px; text-align:center; background:#fafafa; border:2px dashed #ddd; border-radius:8px; color:#999; margin-top:10px;">
                        Este produto não reduz nada do estoque quando vendido.
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [CascadingParameter] private AdminAlertService Alert { get; set; } = default!;

    // ── Estado Produtos ──
    private List<ProdutoDto>      produtos    = new();
    private List<ComplementoDto>  complementos = new();
    private ProdutoDto            produtoEdit  = new();
    private bool                  mostrarFormProduto = false;
    private bool                  salvando    = false;
    private bool                  salvandoOrdem = false;
    private HashSet<int>          complementosSelecionadosEdit = new();

    // ── Estado Modal Receita ──
    private bool              mostrarModalReceita = false;
    private ProdutoDto?       receitaProduto      = null;
    private List<ItemReceitaDto> itensReceita     = new();
    private List<InsumoDto>   todosInsumos        = new();
    private int               novoInsumoId        = 0;
    private decimal           novaQtdeInsumo      = 0;
    private bool              salvandoReceita     = false;

    private record SoftDeleteResponse(bool SoftDelete, string Mensagem);

    protected override async Task OnInitializedAsync() => await Carregar();

    private async Task Carregar()
    {
        try
        {
            var prods = await Http.GetFromJsonAsync<List<ProdutoDto>>("api/produtos");
            if (prods != null) produtos = prods;

            var comps = await Http.GetFromJsonAsync<List<ComplementoDto>>("api/complementos");
            if (comps != null) complementos = comps;
        }
        catch (Exception ex) { Alert.MostrarErro($"Erro ao carregar produtos: {ex.Message}"); }
    }

    // ── Complementos no formulário ──
    private bool IsComplementoSelecionado(int id) => complementosSelecionadosEdit.Contains(id);

    private void ToggleSelecaoComplemento(int id, object? isChecked)
    {
        if (isChecked is bool b && b)
            complementosSelecionadosEdit.Add(id);
        else
            complementosSelecionadosEdit.Remove(id);
    }

    // ── Ordem ──
    private async Task MoverCima(int indice)
    {
        if (indice <= 0) return;
        (produtos[indice], produtos[indice - 1]) = (produtos[indice - 1], produtos[indice]);
        await SalvarOrdem();
    }

    private async Task MoverBaixo(int indice)
    {
        if (indice >= produtos.Count - 1) return;
        (produtos[indice], produtos[indice + 1]) = (produtos[indice + 1], produtos[indice]);
        await SalvarOrdem();
    }

    private async Task SalvarOrdem()
    {
        salvandoOrdem = true;
        Alert.Limpar();
        try
        {
            var payload = produtos.Select((p, idx) => new ReordenarProdutoItem(p.Id, idx)).ToList();
            var response = await Http.PatchAsJsonAsync("api/produtos/reordenar", payload);
            if (!response.IsSuccessStatusCode)
                Alert.MostrarErro("Erro ao salvar a nova ordem. Tente novamente.");
        }
        catch (Exception ex) { Alert.MostrarErro($"Erro de conexão: {ex.Message}"); }
        finally { salvandoOrdem = false; }
    }

    // ── CRUD Produtos ──
    private void AbrirNovoProduto()
    {
        Alert.Limpar();
        produtoEdit = new ProdutoDto { Ativo = true };
        complementosSelecionadosEdit.Clear();
        mostrarFormProduto = true;
    }

    private void EditarProduto(ProdutoDto p)
    {
        Alert.Limpar();
        produtoEdit = new ProdutoDto
        {
            Id = p.Id, Nome = p.Nome, Descricao = p.Descricao,
            CategoriaId = p.CategoriaId, PrecoBase = p.PrecoBase,
            ImagemUrl = p.ImagemUrl, Ativo = p.Ativo,
            ComplementosPermitidos = p.ComplementosPermitidos
        };
        complementosSelecionadosEdit.Clear();
        if (!string.IsNullOrWhiteSpace(p.ComplementosPermitidos))
        {
            foreach (var idStr in p.ComplementosPermitidos.Split(',', StringSplitOptions.RemoveEmptyEntries))
                if (int.TryParse(idStr.Trim(), out int idInt))
                    complementosSelecionadosEdit.Add(idInt);
        }
        mostrarFormProduto = true;
    }

    private void FecharFormProduto()
    {
        mostrarFormProduto = false;
        produtoEdit = new();
    }

    private async Task SalvarProduto()
    {
        if (string.IsNullOrWhiteSpace(produtoEdit.Nome) || produtoEdit.PrecoBase <= 0)
        {
            Alert.MostrarErro("Nome e Preço são obrigatórios!");
            return;
        }
        produtoEdit.ComplementosPermitidos = complementosSelecionadosEdit.Any()
            ? string.Join(",", complementosSelecionadosEdit) : "";

        Alert.Limpar();
        salvando = true;
        try
        {
            HttpResponseMessage response;
            if (produtoEdit.Id == 0)
                response = await Http.PostAsJsonAsync("api/produtos", produtoEdit);
            else
                response = await Http.PutAsJsonAsync($"api/produtos/{produtoEdit.Id}", produtoEdit);

            if (response.IsSuccessStatusCode)
            {
                Alert.MostrarSucesso(produtoEdit.Id == 0 ? "Produto criado com sucesso!" : "Produto atualizado com sucesso!");
                FecharFormProduto();
                await Carregar();
            }
            else { Alert.MostrarErro($"Erro ao salvar: {await response.Content.ReadAsStringAsync()}"); }
        }
        catch (Exception ex) { Alert.MostrarErro($"Erro de conexão: {ex.Message}"); }
        finally { salvando = false; }
    }

    private async Task ToggleProduto(ProdutoDto p, bool ativar)
    {
        Alert.Limpar();
        var endpoint = ativar ? $"api/produtos/{p.Id}/ativar" : $"api/produtos/{p.Id}/desativar";
        var response = await Http.PatchAsync(endpoint, null);
        if (response.IsSuccessStatusCode)
        {
            var msg = ativar ? $"'{p.Nome}' ativado no cardápio!" : $"'{p.Nome}' removido do cardápio!";
            try
            {
                var body = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                if (body.TryGetProperty("aviso", out var aviso) && aviso.GetString() is string avisoStr && !string.IsNullOrEmpty(avisoStr))
                    msg += $" ⚠️ {avisoStr}";
            }
            catch { }
            Alert.MostrarSucesso(msg);
            await Carregar();
        }
        else
        {
            var erro = await response.Content.ReadAsStringAsync();
            Alert.MostrarErro(!string.IsNullOrWhiteSpace(erro) ? erro : "Erro ao alterar status do produto.");
        }
    }

    private async Task DeletarProduto(ProdutoDto p)
    {
        Alert.Limpar();
        var response = await Http.DeleteAsync($"api/produtos/{p.Id}");
        if (response.StatusCode == System.Net.HttpStatusCode.NoContent)
        {
            Alert.MostrarSucesso($"Produto '{p.Nome}' excluído permanentemente.");
            await Carregar();
        }
        else if (response.IsSuccessStatusCode)
        {
            var resultado = await response.Content.ReadFromJsonAsync<SoftDeleteResponse>();
            Alert.MostrarSucesso(resultado?.Mensagem ?? $"'{p.Nome}' foi desativado do cardápio (possui pedidos vinculados).");
            await Carregar();
        }
        else { Alert.MostrarErro($"Erro ao excluir produto: {await response.Content.ReadAsStringAsync()}"); }
    }

    // ── Modal Receita ──
    private async Task AbrirModalReceita(ProdutoDto p)
    {
        receitaProduto = p;
        mostrarModalReceita = true;
        novoInsumoId = 0;
        novaQtdeInsumo = 0;
        try
        {
            var rInsumos = await Http.GetFromJsonAsync<List<InsumoDto>>("api/insumos");
            if (rInsumos != null) todosInsumos = rInsumos;
        }
        catch { }
        await CarregarItensReceita(p.Id);
    }

    private void FecharModalReceita()
    {
        mostrarModalReceita = false;
        receitaProduto = null;
        itensReceita.Clear();
    }

    private async Task CarregarItensReceita(int produtoId)
    {
        try
        {
            var r = await Http.GetFromJsonAsync<List<ItemReceitaDto>>($"api/produtos/{produtoId}/receita");
            if (r != null) itensReceita = r;
        }
        catch { itensReceita.Clear(); }
    }

    private async Task AdicionarItemReceita()
    {
        if (receitaProduto == null || novoInsumoId == 0 || novaQtdeInsumo <= 0) return;
        salvandoReceita = true;
        try
        {
            var dto = new NovoItemReceitaDto { InsumoId = novoInsumoId, QuantidadePorUnidade = novaQtdeInsumo };
            var res = await Http.PostAsJsonAsync($"api/produtos/{receitaProduto.Id}/receita", dto);
            if (res.IsSuccessStatusCode)
            {
                await CarregarItensReceita(receitaProduto.Id);
                novoInsumoId = 0;
                novaQtdeInsumo = 0;
            }
            else { Alert.MostrarErro("Erro ao adicionar insumo à receita."); }
        }
        catch (Exception ex) { Alert.MostrarErro($"Erro de conexão: {ex.Message}"); }
        finally { salvandoReceita = false; }
    }

    private async Task RemoverItemReceita(int receitaId)
    {
        if (receitaProduto == null) return;
        try
        {
            var res = await Http.DeleteAsync($"api/produtos/{receitaProduto.Id}/receita/{receitaId}");
            if (res.IsSuccessStatusCode)
                await CarregarItensReceita(receitaProduto.Id);
        }
        catch { }
    }
}

    // FASE 7: Checkout Transparente Cartão
    private bool mostrarModalCartao = false;
    private bool cardBrickInitialized = false;
    private bool isSubmittingCartao = false;
    private string? cartaoStatusFinal = null;       // "approved" | "rejected" | null
    private string? cartaoStatusDetalhe = null;
    private string? cartaoErroCritico = null;
    private string? mpPublicKey = null;
    private DotNetObjectReference<CarrinhoOffcanvas>? _dotnetRef;
    private List<BairroDto> bairrosDisponiveis = new();
    private List<ProdutoDto> produtosLoja = new(); // Used for checking "Apples to Apples" stock

    // Divisão de Pagamento
    private string segundoPagamento = "";
    private decimal valorPrimeiroPagamento = 0m;
    private decimal valorSegundoPagamento = 0m;
    private bool mostrarDivisaoPagamento = false;

    private void AtivarDivisaoPagamento()
    {
        mostrarDivisaoPagamento = true;
        valorPrimeiroPagamento = ValorTotalPedido;
        valorSegundoPagamento = 0;
        segundoPagamento = "";
    }

    private void DesativarDivisaoPagamento()
    {
        mostrarDivisaoPagamento = false;
        valorPrimeiroPagamento = 0;
        valorSegundoPagamento = 0;
        segundoPagamento = "";
    }

    private void CalcularSegundoPagamento(ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out decimal valor))
        {
            valorPrimeiroPagamento = valor;
            if (valorPrimeiroPagamento < 0) valorPrimeiroPagamento = 0;
            if (valorPrimeiroPagamento > ValorTotalPedido) valorPrimeiroPagamento = ValorTotalPedido;
            valorSegundoPagamento = ValorTotalPedido - valorPrimeiroPagamento;
            if (valorSegundoPagamento <= 0.01m)
            {
                valorSegundoPagamento = 0;
                segundoPagamento = "";
            }
        }
        else
        {
            valorPrimeiroPagamento = 0;
            valorSegundoPagamento = ValorTotalPedido;
        }
    }

    private void UsarValorTotalPrimeiro()
    {
        valorPrimeiroPagamento = ValorTotalPedido;
        valorSegundoPagamento = 0;
        segundoPagamento = "";
    }

    protected override async Task OnInitializedAsync()
    {
        Carrinho.OnChange += StateHasChanged;
        
        try
        {
            var bairros = await Http.GetFromJsonAsync<List<BairroDto>>("api/bairros");
            if (bairros != null) bairrosDisponiveis = bairros;

            var prods = await Http.GetFromJsonAsync<List<ProdutoDto>>("api/produtos");
            if (prods != null) produtosLoja = prods;
        }
        catch { /* fail silently if API unavailable */ }
    }

    private decimal TaxaEntregaAtual 
    {
        get 
        {
            if (!string.IsNullOrEmpty(Carrinho.TempBairro) && int.TryParse(Carrinho.TempBairro, out int bairroId))
            {
                var bairro = bairrosDisponiveis.FirstOrDefault(b => b.Id == bairroId);
                return bairro?.TaxaEntrega ?? 0m;
            }
            return 0m;
        }
    }

    private decimal saldoCashback = 0;
    private string mensagemCashback = "";

    private bool _usarCashback = false;
    private decimal valorCashbackDesejado = 0m;
    
    private void ToggleCashback(ChangeEventArgs e)
    {
        _usarCashback = (bool)(e.Value ?? false);
        if (_usarCashback && valorCashbackDesejado == 0)
        {
            valorCashbackDesejado = MaxCashbackPermitido;
        }
    }

    private void UsarMaximoCashback()
    {
        valorCashbackDesejado = MaxCashbackPermitido;
    }

    private decimal MaxCashbackPermitido => Math.Min(Carrinho.Subtotal + TaxaEntregaAtual, saldoCashback);
    private string MaxCashbackString => MaxCashbackPermitido.ToString(System.Globalization.CultureInfo.InvariantCulture);
    
    private decimal ValorCashbackAplicado 
    {
        get 
        {
            if (!_usarCashback) return 0m;
            var val = valorCashbackDesejado;
            if (val < 0) val = 0;
            if (val > MaxCashbackPermitido) val = MaxCashbackPermitido;
            return val;
        }
    }

    private decimal ValorTotalPedido => (Carrinho.Subtotal + TaxaEntregaAtual) - ValorCashbackAplicado;

    private async Task OnTelefoneChanged(ChangeEventArgs e)
    {
        Carrinho.TempTelefone = e.Value?.ToString() ?? "";
        
        saldoCashback = 0;
        mensagemCashback = "";
        _usarCashback = false;
        valorCashbackDesejado = 0;
        
        if (string.IsNullOrWhiteSpace(Carrinho.TempTelefone)) return;

        var telLimpo = new string(Carrinho.TempTelefone.Where(c => char.IsDigit(c)).ToArray());
        if (telLimpo.Length < 8) return;

        try
        {
            var r = await Http.GetAsync($"api/cashback/saldo/{telLimpo}");
            if (r.IsSuccessStatusCode)
            {
                var dto = await r.Content.ReadFromJsonAsync<SaldoCashbackDto>();
                if (dto != null)
                {
                    if (dto.SaldoAtual > 0)
                    {
                        saldoCashback = dto.SaldoAtual;
                        mensagemCashback = $"Você tem R$ {dto.SaldoAtual:F2} de cashback disponível!";
                    }

                    // Auto-preenche o nome se estiver vazio
                    if (!string.IsNullOrWhiteSpace(dto.NomeCliente) && string.IsNullOrWhiteSpace(Carrinho.TempNome))
                    {
                        Carrinho.TempNome = dto.NomeCliente;
                    }
                }
            }
        }
        catch { }
    }

    public void Dispose()
    {
        Carrinho.OnChange -= StateHasChanged;
    }

    private void Remover(int produtoId)
    {
        Carrinho.RemoverItem(produtoId);
    }

    private async Task FinalizarPedido()
    {
        if (string.IsNullOrWhiteSpace(Carrinho.TempNome) || 
            string.IsNullOrWhiteSpace(Carrinho.TempRuaAvenida) || 
            string.IsNullOrWhiteSpace(Carrinho.TempNumeroLocal))
        {
            mensagemErro = "Por favor, preencha seu nome, a rua e o número da casa!";
            return;
        }
        
        if (string.IsNullOrEmpty(Carrinho.TempBairro))
        {
            mensagemErro = "Por favor, escolha o seu bairro para a entrega!";
            return;
        }
        
        if (string.IsNullOrEmpty(Carrinho.TempPagamento))
        {
            mensagemErro = "Por favor, escolha a forma de pagamento!";
            return;
        }

        // Cross-selling logic
        bool temBatata = Carrinho.Itens.Any(i => i.CategoriaId == CategoriaEnum.Batatas);
        bool temBebida = Carrinho.Itens.Any(i => i.CategoriaId == CategoriaEnum.Bebidas);

        bool lojaVendeBebida = produtosLoja.Any(p => p.CategoriaId == CategoriaEnum.Bebidas);
        bool lojaVendeBatata = produtosLoja.Any(p => p.CategoriaId == CategoriaEnum.Batatas);

        if (temBatata && !temBebida && lojaVendeBebida)
        {
            sugestaoTipo = "Bebida";
            mostrarModalSugestao = true;
            return;
        }
        if (!temBatata && temBebida && lojaVendeBatata)
        {
            sugestaoTipo = "Batata";
            mostrarModalSugestao = true;
            return;
        }

        // FASE 7: cartão → mostrar Brick antes de criar pedido
        if (Carrinho.TempPagamento == "2")
        {
            await AbrirModalCartaoAsync();
            return;
        }

        await ProcessarPedidoRealmente();
    }

    private void AceitarSugestao()
    {
        mostrarModalSugestao = false;
        Navigation.NavigateTo("/");
    }

    private async Task RecusarSugestao()
    {
        mostrarModalSugestao = false;
        if (Carrinho.TempPagamento == "2")
        {
            await AbrirModalCartaoAsync();
            return;
        }
        await ProcessarPedidoRealmente();
    }

    // ── FASE 7: Métodos MP Bricks ────────────────────────────────────────────

    private async Task AbrirModalCartaoAsync()
    {
        // Busca PublicKey do backend (apenas 1x por sessão)
        if (string.IsNullOrWhiteSpace(mpPublicKey))
        {
            try
            {
                var resp = await Http.GetAsync("api/pedidos/mp-public-key");
                if (resp.IsSuccessStatusCode)
                {
                    var json = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                    if (json.TryGetProperty("publicKey", out var pk))
                        mpPublicKey = pk.GetString();
                }
            }
            catch { }
        }

        if (string.IsNullOrWhiteSpace(mpPublicKey))
        {
            mensagemErro = "Pagamento com cartão indisponível no momento. Escolha outra forma.";
            return;
        }

        cartaoStatusFinal    = null;
        cartaoStatusDetalhe  = null;
        cartaoErroCritico    = null;
        cardBrickInitialized = false;
        isSubmittingCartao   = false;
        idPedidoConfirmado   = 0;
        valorFinalDoPedido   = ValorTotalPedido;
        resumoItensPedido    = string.Join(", ", Carrinho.Itens.Select(i => $"{i.Quantidade}x {i.NomeProduto}"));

        mostrarModalCartao = true;
        StateHasChanged(); // renderiza o modal + container div

        _dotnetRef = DotNetObjectReference.Create(this);
        // Aguarda render para que o #mp-card-brick-container exista no DOM
        await Task.Delay(100);
        await JS.InvokeVoidAsync("mpBricksInterop.initCardBrick",
            "mp-card-brick-container",
            (double)ValorTotalPedido,
            mpPublicKey,
            _dotnetRef);
        cardBrickInitialized = true;
    }

    [Microsoft.JSInterop.JSInvokable]
    public async Task OnCardBrickSubmit(string token, string paymentMethodId, int installments, string email)
    {
        if (isSubmittingCartao) return;
        isSubmittingCartao = true;
        cartaoErroCritico  = null;
        StateHasChanged();

        try
        {
            // Monta pedidoDto com token
            pedidoDto = new NovoPedidoDto();
            pedidoDto.Itens               = Carrinho.Itens.ToList();
            pedidoDto.NomeCliente         = Carrinho.TempNome;
            pedidoDto.TelefoneCliente     = Carrinho.TempTelefone;
            pedidoDto.EnderecoEntrega     = $"{Carrinho.TempRuaAvenida}, Nº {Carrinho.TempNumeroLocal} - {Carrinho.TempComplementoLocal}".TrimEnd(' ', '-');
            pedidoDto.MetodoPagamento     = MetodoPagamento.Cartao;
            pedidoDto.BairroEntregaId     = int.Parse(Carrinho.TempBairro);
            pedidoDto.ValorCashbackUsado  = ValorCashbackAplicado;
            pedidoDto.MomentoPagamento    = BatatasFritas.Shared.Enums.MomentoPagamento.Online; // cartão online
            pedidoDto.CardToken           = token;
            pedidoDto.CardPaymentMethodId = paymentMethodId;
            pedidoDto.CardInstallments    = installments > 0 ? installments : 1;
            pedidoDto.CardEmailPagador    = string.IsNullOrWhiteSpace(email)
                                            ? "cliente@batatasfritas.com.br"
                                            : email;

            var response = await Http.PostAsJsonAsync("api/pedidos", pedidoDto);

            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();

                if (json.TryGetProperty("pedidoId", out var idProp))
                    idPedidoConfirmado = idProp.GetInt32();

                string status = "pending";
                if (json.TryGetProperty("cartaoStatus", out var csProp) && csProp.ValueKind == System.Text.Json.JsonValueKind.String)
                    status = csProp.GetString() ?? "pending";

                if (json.TryGetProperty("cartaoStatusDetalhe", out var cdProp) && cdProp.ValueKind == System.Text.Json.JsonValueKind.String)
                    cartaoStatusDetalhe = cdProp.GetString();

                cartaoStatusFinal = status;

                if (status == "approved")
                {
                    Carrinho.LimparCarrinho();
                    pedidoDto = new NovoPedidoDto();
                }
                // rejected → mostra tela de erro no próprio modal
            }
            else
            {
                var erro = await response.Content.ReadAsStringAsync();
                cartaoErroCritico = $"Erro ao criar pedido: {erro}";
            }
        }
        catch (Exception ex)
        {
            cartaoErroCritico = $"Erro de conexão: {ex.Message}";
        }
        finally
        {
            isSubmittingCartao = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task FecharModalCartao()
    {
        mostrarModalCartao   = false;
        cardBrickInitialized = false;
        cartaoStatusFinal    = null;
        cartaoStatusDetalhe  = null;
        cartaoErroCritico    = null;
        isSubmittingCartao   = false;

        try { await JS.InvokeVoidAsync("mpBricksInterop.destroyCardBrick"); } catch { }
        _dotnetRef?.Dispose();
        _dotnetRef = null;

        if (idPedidoConfirmado > 0)
            Navigation.NavigateTo("/");
    }

    private async Task TentarNovamenteCartao()
    {
        cartaoStatusFinal   = null;
        cartaoStatusDetalhe = null;
        cartaoErroCritico   = null;
        idPedidoConfirmado  = 0;
        cardBrickInitialized = false;
        StateHasChanged();

        await Task.Delay(80);
        _dotnetRef ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("mpBricksInterop.initCardBrick",
            "mp-card-brick-container",
            (double)valorFinalDoPedido,
            mpPublicKey,
            _dotnetRef);
        cardBrickInitialized = true;
    }

    private async Task ProcessarPedidoRealmente()
    {
        isSubmitting = true;
        mensagemErro = "";
        mensagemSucesso = "";

        // Clone items directly from Cart
        pedidoDto.Itens = Carrinho.Itens.ToList();
        
        // Push State properties to Request DTO
        pedidoDto.NomeCliente = Carrinho.TempNome;
        pedidoDto.TelefoneCliente = Carrinho.TempTelefone;
        pedidoDto.EnderecoEntrega = $"{Carrinho.TempRuaAvenida}, Nº {Carrinho.TempNumeroLocal} - {Carrinho.TempComplementoLocal}".TrimEnd(' ', '-');
        pedidoDto.MetodoPagamento = (MetodoPagamento)int.Parse(Carrinho.TempPagamento);
        pedidoDto.BairroEntregaId = int.Parse(Carrinho.TempBairro);
        pedidoDto.ValorCashbackUsado = ValorCashbackAplicado;

        // Configurar divisão de pagamento se houver
        if (valorSegundoPagamento > 0 && !string.IsNullOrEmpty(segundoPagamento))
        {
            pedidoDto.SegundoMetodoPagamento = (MetodoPagamento)int.Parse(segundoPagamento);
            pedidoDto.ValorSegundoPagamento = valorSegundoPagamento;
        }

        // FASE 6: auto-derivar momento do pagamento (Pix=Online, demais=NaEntrega)
        pedidoDto.MomentoPagamento = pedidoDto.MetodoPagamento == MetodoPagamento.Pix
            ? BatatasFritas.Shared.Enums.MomentoPagamento.Online
            : BatatasFritas.Shared.Enums.MomentoPagamento.NaEntrega;
        if (pedidoDto.SegundoMetodoPagamento.HasValue)
            pedidoDto.SegundoMomentoPagamento = pedidoDto.SegundoMetodoPagamento == MetodoPagamento.Pix
                ? BatatasFritas.Shared.Enums.MomentoPagamento.Online
                : BatatasFritas.Shared.Enums.MomentoPagamento.NaEntrega;
        
        if (pedidoDto.MetodoPagamento == MetodoPagamento.Dinheiro && !string.IsNullOrWhiteSpace(Carrinho.TempTroco))
        {
            var cleaned = Carrinho.TempTroco.Replace("R$", "").Replace(" ", "");
            
            // Aceita virgula ou ponto, converte pra cultura Invariant e tenta fazer o Parse
            var isDecimal = decimal.TryParse(cleaned.Replace(",", "."), 
                System.Globalization.NumberStyles.Any, 
                System.Globalization.CultureInfo.InvariantCulture, 
                out var parsedTroco);
                
            if (isDecimal)
            {
                if (parsedTroco < ValorTotalPedido && parsedTroco > 0)
                {
                    mensagemErro = $"O valor do troco (R$ {parsedTroco.ToString("F2")}) não pode ser inferior ao Valor Total do pedido (R$ {ValorTotalPedido.ToString("F2")})!";
                    isSubmitting = false;
                    return;
                }
                pedidoDto.TrocoPara = parsedTroco;
            }
        }
        else
        {
            pedidoDto.TrocoPara = null;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("api/pedidos", pedidoDto);
            
            if (response.IsSuccessStatusCode)
            {
                var responseContent = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                
                int idRecebido = 0;
                if (responseContent.TryGetProperty("pedidoId", out var idProp))
                {
                    idRecebido = idProp.GetInt32();
                }

                // Captura link de pagamento (legacy) e QR Pix (FASE 5)
                linkPagamentoMP = null;
                qrCodeBase64 = null;
                qrCodeTexto = null;
                pagamentoAprovado = false;

                if (responseContent.TryGetProperty("linkPagamento", out var linkProp) && linkProp.ValueKind == System.Text.Json.JsonValueKind.String)
                {
                    var link = linkProp.GetString();
                    if (!string.IsNullOrWhiteSpace(link))
                        linkPagamentoMP = link;
                }

                if (responseContent.TryGetProperty("qrCodeBase64", out var qrProp) && qrProp.ValueKind == System.Text.Json.JsonValueKind.String)
                {
                    var qr = qrProp.GetString();
                    if (!string.IsNullOrWhiteSpace(qr))
                        qrCodeBase64 = qr;
                }

                if (responseContent.TryGetProperty("qrCodeTexto", out var qrTxtProp) && qrTxtProp.ValueKind == System.Text.Json.JsonValueKind.String)
                {
                    var qrTxt = qrTxtProp.GetString();
                    if (!string.IsNullOrWhiteSpace(qrTxt))
                        qrCodeTexto = qrTxt;
                }

                idPedidoConfirmado = idRecebido;
                valorFinalDoPedido = ValorTotalPedido;
                resumoItensPedido = string.Join(", ", Carrinho.Itens.Select(i => $"{i.Quantidade}x {i.NomeProduto}"));
                metodoPagamentoEscolhido = pedidoDto.MetodoPagamento;

                mostrarModalConfirmacao = true;
                mensagemSucesso = "Pedido recebido! Veja as instruções abaixo.";

                // Conecta SignalR + polling fallback se for Pix com QR
                if (metodoPagamentoEscolhido == MetodoPagamento.Pix && !string.IsNullOrWhiteSpace(qrCodeBase64))
                {
                    _ = ConectarSignalREPollingAsync(idPedidoConfirmado);
                }

                Carrinho.LimparCarrinho();
                pedidoDto = new NovoPedidoDto(); // Reset backend ref
            }
            else
            {
                mensagemErro = "Ops! Não conseguimos enviar o pedido para a cozinha. Tente novamente.";
            }
        }
        catch (Exception ex)
        {
            mensagemErro = $"Erro de conexão com o restaurante: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task FecharModalConfirmacao()
    {
        mostrarModalConfirmacao = false;
        await DesconectarPagamentoAsync();
        Navigation.NavigateTo("/");
    }

    private void VoltarCardapio()
    {
        // A simple navigation to home will close the offcanvas if it's route-based,
        // or the user can just use the standard layout close if it's CSS-based.
        Navigation.NavigateTo("/");
    }

    private async Task ConectarSignalREPollingAsync(int pedidoId)
    {
        try
        {
            var hubUrl = Navigation.ToAbsoluteUri("/hubs/pedidos");
            hubConnection = new HubConnectionBuilder()
                .WithUrl(hubUrl)
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<int>("PagamentoAprovado", id =>
            {
                if (id == pedidoId)
                {
                    pagamentoAprovado = true;
                    InvokeAsync(StateHasChanged);
                }
            });

            await hubConnection.StartAsync();
            await hubConnection.InvokeAsync("JoinPedidoGroup", pedidoId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SignalR] Falha ao conectar: {ex.Message}");
        }

        // Polling fallback a cada 5s (até 30min ou pagamento aprovado)
        pollingCts = new System.Threading.CancellationTokenSource();
        var token = pollingCts.Token;
        _ = Task.Run(async () =>
        {
            var fim = DateTime.UtcNow.AddMinutes(30);
            while (!token.IsCancellationRequested && !pagamentoAprovado && DateTime.UtcNow < fim)
            {
                try
                {
                    await Task.Delay(TimeSpan.FromSeconds(5), token);
                    if (pagamentoAprovado || token.IsCancellationRequested) break;

                    var resp = await Http.GetAsync($"api/pedidos/{pedidoId}");
                    if (resp.IsSuccessStatusCode)
                    {
                        var json = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                        if (json.TryGetProperty("statusPagamento", out var spProp))
                        {
                            // StatusPagamento.Aprovado = 2 (enum)
                            var sp = spProp.ValueKind == System.Text.Json.JsonValueKind.Number ? spProp.GetInt32() : -1;
                            if (sp == (int)StatusPagamento.Aprovado)
                            {
                                pagamentoAprovado = true;
                                await InvokeAsync(StateHasChanged);
                                break;
                            }
                        }
                    }
                }
                catch (TaskCanceledException) { break; }
                catch { /* ignora erros transitórios */ }
            }
        }, token);
    }

    private async Task DesconectarPagamentoAsync()
    {
        try { pollingCts?.Cancel(); } catch { }

        if (hubConnection is not null)
        {
            try
            {
                if (idPedidoConfirmado > 0)
                    await hubConnection.InvokeAsync("LeavePedidoGroup", idPedidoConfirmado);
                await hubConnection.DisposeAsync();
            }
            catch { }
            hubConnection = null;
        }
    }

    private async Task CopiarCodigoPixAsync()
    {
        if (string.IsNullOrWhiteSpace(qrCodeTexto)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", qrCodeTexto);
            codigoCopiado = true;
            StateHasChanged();
            _ = Task.Delay(2500).ContinueWith(_ =>
            {
                codigoCopiado = false;
                InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Clipboard] Falha: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        await DesconectarPagamentoAsync();
        try { await JS.InvokeVoidAsync("mpBricksInterop.destroyCardBrick"); } catch { }
        _dotnetRef?.Dispose();
    }
}

@page "/carrinho"
@using BatatasFritas.Web.Services
@using BatatasFritas.Shared.DTOs
@using BatatasFritas.Shared.Enums
@using System.Net.Http.Json
@using System.Linq
@using System
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject CarrinhoState Carrinho
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Microsoft.JSInterop.IJSRuntime JS

<div class="carrinho-container">
    <h2>Seu Carrinho</h2>
    
    @if (!Carrinho.Itens.Any())
    {
        <div style="text-align: center; margin-top: 50px;">
            <div style="font-size: 4rem; margin-bottom: 20px;">🛒</div>
            <p style="font-size: 1.2rem; font-weight: bold; color: #555;">O carrinho está vazio.</p>
            <p style="color: #888; margin-bottom: 25px;">Que tal adicionar umas batatas incríveis?</p>
            <button class="btn-confirmar" style="width: 100%; border-radius: 8px; padding: 15px; font-size: 1.1rem;" @onclick="@VoltarCardapio">Ver Cardápio</button>
        </div>
    }
    else
    {
        <ul class="carrinho-lista">
            @foreach (var item in Carrinho.Itens)
            {
                <li class="carrinho-item" style="display: flex; flex-direction: column; margin-bottom: 10px; border-bottom: 1px dashed #ccc; padding-bottom: 10px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                        <strong>@item.Quantidade x @item.NomeProduto</strong>
                        <span>R$ @((item.PrecoUnitario * item.Quantidade).ToString("F2"))</span>
                        <button @onclick="@(() => Remover(item.ProdutoId))" style="color: red; border: none; background: transparent; cursor: pointer; font-weight: bold; font-size: 1.2rem;">&times;</button>
                    </div>
                    @if (!string.IsNullOrEmpty(item.Observacao))
                    {
                        <span style="font-size: 0.85em; color: #777; margin-top: 4px;">@item.Observacao</span>
                    }
                </li>
            }
        </ul>
        <div class="checkout-form" style="margin-top: 2rem; border-top: 2px solid #000; padding-top: 1rem;">
            <h3>Finalizar Pedido</h3>
            @if (!string.IsNullOrEmpty(mensagemSucesso))
            {
                <div class="alert alert-success" style="background-color: #bbffbb; padding: 10px; border: 2px solid #000; font-weight: bold; margin-bottom: 1rem;">
                    @mensagemSucesso
                </div>
            }
            @if (!string.IsNullOrEmpty(mensagemErro))
            {
                <div class="alert alert-danger" style="background-color: #ffbbbb; padding: 10px; border: 2px solid #000; font-weight: bold; margin-bottom: 1rem;">
                    @mensagemErro
                </div>
            }
            
            <div style="display: flex; flex-direction: column; gap: 10px; max-width: 400px; margin-bottom: 20px;">
                <div style="margin-top: 5px;">
                    <label style="display: block; font-weight: 900; color: #d9534f; margin-bottom: 5px; font-size: 1rem;">Seu WhatsApp (Ganha Cashback! 🎁)</label>
                    <input value="@Carrinho.TempTelefone" @onchange="@OnTelefoneChanged" type="tel" placeholder="Ex: 91988887777" style="padding: 10px; border: 2px solid #000; width: 100%;" />
                </div>

                <div style="margin-top: 5px;">
                    <label style="display: block; font-weight: bold; margin-bottom: 5px; font-size: 0.9rem;">Seu Nome completo</label>
                    <input @bind="Carrinho.TempNome" type="text" placeholder="Como devemos te chamar?" style="padding: 10px; border: 2px solid #000; width: 100%;" />
                </div>


                
                <input @bind="Carrinho.TempRuaAvenida" type="text" placeholder="Rua / Avenida" style="padding: 10px; border: 2px solid #000;" />
                
                <div style="display: flex; gap: 10px;">
                    <input @bind="Carrinho.TempNumeroLocal" type="text" placeholder="Nº da Casa" style="padding: 10px; border: 2px solid #000; width: 35%;" />
                    <input @bind="Carrinho.TempComplementoLocal" type="text" placeholder="Ponto de Referência" style="padding: 10px; border: 2px solid #000; flex: 1;" />
                </div>
                
                <select @bind="Carrinho.TempBairro" style="padding: 10px; border: 2px solid #000; color: #000; background-color: #fff;">
                    <option value="" disabled selected>Bairro de Entrega...</option>
                    @foreach (var b in bairrosDisponiveis)
                    {
                        <option value="@b.Id">@b.Nome (+ R$ @b.TaxaEntrega.ToString("F2"))</option>
                    }
                </select>

                <select @bind="Carrinho.TempPagamento" style="padding: 10px; border: 2px solid #000; color: #000; background-color: #fff;">
                    <option value="" disabled selected>Forma de Pagamento...</option>
                    <option value="1">💵 Dinheiro</option>
                    <option value="2">💳 Cartão (Crédito/Débito)</option>
                    <option value="4">📱 PIX</option>
                </select>

                @if (saldoCashback > 0)
                {
                    <div style="background-color: #fff8ee; border: 2px solid #ffb347; padding: 12px; border-radius: 8px; font-weight: bold; color: #e67e22; box-shadow: 0 4px 10px rgba(0,0,0,0.05); margin-top: 5px; margin-bottom: 5px;">
                        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: @(_usarCashback ? "15px" : "0");">
                            <div style="flex: 1;">
                                <span style="font-size: 0.8rem; display: block; color: #888; text-transform: uppercase;">Saldo Disponível</span>
                                <span style="font-size: 1.1rem;">R$ @saldoCashback.ToString("F2")</span>
                            </div>
                            <label style="display:flex; align-items:center; cursor:pointer; background: #ffb347; color: #000; padding: 6px 12px; border-radius: 6px; font-size: 0.85rem;">
                                <input type="checkbox" checked="@_usarCashback" @onchange="@ToggleCashback" style="width:16px; height:16px; margin-right:8px;" />
                                USAR SALDO
                            </label>
                        </div>

                        @if (_usarCashback)
                        {
                            <div style="background:#fff; border: 1px solid #ffb347; padding:10px; border-radius:6px; color:#333; margin-top:10px;">
                                <label style="display:block; font-size:0.8rem; margin-bottom:6px; color:#888;">Quero descontar:</label>
                                <div style="display:flex; gap:8px; align-items:center;">
                                    <span style="font-size:1rem; font-weight:bold;">R$</span>
                                    <input type="number" step="0.01" min="0" max="@MaxCashbackString" @bind="@valorCashbackDesejado" style="flex-grow:1; max-width:100px; padding:6px; font-size:1rem; font-weight:bold; border:2px solid #ffb347; border-radius:6px;" />
                                    <button @onclick="@UsarMaximoCashback" style="background:#ffb347; color:#000; border:none; padding:8px 10px; border-radius:6px; font-weight:bold; cursor:pointer; font-size:0.8rem;">MAX</button>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (Carrinho.TempPagamento == "1")
                {
                    <input @bind="Carrinho.TempTroco" type="text" placeholder="Precisa de troco para quanto? (Ex: 50,00)" style="padding: 10px; border: 2px solid #000;" />
                }

                <!-- SELETOR ÚNICO DE PAGAMENTO -->
                @if (!string.IsNullOrEmpty(Carrinho.TempPagamento) && ValorTotalPedido > 0 && !mostrarDivisaoPagamento)
                {
                    <button @onclick="AtivarDivisaoPagamento" 
                            style="background: linear-gradient(135deg, #4CAF50, #2E7D32); border: none; color: #fff; padding: 14px 20px; border-radius: 12px; font-size: 1rem; font-weight: 700; cursor: pointer; margin-top: 12px; width: 100%; display: flex; align-items: center; justify-content: center; gap: 10px; box-shadow: 0 4px 15px rgba(76, 175, 80, 0.35); transition: transform 0.2s, box-shadow 0.2s;">
                        💰 Pagar com 2 Meios de Pagamento
                    </button>
                }

                <!-- DIVISÃO DE PAGAMENTO (só aparece ao ativar manualmente) -->
                @if (mostrarDivisaoPagamento && !string.IsNullOrEmpty(Carrinho.TempPagamento) && ValorTotalPedido > 0)
                {
                    var metodoNome = Carrinho.TempPagamento switch
                    {
                        "1" => "Dinheiro",
                        "2" => "Cartão",
                        "4" => "PIX",
                        _ => "1º Pagamento"
                    };

                    <div style="background:#222; border:2px solid #4CAF50; border-radius:12px; padding:16px; margin-top:15px; text-align:left;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                            <h3 style="color:#4CAF50; margin:0; font-size:1.1rem;">💰 Dividir Pagamento</h3>
                            <button @onclick="DesativarDivisaoPagamento" style="background:transparent; border:none; color:#888; font-size:1.3rem; cursor:pointer; padding:4px 8px;">✕</button>
                        </div>
                        <p style="color:#aaa; margin:0 0 15px 0; font-size:0.9rem;">Informe o valor de cada método:</p>
                        
                        <div style="background:#333; padding:15px; border-radius:8px; margin-bottom:15px;">
                            <label style="display:block; font-size:0.95rem; margin-bottom:8px;">1º - @metodoNome:</label>
                            <div style="display:flex; gap:10px; align-items:center;">
                                <span style="font-size:1.1rem; font-weight:bold;">R$</span>
                                <input type="number" step="0.01" min="0.01" max="@((ValorTotalPedido - 0.01m).ToString(System.Globalization.CultureInfo.InvariantCulture))" @bind="valorPrimeiroPagamento" @oninput="CalcularSegundoPagamento" style="flex-grow:1; max-width:120px; padding:8px; font-size:1.1rem; font-weight:bold; border:2px solid #4CAF50; border-radius:6px; background:#111; color:#fff;" />
                                <button @onclick="UsarValorTotalPrimeiro" style="background:#4CAF50; color:#fff; border:none; padding:8px 12px; border-radius:6px; font-weight:bold; cursor:pointer; font-size:0.9rem;">TOTAL (@ValorTotalPedido.ToString("C2"))</button>
                            </div>
                        </div>

                        @if (valorSegundoPagamento > 0)
                        {
                            <div style="border-top:1px solid #555; padding-top:15px;">
                                <label style="display:block; font-size:0.95rem; margin-bottom:8px;">2º Método:</label>
                                <div style="display:flex; gap:8px; flex-wrap:wrap;">
                                    @foreach (var opt in new[] { "2", "4", "1" }.Where(o => o != Carrinho.TempPagamento))
                                    {
                                        <button class="totem-opt-btn @(segundoPagamento == opt ? "active" : "")" 
                                                @onclick='() => { segundoPagamento = opt; }' style="flex:1; min-width:70px; padding:8px; background:#333; color:#fff; border:2px solid @(segundoPagamento == opt ? "#4CAF50" : "#555"); border-radius:8px; cursor:pointer; text-align:center;">
                                            <span style="font-size:1.1rem;">@(opt == "1" ? "💵" : opt == "2" ? "💳" : "📱")</span><br><small>@(opt == "1" ? "Dinheiro" : opt == "2" ? "Cartão" : "PIX")</small>
                                        </button>
                                    }
                                </div>
                                <div style="margin-top:10px; text-align:center;">
                                    <span style="color:#ffb347; font-size:1rem;">Restante: <strong>@valorSegundoPagamento.ToString("C2")</strong></span>
                                </div>
                            </div>
                        }

                        <!-- VALIDAÇÃO -->
                        @if (valorPrimeiroPagamento > 0 && valorSegundoPagamento > 0)
                        {
                            var soma = valorPrimeiroPagamento + valorSegundoPagamento;
                            var diff = Math.Abs(soma - ValorTotalPedido);
                            @if (diff > 0.01m)
                            {
                                <div style="background:#3a0000; border:1px solid #ff4444; color:#ff6b6b; padding:8px; border-radius:6px; margin-top:10px; font-size:0.85rem; text-align:center;">
                                    ⚠️ Soma (R$ @soma.ToString("C2")) ≠ Total (R$ @ValorTotalPedido.ToString("C2"))
                                </div>
                            }
                            else
                            {
                                <div style="background:#003300; border:1px solid #4CAF50; color:#4CAF50; padding:8px; border-radius:6px; margin-top:10px; font-size:0.85rem; text-align:center;">
                                    ✅ Valores conferem!
                                </div>
                            }
                        }
                    </div>
                }
            </div>

            <div class="carrinho-total" style="flex-direction: column; align-items: stretch; gap: 5px;">
                @if (!string.IsNullOrEmpty(Carrinho.TempBairro))
                {
                    <div style="display: flex; justify-content: space-between; font-size: 1.1em; color: #555;">
                        <span>Subtotal:</span>
                        <span>R$ @Carrinho.Subtotal.ToString("F2")</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 1.1em; color: #555;">
                        <span>Taxa de Entrega:</span>
                        <span>R$ @TaxaEntregaAtual.ToString("F2")</span>
                    </div>
                }
                @if (_usarCashback && ValorCashbackAplicado > 0)
                {
                    <div style="display: flex; justify-content: space-between; font-size: 1.1em; color: #27ae60; font-weight: bold;">
                        <span>🎁 Desconto Cashback:</span>
                        <span>- R$ @ValorCashbackAplicado.ToString("F2")</span>
                    </div>
                }
                <div style="display: flex; justify-content: space-between; font-size: 1.4em; font-weight: 900; color: #d9534f; margin-top: 5px; border-top: 2px dashed #000; padding-top: 10px;">
                    <span>TOTAL:</span>
                    <span>R$ @ValorTotalPedido.ToString("F2")</span>
                </div>
                
                <button class="btn-finalizar" style="background: #000; color: #fff; border: 2px solid #000; padding: 10px 20px; font-weight: 900; cursor: pointer; text-transform: uppercase; width: 100%; margin-top: 15px;" @onclick="@FinalizarPedido" disabled="@isSubmitting">
                    @(isSubmitting ? "Enviando..." : "Mandar pra Cozinha 🚀")
                </button>
            </div>
        </div>
    }
</div>

@if (mostrarModalConfirmacao && metodoPagamentoEscolhido == MetodoPagamento.Pix && !string.IsNullOrWhiteSpace(qrCodeBase64))
{
    <div class="modal-overlay" style="align-items: center; padding: 20px; background: rgba(0,0,0,0.85);">
        <div class="modal-content" style="text-align: center; max-width: 500px; padding: 28px; border-radius: 16px; border: 3px solid #ffb347; box-shadow: 0 10px 50px rgba(0,0,0,0.5);">
            @if (pagamentoAprovado)
            {
                var msgPosPix = $"Olá! Pedido #{idPedidoConfirmado:D3} — pagamento aprovado via Pix ✅. Segue minha localização para a entrega.";
                var linkWhatsPosPix = $"https://wa.me/5591986201943?text={Uri.EscapeDataString(msgPosPix)}";

                <div style="font-size: 5rem; margin-bottom: 4px;">✅</div>
                <h2 style="color: #25D366; font-weight: 900; margin-bottom: 4px; text-transform: uppercase;">Pagamento confirmado!</h2>
                <p style="color: #ffb347; font-weight: 700; margin-bottom: 16px;">Pedido #@idPedidoConfirmado.ToString("D3")</p>

                <p style="font-size: 1.05rem; margin-bottom: 14px; line-height: 1.4; color: #333;">
                    Seu pedido já foi enviado para a cozinha! <b>Envie sua localização atual pelo WhatsApp para facilitar a entrega.</b>
                </p>

                <div style="background: #fff8ee; border: 2px dashed #ffb347; border-radius: 12px; padding: 16px; margin-bottom: 18px; text-align: left;">
                    <p style="margin: 0; font-size: 0.8rem; color: #888; text-transform: uppercase; font-weight: bold;">Resumo do Pedido:</p>
                    <p style="margin: 5px 0; font-size: 0.95rem; color: #333; line-height: 1.3;">
                        @resumoItensPedido
                    </p>
                    <div style="margin-top: 10px; display:flex; justify-content:space-between; align-items:flex-end; border-top: 1px solid #ffe0b2; padding-top: 10px;">
                        <span style="font-size: 0.8rem; color: #888; text-transform: uppercase; font-weight: bold;">Total Pago:</span>
                        <span style="font-size: 1.3rem; font-weight: 900; color: #25D366;">R$ @valorFinalDoPedido.ToString("N2")</span>
                    </div>
                </div>

                <a href="@linkWhatsPosPix"
                   target="_blank"
                   class="btn-confirmar"
                   style="display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; border-radius: 12px; padding: 18px; font-size: 1.15rem; background: #25D366; border: none; color: #fff; text-decoration: none; font-weight: 900; box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4);">
                    <span>ENVIAR LOCALIZAÇÃO NO WHATSAPP</span> ✅
                </a>

                <button class="btn-cancelar" style="margin-top: 16px; background: transparent; border: 1px solid #ddd; width: 100%; color: #999; padding: 10px; border-radius: 8px; font-weight: 600;" @onclick="@FecharModalConfirmacao">Já enviei / Fechar</button>
            }
            else
            {
                <h2 style="color: #000; font-weight: 900; margin-bottom: 4px; text-transform: uppercase; font-size: 1.4rem;">PIX · PAGAMENTO INSTANTÂNEO</h2>
                <p style="color: #ffb347; font-weight: 700; margin-bottom: 14px;">Pedido #@idPedidoConfirmado.ToString("D3") · R$ @valorFinalDoPedido.ToString("N2")</p>

                <div style="display:flex; justify-content:center; margin-bottom:14px;">
                    <img src="data:image/png;base64,@qrCodeBase64" alt="QR Code Pix"
                         style="width: 220px; height: 220px; border: 8px solid #fff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.12);" />
                </div>

                <p style="font-size: 0.95rem; color:#555; margin-bottom: 14px;">Escaneie o QR Code com o app do seu banco</p>

                <div style="display:flex; align-items:center; gap:10px; margin: 10px 0 14px;">
                    <hr style="flex:1; border: none; border-top: 1px solid #ddd;" />
                    <span style="color:#888; font-size:0.85rem; font-weight:600;">ou copie e cole</span>
                    <hr style="flex:1; border: none; border-top: 1px solid #ddd;" />
                </div>

                <textarea readonly
                          style="width: 100%; max-width: 100%; min-height: 70px; font-family: ui-monospace, Menlo, monospace; font-size: 0.72rem; padding: 12px; border: 2px dashed #ffb347; background: #fff; color:#333; border-radius: 8px; resize: none; margin-bottom: 12px;">@qrCodeTexto</textarea>

                <button class="btn-confirmar"
                        style="display:flex; align-items:center; justify-content:center; gap:8px; width: 100%; border-radius: 12px; padding: 16px; font-size: 1.1rem; background: #009EE3; border: none; color: #fff; font-weight: 900; box-shadow: 0 4px 15px rgba(0,158,227,0.4); cursor:pointer;"
                        @onclick="@CopiarCodigoPixAsync">
                    <span>@(codigoCopiado ? "✓ Código Pix copiado!" : "📋 Copiar código Pix")</span>
                </button>

                <p style="margin-top: 16px; font-size: 0.85rem; color: #888; font-style: italic;">O pagamento é confirmado automaticamente em segundos.</p>

                <button class="btn-cancelar" style="margin-top: 12px; background: transparent; border: 1px solid #ddd; width: 100%; color: #999; padding: 10px; border-radius: 8px; font-weight: 600;" @onclick="@FecharModalConfirmacao">Cancelar pedido</button>
            }
        </div>
    </div>
}
else if (mostrarModalConfirmacao)
{
    var metodo = metodoPagamentoEscolhido;
    string icone = metodo == MetodoPagamento.Pix ? "🛡️" : (metodo == MetodoPagamento.Dinheiro ? "💵" : "💳");
    string titulo = metodo == MetodoPagamento.Pix ? "Aguardando Pagamento" : "Pedido em Processamento";

    <div class="modal-overlay" style="align-items: center; padding: 20px; background: rgba(0,0,0,0.8);">
        <div class="modal-content" style="text-align: center; max-width: 500px; padding: 30px; border-radius: 16px; border: 3px solid #ffb347; box-shadow: 0 10px 50px rgba(0,0,0,0.5);">
            <div style="font-size: 4rem; margin-bottom: 10px;">@icone</div>
            <h2 style="color: #000; font-weight: 900; margin-bottom: 5px; text-transform: uppercase;">@titulo</h2>
            <p style="color: #ffb347; font-weight: 700; margin-bottom: 20px;">Pedido #@idPedidoConfirmado.ToString("D3")</p>
            
            <p style="font-size: 1.1rem; margin-bottom: 15px; line-height: 1.4;">
                @if (metodo == MetodoPagamento.Pix && !string.IsNullOrWhiteSpace(linkPagamentoMP))
                {
                    <text>Pague pelo Mercado Pago. <b>Seu pedido será preparado automaticamente após a confirmação.</b></text>
                }
                else if (metodo == MetodoPagamento.Pix)
                {
                    <text>Seu pedido foi recebido, mas <b>só começaremos a preparar após a confirmação do PIX e recebimento da sua localização pelo WhatsApp.</b></text>
                }
                else
                {
                    <text>Seu pedido foi recebido! <b>Por favor, envie sua localização atual pelo WhatsApp para facilitar a entrega pelo nosso motoboy.</b></text>
                }
            </p>
            
            <div style="background: #fff8ee; border: 2px dashed #ffb347; border-radius: 12px; padding: 20px; margin-bottom: 20px; text-align: left;">
                <div style="margin-bottom: 15px; border-bottom: 1px solid #ffe0b2; padding-bottom: 10px;">
                    <p style="margin: 0; font-size: 0.8rem; color: #888; text-transform: uppercase; font-weight: bold;">Resumo do Pedido:</p>
                    <p style="margin: 5px 0; font-size: 0.95rem; color: #333; line-height: 1.3;">
                        @resumoItensPedido
                    </p>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: flex-end;">
                    <div>
                        <p style="margin: 0; font-size: 0.8rem; color: #888; text-transform: uppercase; font-weight: bold;">Chave PIX / Dúvidas:</p>
                        <p style="margin: 5px 0; font-size: 1.4rem; font-weight: 900; color: #000;">91 98620-1943</p>
                    </div>
                    <div style="text-align: right;">
                        <p style="margin: 0; font-size: 0.8rem; color: #888; text-transform: uppercase; font-weight: bold;">Total:</p>
                        <p style="margin: 5px 0; font-size: 1.6rem; font-weight: 900; color: #d9534f;">R$ @valorFinalDoPedido.ToString("N2")</p>
                    </div>
                </div>
            </div>

            <p style="color: #d9534f; font-weight: 800; font-size: 1.05rem; margin-bottom: 25px;">
                @if (metodo == MetodoPagamento.Pix)
                {
                    <text>⚠️ Envie o <u>Comprovante</u> E sua <u>Localização Atual</u> pelo WhatsApp:</text>
                }
                else
                {
                    <text>⚠️ Facilite a entrega! Envie sua <u>Localização Atual</u> pelo WhatsApp:</text>
                }
            </p>

            @{
                string msgStatus = "";
                if (metodo == MetodoPagamento.Pix) msgStatus = $"Aqui está o comprovante do PIX no valor de R$ {valorFinalDoPedido:N2} e minha localização para a entrega.";
                else if (metodo == MetodoPagamento.Dinheiro) msgStatus = $"O pagamento será em Dinheiro (Total: R$ {valorFinalDoPedido:N2}). Segue minha localização para a entrega.";
                else if (metodo == MetodoPagamento.Cartao) msgStatus = $"O pagamento será no Cartão Crédito/Débito (Total: R$ {valorFinalDoPedido:N2}). Segue minha localização para a entrega.";
                
                var textoWhats = $"Olá! Acabei de fazer o pedido #{idPedidoConfirmado:D3}. {msgStatus}";
                var linkWhats = $"https://wa.me/5591986201943?text={Uri.EscapeDataString(textoWhats)}";
            }
            @if (metodo == MetodoPagamento.Pix && !string.IsNullOrWhiteSpace(linkPagamentoMP))
            {
                <a href="@linkPagamentoMP"
                   target="_blank"

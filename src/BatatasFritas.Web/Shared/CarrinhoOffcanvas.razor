@page "/carrinho"
@using BatatasFritas.Web.Services
@using BatatasFritas.Shared.DTOs
@using BatatasFritas.Shared.Enums
@using System.Net.Http.Json
@inject CarrinhoState Carrinho
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="carrinho-container">
    <h2>Seu Carrinho</h2>
    
    @if (!Carrinho.Itens.Any())
    {
        <div style="text-align: center; margin-top: 50px;">
            <div style="font-size: 4rem; margin-bottom: 20px;">🛒</div>
            <p style="font-size: 1.2rem; font-weight: bold; color: #555;">O carrinho está vazio.</p>
            <p style="color: #888; margin-bottom: 25px;">Que tal adicionar umas batatas incríveis?</p>
            <button class="btn-confirmar" style="width: 100%; border-radius: 8px; padding: 15px; font-size: 1.1rem;" @onclick="VoltarCardapio">Ver Cardápio</button>
        </div>
    }
    else
    {
        <ul class="carrinho-lista">
            @foreach (var item in Carrinho.Itens)
            {
                <li class="carrinho-item" style="display: flex; flex-direction: column; margin-bottom: 10px; border-bottom: 1px dashed #ccc; padding-bottom: 10px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                        <strong>@item.Quantidade x @item.NomeProduto</strong>
                        <span>R$ @((item.PrecoUnitario * item.Quantidade).ToString("F2"))</span>
                        <button @onclick="() => Remover(item.ProdutoId)" style="color: red; border: none; background: transparent; cursor: pointer; font-weight: bold; font-size: 1.2rem;">&times;</button>
                    </div>
                    @if (!string.IsNullOrEmpty(item.Observacao))
                    {
                        <span style="font-size: 0.85em; color: #777; margin-top: 4px;">@item.Observacao</span>
                    }
                </li>
            }
        </ul>
        <div class="checkout-form" style="margin-top: 2rem; border-top: 2px solid #000; padding-top: 1rem;">
            <h3>Finalizar Pedido</h3>
            @if (!string.IsNullOrEmpty(mensagemSucesso))
            {
                <div class="alert alert-success" style="background-color: #bbffbb; padding: 10px; border: 2px solid #000; font-weight: bold; margin-bottom: 1rem;">
                    @mensagemSucesso
                </div>
            }
            @if (!string.IsNullOrEmpty(mensagemErro))
            {
                <div class="alert alert-danger" style="background-color: #ffbbbb; padding: 10px; border: 2px solid #000; font-weight: bold; margin-bottom: 1rem;">
                    @mensagemErro
                </div>
            }
            
            <div style="display: flex; flex-direction: column; gap: 10px; max-width: 400px; margin-bottom: 20px;">
                <input @bind="Carrinho.TempNome" type="text" placeholder="Seu Nome completo" style="padding: 10px; border: 2px solid #000;" />
                
                <div style="margin-top: 5px;">
                    <label style="display: block; font-weight: 900; color: #d9534f; margin-bottom: 5px; font-size: 1rem;">Seu WhatsApp (Ganha Cashback! 🎁)</label>
                    <input value="@Carrinho.TempTelefone" @onchange="OnTelefoneChanged" type="text" placeholder="Ex: 91999999999" style="padding: 10px; border: 2px solid #000; width: 100%;" />
                </div>


                
                <input @bind="Carrinho.TempRuaAvenida" type="text" placeholder="Rua / Avenida" style="padding: 10px; border: 2px solid #000;" />
                
                <div style="display: flex; gap: 10px;">
                    <input @bind="Carrinho.TempNumeroLocal" type="text" placeholder="Nº da Casa" style="padding: 10px; border: 2px solid #000; width: 35%;" />
                    <input @bind="Carrinho.TempComplementoLocal" type="text" placeholder="Ponto de Referência" style="padding: 10px; border: 2px solid #000; flex: 1;" />
                </div>
                
                <select @bind="Carrinho.TempBairro" style="padding: 10px; border: 2px solid #000; color: #000; background-color: #fff;">
                    <option value="" disabled selected>Bairro de Entrega...</option>
                    @foreach (var b in bairrosDisponiveis)
                    {
                        <option value="@b.Id">@b.Nome (+ R$ @b.TaxaEntrega.ToString("F2"))</option>
                    }
                </select>

                <select @bind="Carrinho.TempPagamento" style="padding: 10px; border: 2px solid #000; color: #000; background-color: #fff;">
                    <option value="" disabled selected>Forma de Pagamento...</option>
                    <option value="1">Dinheiro</option>
                    <option value="2">Cartão (Na Maquininha do Motoboy)</option>
                    <option value="4">PIX (Pagar Agora)</option>
                    <option value="5">💳 Pagar Agora (Cartão/PIX Online)</option>
                </select>

                @if (saldoCashback > 0)
                {
                    <div style="background-color: #fff8ee; border: 2px solid #ffb347; padding: 12px; border-radius: 8px; font-weight: bold; color: #e67e22; box-shadow: 0 4px 10px rgba(0,0,0,0.05); margin-top: 5px; margin-bottom: 5px;">
                        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: @(_usarCashback ? "15px" : "0");">
                            <div style="flex: 1;">
                                <span style="font-size: 0.8rem; display: block; color: #888; text-transform: uppercase;">Saldo Disponível</span>
                                <span style="font-size: 1.1rem;">R$ @saldoCashback.ToString("F2")</span>
                            </div>
                            <label style="display:flex; align-items:center; cursor:pointer; background: #ffb347; color: #000; padding: 6px 12px; border-radius: 6px; font-size: 0.85rem;">
                                <input type="checkbox" checked="@_usarCashback" @onchange="ToggleCashback" style="width:16px; height:16px; margin-right:8px;" />
                                USAR SALDO
                            </label>
                        </div>

                        @if (_usarCashback)
                        {
                            <div style="background:#fff; border: 1px solid #ffb347; padding:10px; border-radius:6px; color:#333; margin-top:10px;">
                                <label style="display:block; font-size:0.8rem; margin-bottom:6px; color:#888;">Quero descontar:</label>
                                <div style="display:flex; gap:8px; align-items:center;">
                                    <span style="font-size:1rem; font-weight:bold;">R$</span>
                                    <input type="number" step="0.01" min="0" max="@MaxCashbackPermitido.ToString(System.Globalization.CultureInfo.InvariantCulture)" @bind="valorCashbackDesejado" style="flex-grow:1; max-width:100px; padding:6px; font-size:1rem; font-weight:bold; border:2px solid #ffb347; border-radius:6px;" />
                                    <button @onclick="UsarMaximoCashback" style="background:#ffb347; color:#000; border:none; padding:8px 10px; border-radius:6px; font-weight:bold; cursor:pointer; font-size:0.8rem;">MAX</button>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (Carrinho.TempPagamento == "1")
                {
                    <input @bind="Carrinho.TempTroco" type="text" placeholder="Precisa de troco para quanto? (Ex: 50,00)" style="padding: 10px; border: 2px solid #000;" />
                }
            </div>

            <div class="carrinho-total" style="flex-direction: column; align-items: stretch; gap: 5px;">
                @if (!string.IsNullOrEmpty(Carrinho.TempBairro))
                {
                    <div style="display: flex; justify-content: space-between; font-size: 1.1em; color: #555;">
                        <span>Subtotal:</span>
                        <span>R$ @Carrinho.Subtotal.ToString("F2")</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 1.1em; color: #555;">
                        <span>Taxa de Entrega:</span>
                        <span>R$ @TaxaEntregaAtual.ToString("F2")</span>
                    </div>
                }
                @if (_usarCashback && ValorCashbackAplicado > 0)
                {
                    <div style="display: flex; justify-content: space-between; font-size: 1.1em; color: #27ae60; font-weight: bold;">
                        <span>🎁 Desconto Cashback:</span>
                        <span>- R$ @ValorCashbackAplicado.ToString("F2")</span>
                    </div>
                }
                <div style="display: flex; justify-content: space-between; font-size: 1.4em; font-weight: 900; color: #d9534f; margin-top: 5px; border-top: 2px dashed #000; padding-top: 10px;">
                    <span>TOTAL:</span>
                    <span>R$ @ValorTotalPedido.ToString("F2")</span>
                </div>
                
                <button class="btn-finalizar" style="background: #000; color: #fff; border: 2px solid #000; padding: 10px 20px; font-weight: 900; cursor: pointer; text-transform: uppercase; width: 100%; margin-top: 15px;" @onclick="FinalizarPedido" disabled="@isSubmitting">
                    @(isSubmitting ? "Enviando..." : "Mandar pra Cozinha 🚀")
                </button>
            </div>
        </div>
    }
</div>

@if (mostrarModalConfirmacao)
{
    var metodo = metodoPagamentoEscolhido;
    string icone = metodo == MetodoPagamento.Pix ? "🛡️" : (metodo == MetodoPagamento.Dinheiro ? "💵" : "💳");
    string titulo = metodo == MetodoPagamento.Pix ? "Aguardando Pagamento" : "Pedido em Processamento";
    
    <div class="modal-overlay" style="align-items: center; padding: 20px; background: rgba(0,0,0,0.8);">
        <div class="modal-content" style="text-align: center; max-width: 500px; padding: 30px; border-radius: 16px; border: 3px solid #ffb347; box-shadow: 0 10px 50px rgba(0,0,0,0.5);">
            <div style="font-size: 4rem; margin-bottom: 10px;">@icone</div>
            <h2 style="color: #000; font-weight: 900; margin-bottom: 5px; text-transform: uppercase;">@titulo</h2>
            <p style="color: #ffb347; font-weight: 700; margin-bottom: 20px;">Pedido #@idPedidoConfirmado.ToString("D3")</p>
            
            <p style="font-size: 1.1rem; margin-bottom: 15px; line-height: 1.4;">
                @if (metodo == MetodoPagamento.Pix)
                {
                    <text>Seu pedido foi recebido, mas <b>só começaremos a preparar após a confirmação do PIX e recebimento da sua localização pelo WhatsApp.</b></text>
                }
                else if (metodo == MetodoPagamento.InfinitePayOnline)
                {
                    <text>Seu pedido foi recebido! <b>Chame no WhatsApp agora mesmo para solicitar seu Link de Pagamento e enviar a sua localização atual de entrega.</b></text>
                }
                else
                {
                    <text>Seu pedido foi recebido! <b>Por favor, envie sua localização atual pelo WhatsApp para facilitar a entrega pelo nosso motoboy.</b></text>
                }
            </p>
            
            <div style="background: #fff8ee; border: 2px dashed #ffb347; border-radius: 12px; padding: 20px; margin-bottom: 20px; text-align: left;">
                <div style="margin-bottom: 15px; border-bottom: 1px solid #ffe0b2; padding-bottom: 10px;">
                    <p style="margin: 0; font-size: 0.8rem; color: #888; text-transform: uppercase; font-weight: bold;">Resumo do Pedido:</p>
                    <p style="margin: 5px 0; font-size: 0.95rem; color: #333; line-height: 1.3;">
                        @resumoItensPedido
                    </p>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: flex-end;">
                    <div>
                        <p style="margin: 0; font-size: 0.8rem; color: #888; text-transform: uppercase; font-weight: bold;">Chave PIX / Dúvidas:</p>
                        <p style="margin: 5px 0; font-size: 1.4rem; font-weight: 900; color: #000;">91 98620-1943</p>
                    </div>
                    <div style="text-align: right;">
                        <p style="margin: 0; font-size: 0.8rem; color: #888; text-transform: uppercase; font-weight: bold;">Total:</p>
                        <p style="margin: 5px 0; font-size: 1.6rem; font-weight: 900; color: #d9534f;">R$ @valorFinalDoPedido.ToString("N2")</p>
                    </div>
                </div>
            </div>

            <p style="color: #d9534f; font-weight: 800; font-size: 1.05rem; margin-bottom: 25px;">
                @if (metodo == MetodoPagamento.Pix)
                {
                    <text>⚠️ Envie o <u>Comprovante</u> E sua <u>Localização Atual</u> pelo WhatsApp:</text>
                }
                else if (metodo == MetodoPagamento.InfinitePayOnline)
                {
                    <text>⚠️ Peça o <u>Link de Pagamento</u> E envie sua <u>Localização Atual</u>:</text>
                }
                else
                {
                    <text>⚠️ Facilite a entrega! Envie sua <u>Localização Atual</u> pelo WhatsApp:</text>
                }
            </p>

            @{
                string msgStatus = "";
                if (metodo == MetodoPagamento.Pix) msgStatus = $"Aqui está o comprovante do PIX no valor de R$ {valorFinalDoPedido:N2} e minha localização para a entrega.";
                else if (metodo == MetodoPagamento.Dinheiro) msgStatus = $"O pagamento será em Dinheiro (Total: R$ {valorFinalDoPedido:N2}). Segue minha localização para a entrega.";
                else if (metodo == MetodoPagamento.InfiniteTap) msgStatus = $"O pagamento será no Cartão na Maquininha do motoboy (Total: R$ {valorFinalDoPedido:N2}). Segue minha localização para a entrega.";
                else if (metodo == MetodoPagamento.InfinitePayOnline) msgStatus = $"Gostaria de pagar com Link de Débito/Crédito (Total: R$ {valorFinalDoPedido:N2}). Segue minha localização para a entrega.";
                
                var textoWhats = $"Olá! Acabei de fazer o pedido #{idPedidoConfirmado:D3}. {msgStatus}";
                var linkWhats = $"https://wa.me/5591986201943?text={Uri.EscapeDataString(textoWhats)}";
            }
            <a href="@linkWhats" 
               target="_blank" 
               class="btn-confirmar" 
               style="display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; border-radius: 12px; padding: 18px; font-size: 1.2rem; background: #25D366; border: none; color: #fff; text-decoration: none; font-weight: 900; box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4);">
                <span>ENVIAR NO WHATSAPP</span> ✅
            </a>

            <button class="btn-cancelar" style="margin-top: 20px; text-decoration: none; background: transparent; border: 1px solid #ddd; width: 100%; color: #999; padding: 10px; border-radius: 8px; font-weight: 600;" @onclick="FecharModalConfirmacao">Já enviei / Fechar</button>
        </div>
    </div>
}

@if (mostrarModalSugestao)
{
    <div class="modal-overlay">
        <div class="modal-content" style="text-align: center;">
            <h2>💡 Dica Quente!</h2>
            @if (sugestaoTipo == "Bebida")
            {
                <p style="font-size: 1.1rem;">Que tal uma <b>bebida bem gelada</b> para acompanhar suas Batatas Fritas?</p>
            }
            else
            {
                <p style="font-size: 1.1rem;">Ninguém toma bebida sozinha! Que tal adicionar nossas <b>Batatas Supremas</b>?</p>
            }
            <div class="modal-footer" style="flex-direction: column; gap: 10px; margin-top: 25px;">
                <button class="btn-confirmar" style="width: 100%; border-radius: 4px; padding: 12px; font-size: 1.1rem;" @onclick="AceitarSugestao">Sim, ver cardápio!</button>
                <button class="btn-cancelar" style="width: 100%; border-radius: 4px; border: none; background: transparent; text-decoration: underline; padding: 10px;" @onclick="RecusarSugestao">Não, obrigado. Finalizar Pedido</button>
            </div>
        </div>
    </div>
}

@code {
    private NovoPedidoDto pedidoDto = new NovoPedidoDto();
    
    private string mensagemSucesso = "";
    private string mensagemErro = "";
    private bool isSubmitting = false;
    private bool mostrarModalSugestao = false;
    private bool mostrarModalConfirmacao = false;
    private decimal valorFinalDoPedido = 0;
    private int idPedidoConfirmado = 0;
    private string resumoItensPedido = "";
    private MetodoPagamento metodoPagamentoEscolhido = MetodoPagamento.Dinheiro;
    private string sugestaoTipo = "";
    private List<BairroDto> bairrosDisponiveis = new();
    private List<ProdutoDto> produtosLoja = new(); // Used for checking "Apples to Apples" stock

    protected override async Task OnInitializedAsync()
    {
        Carrinho.OnChange += StateHasChanged;
        
        try
        {
            var bairros = await Http.GetFromJsonAsync<List<BairroDto>>("api/bairros");
            if (bairros != null) bairrosDisponiveis = bairros;

            var prods = await Http.GetFromJsonAsync<List<ProdutoDto>>("api/produtos");
            if (prods != null) produtosLoja = prods;
        }
        catch { /* fail silently if API unavailable */ }
    }

    private decimal TaxaEntregaAtual 
    {
        get 
        {
            if (!string.IsNullOrEmpty(Carrinho.TempBairro) && int.TryParse(Carrinho.TempBairro, out int bairroId))
            {
                var bairro = bairrosDisponiveis.FirstOrDefault(b => b.Id == bairroId);
                return bairro?.TaxaEntrega ?? 0m;
            }
            return 0m;
        }
    }

    private decimal saldoCashback = 0;
    private string mensagemCashback = "";

    private bool _usarCashback = false;
    private decimal valorCashbackDesejado = 0m;
    
    private void ToggleCashback(ChangeEventArgs e)
    {
        _usarCashback = (bool)(e.Value ?? false);
        if (_usarCashback && valorCashbackDesejado == 0)
        {
            valorCashbackDesejado = MaxCashbackPermitido;
        }
    }

    private void UsarMaximoCashback()
    {
        valorCashbackDesejado = MaxCashbackPermitido;
    }

    private decimal MaxCashbackPermitido => Math.Min(Carrinho.Subtotal + TaxaEntregaAtual, saldoCashback);
    
    private decimal ValorCashbackAplicado 
    {
        get 
        {
            if (!_usarCashback) return 0m;
            var val = valorCashbackDesejado;
            if (val < 0) val = 0;
            if (val > MaxCashbackPermitido) val = MaxCashbackPermitido;
            return val;
        }
    }

    private decimal ValorTotalPedido => (Carrinho.Subtotal + TaxaEntregaAtual) - ValorCashbackAplicado;

    private async Task OnTelefoneChanged(ChangeEventArgs e)
    {
        Carrinho.TempTelefone = e.Value?.ToString() ?? "";
        
        saldoCashback = 0;
        mensagemCashback = "";
        _usarCashback = false;
        valorCashbackDesejado = 0;
        
        if (string.IsNullOrWhiteSpace(Carrinho.TempTelefone) || Carrinho.TempTelefone.Length < 10) return;

        var telLimpo = new string(Carrinho.TempTelefone.Where(char.IsDigit).ToArray());
        try
        {
            var r = await Http.GetAsync($"api/cashback/saldo/{telLimpo}");
            if (r.IsSuccessStatusCode)
            {
                var dto = await r.Content.ReadFromJsonAsync<SaldoCashbackDto>();
                if (dto != null && dto.SaldoAtual > 0)
                {
                    saldoCashback = dto.SaldoAtual;
                    mensagemCashback = $"Você tem R$ {dto.SaldoAtual:F2} de cashback disponível!";
                }
            }
        }
        catch { }
    }

    public void Dispose()
    {
        Carrinho.OnChange -= StateHasChanged;
    }

    private void Remover(int produtoId)
    {
        Carrinho.RemoverItem(produtoId);
    }

    private async Task FinalizarPedido()
    {
        if (string.IsNullOrWhiteSpace(Carrinho.TempNome) || 
            string.IsNullOrWhiteSpace(Carrinho.TempRuaAvenida) || 
            string.IsNullOrWhiteSpace(Carrinho.TempNumeroLocal))
        {
            mensagemErro = "Por favor, preencha seu nome, a rua e o número da casa!";
            return;
        }
        
        if (string.IsNullOrEmpty(Carrinho.TempBairro))
        {
            mensagemErro = "Por favor, escolha o seu bairro para a entrega!";
            return;
        }
        
        if (string.IsNullOrEmpty(Carrinho.TempPagamento))
        {
            mensagemErro = "Por favor, escolha a forma de pagamento!";
            return;
        }

        // Cross-selling logic
        bool temBatata = Carrinho.Itens.Any(i => i.CategoriaId == CategoriaEnum.Batatas);
        bool temBebida = Carrinho.Itens.Any(i => i.CategoriaId == CategoriaEnum.Bebidas);

        bool lojaVendeBebida = produtosLoja.Any(p => p.CategoriaId == CategoriaEnum.Bebidas);
        bool lojaVendeBatata = produtosLoja.Any(p => p.CategoriaId == CategoriaEnum.Batatas);

        if (temBatata && !temBebida && lojaVendeBebida)
        {
            sugestaoTipo = "Bebida";
            mostrarModalSugestao = true;
            return;
        }
        if (!temBatata && temBebida && lojaVendeBatata)
        {
            sugestaoTipo = "Batata";
            mostrarModalSugestao = true;
            return;
        }

        await ProcessarPedidoRealmente();
    }

    private void AceitarSugestao()
    {
        mostrarModalSugestao = false;
        Navigation.NavigateTo("/");
    }

    private async Task RecusarSugestao()
    {
        mostrarModalSugestao = false;
        await ProcessarPedidoRealmente();
    }

    private async Task ProcessarPedidoRealmente()
    {
        isSubmitting = true;
        mensagemErro = "";
        mensagemSucesso = "";

        // Clone items directly from Cart
        pedidoDto.Itens = Carrinho.Itens.ToList();
        
        // Push State properties to Request DTO
        pedidoDto.NomeCliente = Carrinho.TempNome;
        pedidoDto.TelefoneCliente = Carrinho.TempTelefone;
        pedidoDto.EnderecoEntrega = $"{Carrinho.TempRuaAvenida}, Nº {Carrinho.TempNumeroLocal} - {Carrinho.TempComplementoLocal}".TrimEnd(' ', '-');
        pedidoDto.MetodoPagamento = (MetodoPagamento)int.Parse(Carrinho.TempPagamento);
        pedidoDto.BairroEntregaId = int.Parse(Carrinho.TempBairro);
        pedidoDto.ValorCashbackUsado = ValorCashbackAplicado;
        
        if (pedidoDto.MetodoPagamento == MetodoPagamento.Dinheiro && !string.IsNullOrWhiteSpace(Carrinho.TempTroco))
        {
            var cleaned = Carrinho.TempTroco.Replace("R$", "").Replace(" ", "");
            
            // Aceita virgula ou ponto, converte pra cultura Invariant e tenta fazer o Parse
            var isDecimal = decimal.TryParse(cleaned.Replace(",", "."), 
                System.Globalization.NumberStyles.Any, 
                System.Globalization.CultureInfo.InvariantCulture, 
                out var parsedTroco);
                
            if (isDecimal)
            {
                if (parsedTroco < ValorTotalPedido && parsedTroco > 0)
                {
                    mensagemErro = $"O valor do troco (R$ {parsedTroco.ToString("F2")}) não pode ser inferior ao Valor Total do pedido (R$ {ValorTotalPedido.ToString("F2")})!";
                    isSubmitting = false;
                    return;
                }
                pedidoDto.TrocoPara = parsedTroco;
            }
        }
        else
        {
            pedidoDto.TrocoPara = null;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("api/pedidos", pedidoDto);
            
            if (response.IsSuccessStatusCode)
            {
                var responseContent = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                
                string linkPagamento = "";
                if (responseContent.TryGetProperty("linkPagamento", out var linkProp))
                {
                    linkPagamento = linkProp.GetString() ?? "";
                }

                if (!string.IsNullOrEmpty(linkPagamento))
                {
                    mensagemSucesso = "Pedido recebido! Redirecionando para o pagamento online...";
                    Carrinho.LimparCarrinho();
                    pedidoDto = new NovoPedidoDto();
                    // Redirecionar para o InfinitePay
                    Navigation.NavigateTo(linkPagamento);
                }
                else
                {
                    int idRecebido = 0;
                    if (responseContent.TryGetProperty("pedidoId", out var idProp))
                    {
                        idRecebido = idProp.GetInt32();
                    }

                    idPedidoConfirmado = idRecebido;
                    valorFinalDoPedido = ValorTotalPedido;
                    resumoItensPedido = string.Join(", ", Carrinho.Itens.Select(i => $"{i.Quantidade}x {i.NomeProduto}"));
                    metodoPagamentoEscolhido = pedidoDto.MetodoPagamento;
                    
                    mostrarModalConfirmacao = true;
                    mensagemSucesso = "Pedido recebido! Veja as instruções abaixo.";

                    Carrinho.LimparCarrinho();
                    pedidoDto = new NovoPedidoDto(); // Reset backend ref
                }
            }
            else
            {
                mensagemErro = "Ops! Não conseguimos enviar o pedido para a cozinha. Tente novamente.";
            }
        }
        catch (Exception ex)
        {
            mensagemErro = $"Erro de conexão com o restaurante: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void FecharModalConfirmacao()
    {
        mostrarModalConfirmacao = false;
        Navigation.NavigateTo("/");
    }

    private void VoltarCardapio()
    {
        // A simple navigation to home will close the offcanvas if it's route-based, 
        // or the user can just use the standard layout close if it's CSS-based.
        Navigation.NavigateTo("/");
    }
}

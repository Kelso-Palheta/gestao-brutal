@page "/totem"
@layout TotemLayout
@using BatatasFritas.Shared.DTOs
@using BatatasFritas.Shared.Enums
@using BatatasFritas.Web.Services
@using System.Net.Http.Json
@inject HttpClient Http
@inject CarrinhoState Carrinho
@inject NavigationManager Nav

<div class="totem-grid">

    <!-- Lado Esquerdo: Cardápio Full -->
    <div class="totem-menu-area">
        
        <div class="totem-header">
            <h1 class="totem-logo">🍟 Palheta Brutal</h1>
            <p>Toque nos produtos para adicionar</p>
        </div>

        @if (carregando)
        {
            <div class="totem-loading">Carregando cardápio...</div>
        }
        else
        {
            <div class="totem-filters">
                <button class="totem-btn-filter @(string.IsNullOrEmpty(categoriaAtiva) ? "active" : "")" @onclick='() => FiltroCategoria("")'>
                    🍟 Tudo
                </button>
                @foreach (var c in Enum.GetValues<CategoriaEnum>().Where(cat => produtos.Any(p => p.CategoriaId == cat && p.Ativo)))
                {
                    <button class="totem-btn-filter @(categoriaAtiva == c.ToString() ? "active" : "")" @onclick="() => FiltroCategoria(c.ToString())">
                        @NomeCategoria(c)
                    </button>
                }
            </div>

            <div class="totem-products-list">
                @foreach (var p in ProdutosFiltrados)
                {
                    <div class="totem-product-card @(p.Ativo ? "" : "inativo")" @onclick="() => AbrirModal(p)">
                        <div class="totem-card-img">
                            @if (p.CategoriaId == CategoriaEnum.Bebidas) { <text>🥤</text> }
                            else if (p.CategoriaId == CategoriaEnum.Porcoes) { <text>🍗</text> }
                            else if (p.CategoriaId == CategoriaEnum.Sobremesas) { <text>🍰</text> }
                            else { <text>🍟</text> }
                        </div>
                        <div class="totem-card-info">
                            <h3>@p.Nome</h3>
                            <p>@p.Descricao</p>
                            <span class="totem-price">@p.PrecoBase.ToString("C2")</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Lado Direito: Carrinho Fixo -->
    <div class="totem-sidebar">
        <div class="totem-sidebar-header">
            <h2>🛒 Seu Pedido</h2>
            <button class="totem-btn-clear" @onclick="LimparPedido">🗑️ Limpar</button>
        </div>

        <div class="totem-cart-items">
            @if (!Carrinho.Itens.Any())
            {
                <div class="totem-empty-cart">
                    <span style="font-size: 3rem;">👆</span>
                    <p>Toque nos itens ao lado para iniciar seu pedido.</p>
                </div>
            }
            else
            {
                @foreach (var item in Carrinho.Itens)
                {
                    <div class="totem-cart-item">
                        <div class="totem-item-qnty">@item.Quantidade</div>
                        <div class="totem-item-details">
                            <strong>@item.NomeProduto</strong>
                            @if (!string.IsNullOrEmpty(item.Observacao))
                            {
                                <span class="totem-item-obs">@item.Observacao</span>
                            }
                        </div>
                        <div class="totem-item-price">@((item.PrecoUnitario * item.Quantidade).ToString("C2"))</div>
                        <button class="totem-btn-remove" @onclick="() => Carrinho.RemoverItem(item.ProdutoId)">×</button>
                    </div>
                }
            }
        </div>

        <div class="totem-sidebar-footer">
            <div class="totem-total-line">
                <span>Total:</span>
                <strong>@Carrinho.Subtotal.ToString("C2")</strong>
            </div>
            
            <button class="totem-btn-checkout" 
                    disabled="@(!Carrinho.Itens.Any())" 
                    @onclick="IrParaPagamento">
                ✅ Finalizar Pedido
            </button>
        </div>
    </div>
</div>

<!-- Modal Personalização Gigante -->
@if (produtoSelecionado != null)
{
    <div class="totem-modal-overlay">
        <div class="totem-modal">
            <div class="totem-modal-header">
                <h2>@produtoSelecionado.Nome</h2>
                <button class="totem-close-lg" @onclick="FecharModal">✕</button>
            </div>
            <div class="totem-modal-body">
                <p class="totem-modal-desc">@produtoSelecionado.Descricao</p>
                <div class="totem-modal-price">@produtoSelecionado.PrecoBase.ToString("C2")</div>

                @if (complementosAtivos.Any(x => x.TipoAcao == "Remocao"))
                {
                    <div class="totem-obs-box">
                        <label>Remoções / Sem</label>
                        <div class="totem-quick-obs">
                            @foreach (var c in complementosAtivos.Where(x => x.TipoAcao == "Remocao"))
                            {
                                <button class="totem-chip @(selecionadosIds.Contains(c.Id) ? "on" : "")" @onclick='() => ToggleComplemento(c)'>
                                    @(selecionadosIds.Contains(c.Id) ? "✅ " : "❌ ")@c.Nome
                                </button>
                            }
                        </div>
                    </div>
                }

                @if (complementosAtivos.Any(x => x.TipoAcao == "MolhoGratuito"))
                {
                    <div class="totem-obs-box">
                        <label>Complementos Gratuitos (Molhos)</label>
                        <div class="totem-quick-obs">
                            @foreach (var c in complementosAtivos.Where(x => x.TipoAcao == "MolhoGratuito"))
                            {
                                <button class="totem-chip @(selecionadosIds.Contains(c.Id) ? "on-green" : "")" @onclick='() => ToggleComplemento(c)'>
                                    @(selecionadosIds.Contains(c.Id) ? "✅ " : "+ ")@c.Nome
                                </button>
                            }
                        </div>
                    </div>
                }

                @if (complementosAtivos.Any(x => x.TipoAcao == "AdicionalPago"))
                {
                    <div class="totem-obs-box">
                        <label>Adicionais Pagos (+ R$)</label>
                        <div class="totem-quick-obs">
                            @foreach (var c in complementosAtivos.Where(x => x.TipoAcao == "AdicionalPago"))
                            {
                                var qtd = quantidadesAdicionais.ContainsKey(c.Id) ? quantidadesAdicionais[c.Id] : 0;
                                <div class="totem-chip @(qtd > 0 ? "on-green" : "")" style="display:flex; align-items:center; gap: 15px; cursor: pointer; user-select:none; padding:10px 20px;">
                                    <div @onclick='() => AlterarQuantidade(c.Id, 1)' style="flex-grow:1; text-align:left;">
                                        @(qtd > 0 ? "✅ " : "+ ")@c.Nome (@c.Preco.ToString("C2"))
                                    </div>
                                    @if(qtd > 0)
                                    {
                                        <div style="display:flex; align-items:center; gap:10px; background:rgba(0,0,0,0.1); border-radius:30px; padding:2px 8px;">
                                            <button @onclick:stopPropagation="true" @onclick='() => AlterarQuantidade(c.Id, -1)' style="background:transparent; color:inherit; border:none; padding:5px 10px; font-size:1.4rem; font-weight:bold;">−</button>
                                            <span style="font-size:1.2rem; font-weight:bold;">@qtd</span>
                                            <button @onclick:stopPropagation="true" @onclick='() => AlterarQuantidade(c.Id, 1)' style="background:transparent; color:inherit; border:none; padding:5px 10px; font-size:1.4rem; font-weight:bold;">+</button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="totem-qty-selector">
                    <span>Quantidade:</span>
                    <button class="totem-qty-btn" @onclick="() => { if(quantidade > 1) quantidade--; }">−</button>
                    <span class="totem-qty-value">@quantidade</span>
                    <button class="totem-qty-btn" @onclick="() => quantidade++">+</button>
                </div>
            </div>
            
            <div class="totem-modal-footer">
                <button class="totem-btn-confirm-add" @onclick="AdicionarAoCarrinho">
                    ADICIONAR — @(PrecoTotalAtual.ToString("C2"))
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ProdutoDto> produtos = new();
    private bool carregando = true;
    private string categoriaAtiva = "";

    // Modal state
    private ProdutoDto? produtoSelecionado;
    private int quantidade = 1;

    private List<ComplementoDto> todosComplementos = new();
    private IEnumerable<ComplementoDto> complementosAtivos =>
        todosComplementos.Where(c => c.CategoriaAlvo == "Todas" || c.CategoriaAlvo == produtoSelecionado?.CategoriaId.ToString());

    // Auxilia no cálculo do total
    private HashSet<int> selecionadosIds = new();
    private Dictionary<int, int> quantidadesAdicionais = new();

    private decimal precoAdicionais => todosComplementos
        .Where(c => c.TipoAcao == "AdicionalPago" && quantidadesAdicionais.ContainsKey(c.Id))
        .Sum(c => c.Preco * quantidadesAdicionais[c.Id]);

    private decimal PrecoTotalAtual => ((produtoSelecionado?.PrecoBase ?? 0) + precoAdicionais) * quantidade;

    private IEnumerable<ProdutoDto> ProdutosFiltrados => string.IsNullOrEmpty(categoriaAtiva) 
        ? produtos.Where(p => p.Ativo) 
        : produtos.Where(p => p.Ativo && p.CategoriaId.ToString() == categoriaAtiva);

    protected override async Task OnInitializedAsync()
    {
        // Totem inicia sempre "limpo" por segurança
        if (Carrinho.Itens.Any()) Carrinho.LimparCarrinho();
        Carrinho.OnChange += StateHasChanged;

        try
        {
            var r = await Http.GetFromJsonAsync<List<ProdutoDto>>("api/produtos");
            if (r != null) produtos = r;

            var c = await Http.GetFromJsonAsync<List<ComplementoDto>>("api/complementos/ativos");
            if (c != null) todosComplementos = c;
        }
        catch { }
        finally { carregando = false; }
    }

    public void Dispose() => Carrinho.OnChange -= StateHasChanged;

    private void FiltroCategoria(string c) => categoriaAtiva = c;

    private void AbrirModal(ProdutoDto p)
    {
        if (!p.Ativo) return;
        if (p.CategoriaId == CategoriaEnum.Bebidas)
        {
            // Bebidas não precisam de personalizar no Totem por padrão, vai direto pro carrinho
            Carrinho.AdicionarItemComOpcoes(p, 1, p.PrecoBase, "");
            return;
        }
        produtoSelecionado = p;
        quantidade = 1;
        selecionadosIds.Clear();
        quantidadesAdicionais.Clear();
    }

    private void FecharModal() => produtoSelecionado = null;

    private void ToggleComplemento(ComplementoDto c)
    {
        if (selecionadosIds.Contains(c.Id))
            selecionadosIds.Remove(c.Id);
        else
            selecionadosIds.Add(c.Id);
    }

    private void AlterarQuantidade(int id, int delta)
    {
        if (!quantidadesAdicionais.ContainsKey(id))
            quantidadesAdicionais[id] = 0;
            
        quantidadesAdicionais[id] += delta;
        if (quantidadesAdicionais[id] <= 0)
            quantidadesAdicionais.Remove(id);
    }

    private void AdicionarAoCarrinho()
    {
        if (produtoSelecionado != null)
        {
            var selecionados = todosComplementos.Where(c => selecionadosIds.Contains(c.Id)).Select(c => c.Nome).ToList();
            var pagos = todosComplementos.Where(c => c.TipoAcao == "AdicionalPago" && quantidadesAdicionais.ContainsKey(c.Id))
                                         .Select(c => $"{quantidadesAdicionais[c.Id]}x {c.Nome}");
            
            selecionados.AddRange(pagos);
            var observacaoFinal = string.Join(", ", selecionados);

            var precoTotalObj = produtoSelecionado.PrecoBase + precoAdicionais;

            Carrinho.AdicionarItemComOpcoes(
                produtoSelecionado,
                quantidade,
                precoTotalObj,
                observacaoFinal
            );
        }
        FecharModal();
    }

    private void LimparPedido() => Carrinho.LimparCarrinho();

    private void IrParaPagamento()
    {
        Nav.NavigateTo("/totem/checkout");
    }

    private static string NomeCategoria(CategoriaEnum cat) => cat switch
    {
        CategoriaEnum.Batatas    => "🍟 Batatas",
        CategoriaEnum.Bebidas    => "🥤 Bebidas",
        CategoriaEnum.Porcoes    => "🍗 Porções",
        CategoriaEnum.Sobremesas => "🍰 Sobremesas",
        _                        => cat.ToString()
    };
}

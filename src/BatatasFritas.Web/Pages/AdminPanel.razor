@page "/admin"
@layout EmptyLayout
@inject KdsAuthService KdsAuth
@inject NavigationManager Nav

@if (!carregando)
{
<div class="admin-page">

    <!-- HEADER -->
    <div class="admin-header">
        <div class="admin-header-brand">
            <span>⚙️</span>
            <div>
                <h1>Painel Admin</h1>
                <p>Batata Palheta Brutal</p>
            </div>
        </div>
        <div class="admin-header-nav">
            <a href="/totem" class="admin-nav-link" target="_blank">📱 Totem</a>
            <a href="/admin/estoque" class="admin-nav-link">📦 Estoque</a>
            <a href="/admin/dashboard" class="admin-nav-link">📊 Dashboard</a>
            <a href="/kds" class="admin-nav-link">🍳 KDS</a>
            <button @onclick="@Sair" class="admin-btn-sair">🔒 Sair</button>
        </div>
    </div>

    <div class="admin-body">

        <!-- TABS -->
        <div class="admin-tabs">
            <button class="admin-tab @(abaAtiva == "produtos" ? "active" : "")" @onclick="@(() => abaAtiva = "produtos")">
                🍟 Produtos
            </button>
            <button class="admin-tab @(abaAtiva == "complementos" ? "active" : "")" @onclick="@(() => abaAtiva = "complementos")">
                ➕ Adicionais e Molhos
            </button>
            <button class="admin-tab @(abaAtiva == "bairros" ? "active" : "")" @onclick="@(() => abaAtiva = "bairros")">
                📍 Bairros e Taxas
            </button>
            <button class="admin-tab @(abaAtiva == "configuracoes" ? "active" : "")" @onclick="@(() => abaAtiva = "configuracoes")">
                ⚙️ Configurações
            </button>
            <button class="admin-tab @(abaAtiva == "clientes" ? "active" : "")" @onclick="@(() => abaAtiva = "clientes")">
                👥 Clientes
            </button>
        </div>

        <!-- ALERTAS GLOBAIS -->
        @if (!string.IsNullOrEmpty(_alert.MsgSucesso))
        {
            <div class="admin-alert admin-alert-ok">✅ @_alert.MsgSucesso</div>
        }
        @if (!string.IsNullOrEmpty(_alert.MsgErro))
        {
            <div class="admin-alert admin-alert-erro">❌ @_alert.MsgErro</div>
        }

        <!-- SUB-COMPONENTES (lazy: só renderiza quando aba está ativa) -->
        <CascadingValue Value="_alert">
            @if (abaAtiva == "produtos")      { <AdminProdutos /> }
            @if (abaAtiva == "complementos")  { <AdminComplementos /> }
            @if (abaAtiva == "bairros")       { <AdminBairros /> }
            @if (abaAtiva == "configuracoes") { <AdminConfiguracoes /> }
            @if (abaAtiva == "clientes")      { <AdminClientes /> }
        </CascadingValue>

    </div><!-- /admin-body -->
</div>
}

@code {
    private string           abaAtiva  = "produtos";
    private bool             carregando = true;
    private AdminAlertService _alert   = new();

    protected override async Task OnInitializedAsync()
    {
        if (!await KdsAuth.EstaAutenticadoAsync())
        {
            var returnUrl = Nav.ToBaseRelativePath(Nav.Uri);
            Nav.NavigateTo($"/kds/login?returnUrl={returnUrl}", replace: true);
            return;
        }

        // Callback reconecta StateHasChanged do shell ao serviço de alertas
        _alert.OnMudou = StateHasChanged;
        carregando = false;
    }

    private async Task Sair()
    {
        await KdsAuth.LogoutAsync();
        Nav.NavigateTo("/kds/login", replace: true);
    }
}

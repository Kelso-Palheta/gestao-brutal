    // ======================== SEGURANÇA ========================

    private async Task AlterarSenha()
    {
        msgSenhaOk  = string.Empty;
        msgSenhaErro = string.Empty;

        if (string.IsNullOrWhiteSpace(senhaAtual) || string.IsNullOrWhiteSpace(novaSenha) || string.IsNullOrWhiteSpace(confirmarSenha))
        {
            msgSenhaErro = "Preencha todos os campos.";
            return;
        }
        if (novaSenha != confirmarSenha)
        {
            msgSenhaErro = "A nova senha e a confirmação não coincidem.";
            return;
        }
        if (novaSenha.Length < 4)
        {
            msgSenhaErro = "A nova senha deve ter ao menos 4 caracteres.";
            return;
        }

        alterandoSenha = true;
        try
        {
            var body = new AlterarSenhaRequest { SenhaAtual = senhaAtual, NovaSenha = novaSenha };
            var response = await Http.PostAsJsonAsync("api/configuracoes/auth/alterar-senha", body);

            if (response.IsSuccessStatusCode)
            {
                msgSenhaOk    = "Senha alterada com sucesso! Use a nova senha no próximo login.";
                senhaAtual    = string.Empty;
                novaSenha     = string.Empty;
                confirmarSenha = string.Empty;
            }
            else
            {
                msgSenhaErro = await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            msgSenhaErro = $"Erro de conexão: {ex.Message}";
        }
        finally
        {
            alterandoSenha = false;
        }
    }


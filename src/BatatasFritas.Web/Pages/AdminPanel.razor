    private void EditarProduto(ProdutoDto p)
    {
        LimparMensagens();
        produtoEdit = new ProdutoDto
        {
            Id = p.Id,
            Nome = p.Nome,
            Descricao = p.Descricao,
            CategoriaId = p.CategoriaId,
            PrecoBase = p.PrecoBase,
            ImagemUrl = p.ImagemUrl,
            Ativo = p.Ativo
        };
        mostrarFormProduto = true;
        mostrarFormBairro = false;
    }

    private void FecharFormProduto()
    {
        mostrarFormProduto = false;
        produtoEdit = new();
    }

    private async Task SalvarProduto()
    {
        if (string.IsNullOrWhiteSpace(produtoEdit.Nome) || produtoEdit.PrecoBase <= 0)
        {
            msgErro = "Nome e Preço são obrigatórios!";
            return;
        }

        LimparMensagens();
        salvando = true;

        try
        {
            HttpResponseMessage response;
            if (produtoEdit.Id == 0)
                response = await Http.PostAsJsonAsync("api/produtos", produtoEdit);
            else
                response = await Http.PutAsJsonAsync($"api/produtos/{produtoEdit.Id}", produtoEdit);

            if (response.IsSuccessStatusCode)
            {
                msgSucesso = produtoEdit.Id == 0 ? "Produto criado com sucesso!" : "Produto atualizado com sucesso!";
                FecharFormProduto();
                await CarregarTudo();
            }
            else
            {
                msgErro = $"Erro ao salvar: {await response.Content.ReadAsStringAsync()}";
            }
        }
        catch (Exception ex)
        {
            msgErro = $"Erro de conexão: {ex.Message}";
        }
        finally { salvando = false; }
    }

    private async Task ToggleProduto(ProdutoDto p, bool ativar)
    {
        LimparMensagens();
        var endpoint = ativar ? $"api/produtos/{p.Id}/ativar" : $"api/produtos/{p.Id}/desativar";
        var response = await Http.PatchAsync(endpoint, null);
        if (response.IsSuccessStatusCode)
        {
            msgSucesso = ativar ? $"'{p.Nome}' ativado no cardápio!" : $"'{p.Nome}' removido do cardápio!";
            await CarregarTudo();
        }
        else
        {
            msgErro = "Erro ao alterar status do produto.";
        }
    }

    private async Task DeletarProduto(ProdutoDto p)
    {
        LimparMensagens();
        var response = await Http.DeleteAsync($"api/produtos/{p.Id}");

        if (response.StatusCode == System.Net.HttpStatusCode.NoContent)
        {
            // Excluído fisicamente
            msgSucesso = $"Produto '{p.Nome}' excluído permanentemente.";
            await CarregarTudo();
        }
        else if (response.IsSuccessStatusCode)
        {
            // Soft-delete: produto tinha pedidos vinculados, foi desativado
            var resultado = await response.Content.ReadFromJsonAsync<SoftDeleteResponse>();
            msgSucesso = resultado?.Mensagem ?? $"'{p.Nome}' foi desativado do cardápio (possui pedidos vinculados).";
            await CarregarTudo();
        }
        else
        {
            msgErro = $"Erro ao excluir produto: {await response.Content.ReadAsStringAsync()}";
        }
    }


    // ======================== ORDEM DOS PRODUTOS ========================

    private bool salvandoOrdem = false;

    private async Task MoverCima(int indice)
    {
        if (indice <= 0) return;
        // Troca na lista local
        (produtos[indice], produtos[indice - 1]) = (produtos[indice - 1], produtos[indice]);
        await SalvarOrdem();
    }

    private async Task MoverBaixo(int indice)
    {
        if (indice >= produtos.Count - 1) return;
        (produtos[indice], produtos[indice + 1]) = (produtos[indice + 1], produtos[indice]);
        await SalvarOrdem();
    }

    private async Task SalvarOrdem()
    {
        salvandoOrdem = true;
        LimparMensagens();
        try
        {
            // Gera a lista com a nova posição de cada produto (0-based)
            var payload = produtos
                .Select((p, idx) => new ReordenarProdutoItem(p.Id, idx))
                .ToList();

            var response = await Http.PatchAsJsonAsync("api/produtos/reordenar", payload);
            if (!response.IsSuccessStatusCode)
                msgErro = "Erro ao salvar a nova ordem. Tente novamente.";
        }
        catch (Exception ex)
        {
            msgErro = $"Erro de conexão: {ex.Message}";
        }
        finally
        {
            salvandoOrdem = false;
        }
    }


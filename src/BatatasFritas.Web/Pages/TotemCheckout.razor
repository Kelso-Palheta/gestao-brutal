@page "/totem/checkout"
@layout TotemLayout
@using BatatasFritas.Shared.DTOs
@using BatatasFritas.Shared.Enums
@using BatatasFritas.Web.Services
@using System.Net.Http.Json
@inject IJSRuntime JS
@inject HttpClient Http
@inject CarrinhoState Carrinho
@inject NavigationManager Nav

<div class="totem-flow">
    <button class="totem-btn-back" @onclick='() => Nav.NavigateTo("/totem")'>← Voltar</button>

    <div class="totem-checkout-box">
        <h1>Quase lá!</h1>
        <p class="totem-checkout-sub">Resumo do seu pedido:</p>

        <div class="totem-checkout-items">
            @foreach (var i in Carrinho.Itens)
            {
                <div class="totem-chk-item">
                    <span>@i.Quantidade x @i.NomeProduto</span>
                    <strong>@((i.PrecoUnitario * i.Quantidade).ToString("C2"))</strong>
                </div>
            }
        </div>
        <div class="totem-chk-total">
            <div style="font-size:18px; color:#aaa; margin-bottom: 5px;">SUBTOTAL: <span>@Carrinho.Subtotal.ToString("C2")</span></div>
            @if (_usarCashback && saldoDisponivel > 0)
            {
                <div style="font-size:18px; color:#ffb347; margin-bottom: 5px;">CASHBACK: <span>-@ValorCashbackAplicado.ToString("C2")</span></div>
            }
            <strong>TOTAL: @Math.Max(0, Carrinho.Subtotal - ValorCashbackAplicado).ToString("C2")</strong>
        </div>

        @if (!string.IsNullOrEmpty(msgErro))
        {
            <div class="totem-err">❌ @msgErro</div>
        }

        <!-- ETAPA 1: ONDE VAI COMER? -->
        @if (etapa == 1)
        {
            <h2 class="totem-step-title">1. Onde você vai comer?</h2>
            <div class="totem-options">
                <button class="totem-opt-btn @(ondeComer == "Aqui" ? "active" : "")" 
                        @onclick='() => { ondeComer = "Aqui"; }'>
                    <span class="totem-opt-icon">🍽️</span><br>Aqui
                </button>
                <button class="totem-opt-btn @(ondeComer == "Viagem" ? "active" : "")" 
                        @onclick='() => { ondeComer = "Viagem"; }'>
                    <span class="totem-opt-icon">🥡</span><br>Para Viagem
                </button>
            </div>

            <h2 class="totem-step-title" style="margin-top:30px">Seu WhatsApp (Ganha Cashback! 🎁)</h2>
            <input type="tel" class="totem-input-lg" @bind="telefoneCliente" @onblur="BuscarCashback" placeholder="Ex: (11) 99999-9999" />

            <h2 class="totem-step-title" style="margin-top:15px">Nome para o pedido? (Para chamarmos)</h2>
            <input type="text" class="totem-input-lg" @bind="nomeCliente" placeholder="Ex: João" />

            <button class="totem-btn-next" disabled="@(!PodeAvancar())" @onclick="IrEtapa2">
                Avançar →
            </button>
        }

        <!-- ETAPA 2: PAGAMENTO -->
        @if (etapa == 2)
        {
            @if (saldoDisponivel > 0)
            {
                <div class="totem-cashback-box" style="background:#222; border:2px solid #ffb347; border-radius:12px; padding:16px; margin-bottom:20px; text-align:left;">
                    <h3 style="color:#ffb347; margin:0 0 10px 0; font-size:1.2rem;">🎁 Você tem @saldoDisponivel.ToString("C2") de Cashback!</h3>
                    <label style="display:flex; align-items:center; gap:10px; cursor:pointer; font-size: 1.1rem; margin-bottom: @(_usarCashback ? "15px" : "0");">
                        <input type="checkbox" checked="@_usarCashback" @onchange="ToggleCashback" style="width:24px; height:24px;" />
                        <span>Usar saldo de cashback neste pedido</span>
                    </label>

                    @if (_usarCashback)
                    {
                        <div style="background:#333; padding:15px; border-radius:8px;">
                            <label style="display:block; font-size:1rem; margin-bottom:8px;">Quanto do saldo quer usar?</label>
                            <div style="display:flex; gap:10px; align-items:center;">
                                <span style="font-size:1.2rem; font-weight:bold;">R$</span>
                                <input type="number" step="0.01" min="0" max="@MaxCashbackPermitido.ToString(System.Globalization.CultureInfo.InvariantCulture)" @bind="valorCashbackDesejado" style="flex-grow:1; max-width:150px; padding:8px; font-size:1.2rem; font-weight:bold; border:2px solid #ffb347; border-radius:6px; background:#111; color:#fff;" />
                                <button @onclick="UsarMaximoCashback" style="background:#ffb347; color:#000; border:none; padding:10px 15px; border-radius:6px; font-weight:bold; cursor:pointer;">MÁXIMO (@MaxCashbackPermitido.ToString("C2"))</button>
                            </div>
                        </div>
                    }
                </div>
            }

            <h2 class="totem-step-title">2. Como deseja pagar?</h2>
            
            <!-- SELETOR ÚNICO DE PAGAMENTO (visível por padrão) -->
            <div class="totem-options" style="flex-wrap:wrap;">
                <button class="totem-opt-btn @(pagamento == "Pix" ? "active" : "")" 
                        @onclick='() => { pagamento = "Pix"; segundoPagamento = ""; valorPrimeiroPagamento = 0; valorSegundoPagamento = 0; }'>
                    <span class="totem-opt-icon">📱</span><br>PIX<br><small>QR Code na tela</small>
                </button>
                <button class="totem-opt-btn @(pagamento == "Cartao" ? "active" : "")" 
                        @onclick='() => { pagamento = "Cartao"; segundoPagamento = ""; valorPrimeiroPagamento = 0; valorSegundoPagamento = 0; }'>
                    <span class="totem-opt-icon">💳</span><br>Cartão<br><small>Débito / Crédito</small>
                </button>
                <button class="totem-opt-btn @(pagamento == "Dinheiro" ? "active" : "")" 
                        @onclick='() => { pagamento = "Dinheiro"; segundoPagamento = ""; valorPrimeiroPagamento = 0; valorSegundoPagamento = 0; }'>
                    <span class="totem-opt-icon">💵</span><br>Dinheiro<br><small>Pagar no Caixa</small>
                </button>
            </div>

            <!-- BOTÃO PARA ATIVAR PAGAMENTO DIVIDIDO (oculto por padrão) -->
            @if (!string.IsNullOrEmpty(pagamento) && TotalPagar > 0 && !mostrarDivisaoPagamento)
            {
                <button @onclick="AtivarDivisaoPagamento" 
                        style="background: linear-gradient(135deg, #4CAF50, #2E7D32); border: none; color: #fff; padding: 16px 24px; border-radius: 14px; font-size: 1.1rem; font-weight: 700; cursor: pointer; margin-top: 20px; width: 100%; display: flex; align-items: center; justify-content: center; gap: 12px; box-shadow: 0 4px 20px rgba(76, 175, 80, 0.4); transition: transform 0.2s, box-shadow 0.2s;">
                    💰 Pagar com 2 Meios de Pagamento
                </button>
            }

            <!-- DIVISÃO DE PAGAMENTO (só aparece ao ativar manualmente) -->
            @if (mostrarDivisaoPagamento && !string.IsNullOrEmpty(pagamento) && TotalPagar > 0)
            {
                <div class="totem-dividir-pagamento" style="background:#222; border:2px solid #4CAF50; border-radius:12px; padding:16px; margin-top:20px; text-align:left;">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                        <h3 style="color:#4CAF50; margin:0; font-size:1.1rem;">💰 Dividir Pagamento</h3>
                        <button @onclick="DesativarDivisaoPagamento" style="background:transparent; border:none; color:#888; font-size:1.5rem; cursor:pointer; padding:4px 8px;">✕</button>
                    </div>
                    <p style="color:#aaa; margin:0 0 15px 0; font-size:0.95rem;">Informe o valor de cada método:</p>
                    
                    <div style="background:#333; padding:15px; border-radius:8px; margin-bottom:15px;">
                        <label style="display:block; font-size:1rem; margin-bottom:8px;">1º - @(pagamento switch { "Dinheiro" => "Dinheiro", "Cartao" => "Cartão", "Pix" => "PIX", _ => "Método"}):</label>
                        <div style="display:flex; gap:10px; align-items:center;">
                            <span style="font-size:1.2rem; font-weight:bold;">R$</span>
                            <input type="number" step="0.01" min="0.01" max="@((TotalPagar - 0.01m).ToString(System.Globalization.CultureInfo.InvariantCulture))" @bind="valorPrimeiroPagamento" @bind:format="F2" @oninput="CalcularSegundoPagamento" style="flex-grow:1; max-width:150px; padding:8px; font-size:1.2rem; font-weight:bold; border:2px solid #4CAF50; border-radius:6px; background:#111; color:#fff;" />
                            <button @onclick="UsarValorTotalPrimeiro" style="background:#4CAF50; color:#fff; border:none; padding:10px 15px; border-radius:6px; font-weight:bold; cursor:pointer;">TOTAL (@TotalPagar.ToString("C2"))</button>
                        </div>
                    </div>

                    @if (valorSegundoPagamento > 0)
                    {
                        <div style="border-top:1px solid #555; padding-top:15px;">
                            <label style="display:block; font-size:1rem; margin-bottom:8px;">2º Método:</label>
                            <div class="totem-options" style="flex-wrap:wrap; gap:8px;">
                                @foreach (var opt in new[] { "Pix", "Cartao", "Dinheiro" }.Where(o => o != pagamento))
                                {
                                    <button class="totem-opt-btn @(segundoPagamento == opt ? "active" : "")" 
                                            @onclick='() => { segundoPagamento = opt; }' style="flex:1; min-width:80px; padding:10px;">
                                        <span class="totem-opt-icon" style="font-size:1.2rem;">@(opt == "Pix" ? "📱" : opt == "Cartao" ? "💳" : "💵")</span><br><small>@(opt == "Pix" ? "PIX" : opt == "Cartao" ? "Cartão" : "Dinheiro")</small>
                                    </button>
                                }
                            </div>
                            <div style="margin-top:10px; text-align:center;">
                                <span style="color:#ffb347; font-size:1.1rem;">Restante: <strong>@valorSegundoPagamento.ToString("C2")</strong></span>
                            </div>
                        </div>
                    }

                    <!-- VALIDAÇÃO: soma deve ser igual ao total -->
                    @if (valorPrimeiroPagamento > 0 && valorSegundoPagamento > 0)
                    {
                        var soma = valorPrimeiroPagamento + valorSegundoPagamento;
                        var diff = Math.Abs(soma - TotalPagar);
                        @if (diff > 0.01m)
                        {
                            <div style="background:#3a0000; border:1px solid #ff4444; color:#ff6b6b; padding:10px; border-radius:8px; margin-top:12px; font-size:0.9rem; text-align:center;">
                                ⚠️ A soma dos valores (R$ @soma.ToString("C2")) não confere com o total (R$ @TotalPagar.ToString("C2"))
                            </div>
                        }
                        else
                        {
                            <div style="background:#003300; border:1px solid #4CAF50; color:#4CAF50; padding:10px; border-radius:8px; margin-top:12px; font-size:0.9rem; text-align:center;">
                                ✅ Valores conferem! Total: R$ @TotalPagar.ToString("C2")
                            </div>
                        }
                    }
                </div>
            }

            <button class="totem-btn-final" disabled="@(!PodeFinalizar())" @onclick="ConfirmarPedido">
                @(enviando ? "Aguarde..." : (TotalPagar > 0 ? "FINALIZAR PEDIDO ✅" : "CONCLUIR COM CASHBACK 🎁"))
            </button>
        }

    </div>
</div>

@code {
    private int etapa = 1;
    private string ondeComer = "";
    private string telefoneCliente = "";
    private string nomeCliente = "";
    private decimal saldoDisponivel = 0m;
    
    private bool _usarCashback = false;
    private decimal valorCashbackDesejado = 0m;
    
    private void ToggleCashback(ChangeEventArgs e)
    {
        _usarCashback = (bool)(e.Value ?? false);
        if (_usarCashback && valorCashbackDesejado == 0)
        {
            valorCashbackDesejado = MaxCashbackPermitido;
        }
    }

    private void UsarMaximoCashback()
    {
        valorCashbackDesejado = MaxCashbackPermitido;
    }

    private decimal MaxCashbackPermitido => Math.Min(Carrinho.Subtotal, saldoDisponivel);
    
    private decimal ValorCashbackAplicado 
    {
        get 
        {
            if (!_usarCashback) return 0m;
            var val = valorCashbackDesejado;
            if (val < 0) val = 0;
            if (val > MaxCashbackPermitido) val = MaxCashbackPermitido;
            return val;
        }
    }
    
    private decimal TotalPagar => Math.Max(0, Carrinho.Subtotal - ValorCashbackAplicado);

    private string pagamento = "";
    private string segundoPagamento = "";
    private decimal valorPrimeiroPagamento = 0m;
    private decimal valorSegundoPagamento = 0m;
    private string msgErro = "";
    private bool enviando = false;
    private bool mostrarDivisaoPagamento = false;

    private void AtivarDivisaoPagamento()
    {
        mostrarDivisaoPagamento = true;
        valorPrimeiroPagamento = TotalPagar;
        valorSegundoPagamento = 0;
        segundoPagamento = "";
    }

    private void DesativarDivisaoPagamento()
    {
        mostrarDivisaoPagamento = false;
        valorPrimeiroPagamento = 0;
        valorSegundoPagamento = 0;
        segundoPagamento = "";
    }

    private void CalcularSegundoPagamento(ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out decimal valor))
        {
            valorPrimeiroPagamento = valor;
            if (valorPrimeiroPagamento < 0) valorPrimeiroPagamento = 0;
            if (valorPrimeiroPagamento > TotalPagar) valorPrimeiroPagamento = TotalPagar;
            valorSegundoPagamento = TotalPagar - valorPrimeiroPagamento;
            if (valorSegundoPagamento <= 0.01m)
            {
                valorSegundoPagamento = 0;
                segundoPagamento = "";
            }
        }
        else
        {
            valorPrimeiroPagamento = 0;
            valorSegundoPagamento = TotalPagar;
        }
    }

    private void UsarValorTotalPrimeiro()
    {
        valorPrimeiroPagamento = TotalPagar;
        valorSegundoPagamento = 0;
        segundoPagamento = "";
    }

    private bool PodeFinalizar()
    {
        if (enviando) return false;
        if (TotalPagar == 0) return true; // Cashback cobriu tudo
        if (string.IsNullOrEmpty(pagamento)) return false;
        
        // Se tem divisão de pagamento, precisa do segundo método
        if (valorSegundoPagamento > 0 && string.IsNullOrEmpty(segundoPagamento))
            return false;
        
        return true;
    }

    protected override void OnInitialized()
    {
        if (!Carrinho.Itens.Any()) Nav.NavigateTo("/totem");
    }

    private bool PodeAvancar() => !string.IsNullOrEmpty(ondeComer) && !string.IsNullOrWhiteSpace(nomeCliente) && !string.IsNullOrWhiteSpace(telefoneCliente);

    private async Task BuscarCashback()
    {
        if (!string.IsNullOrWhiteSpace(telefoneCliente))
        {
            try 
            {
                var telLimpo = new string(telefoneCliente.Where(char.IsDigit).ToArray());
                if (telLimpo.Length >= 8) 
                {
                    var response = await Http.GetFromJsonAsync<SaldoCashbackDto>($"api/cashback/saldo/{telLimpo}");
                    if (response != null)
                    {
                        saldoDisponivel = response.SaldoAtual;
                        if (!string.IsNullOrWhiteSpace(response.NomeCliente) && string.IsNullOrWhiteSpace(nomeCliente))
                        {
                            nomeCliente = response.NomeCliente;
                        }
                    }
                    else
                    {
                        saldoDisponivel = 0;
                    }
                }
            } 
            catch { /* ignora se API falhar ou não tiver carteira */ }
        }
    }

    private void IrEtapa2()
    {
        msgErro = "";
        etapa = 2;
    }

    private async Task ConfirmarPedido()
    {
        enviando = true;
        msgErro = "";

        // Mapeia método de pagamento
        var metodo = pagamento switch
        {
            "Pix" => MetodoPagamento.Pix,
            "Cartao" => MetodoPagamento.Cartao,
            _ => MetodoPagamento.Dinheiro
        };

        var valorCentavos = (int)(TotalPagar * 100);

        // Mapeia segundo método de pagamento se houver divisão
        MetodoPagamento? segundoMetodo = null;
        decimal? valorSegundoPgto = null;
        
        if (valorSegundoPagamento > 0 && !string.IsNullOrEmpty(segundoPagamento))
        {
            segundoMetodo = segundoPagamento switch
            {
                "Pix" => MetodoPagamento.Pix,
                "Cartao" => MetodoPagamento.Cartao,
                _ => MetodoPagamento.Dinheiro
            };
            valorSegundoPgto = valorSegundoPagamento;
        }

        var metodoFinal = TotalPagar == 0 ? MetodoPagamento.Pix : metodo;
        var dto = new NovoPedidoDto
        {
            NomeCliente = nomeCliente + (ondeComer == "Viagem" ? " (Viagem)" : ""),
            TelefoneCliente = telefoneCliente,
            TipoAtendimento = TipoAtendimento.Totem,
            MetodoPagamento = metodoFinal,
            SegundoMetodoPagamento = segundoMetodo,
            ValorSegundoPagamento = valorSegundoPgto,
            ValorCashbackUsado = ValorCashbackAplicado,
            Itens = Carrinho.Itens.ToList(),
            // FASE 6: auto-derivar momento do pagamento (Pix=Online, demais=NaEntrega)
            MomentoPagamento = metodoFinal == MetodoPagamento.Pix
                ? BatatasFritas.Shared.Enums.MomentoPagamento.Online
                : BatatasFritas.Shared.Enums.MomentoPagamento.NaEntrega,
            SegundoMomentoPagamento = segundoMetodo.HasValue
                ? (segundoMetodo == MetodoPagamento.Pix
                    ? BatatasFritas.Shared.Enums.MomentoPagamento.Online
                    : BatatasFritas.Shared.Enums.MomentoPagamento.NaEntrega)
                : null
        };

        try
        {
            var r = await Http.PostAsJsonAsync("api/pedidos", dto);
            if (r.IsSuccessStatusCode)
            {
                var responseContent = await r.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                int idRecebido = responseContent.GetProperty("pedidoId").GetInt32();

                Carrinho.LimparCarrinho();

                // Cartão e Pix no totem → maquininha (MP Point Smart 2)
                if (pagamento == "Cartao" || pagamento == "Pix")
                {
                    Nav.NavigateTo($"/totem/pagamento-point/{idRecebido}/{valorCentavos}");
                }
                else
                {
                    Nav.NavigateTo($"/totem/sucesso/{idRecebido}?tipo={pagamento}&amount={valorCentavos}", forceLoad: true);
                }
            }
            else msgErro = "Erro ao enviar pedido: " + await r.Content.ReadAsStringAsync();
        }
        catch (Exception ex)
        {
            msgErro = "Sem conexão: " + ex.Message;
        }
        finally { enviando = false; }
    }
}

@page "/admin/dashboard"
@layout EmptyLayout
@implements IAsyncDisposable
@using BatatasFritas.Shared.DTOs
@using BatatasFritas.Web.Services
@using Microsoft.AspNetCore.SignalR.Client
@using System.Net.Http.Json
@inject HttpClient Http
@inject KdsAuthService KdsAuth
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="dash-container">
    @if (carregando)
    {
        <div class="dash-loading">⏳ Carregando dados financeiros...</div>
    }
    else if (dados != null)
    {
        <!-- CABEÇALHO -->
        <div class="dash-header no-print">
            <div class="dash-header-left">
                <h1>📊 Dashboard Financeiro</h1>
                <p>
                    Visão geral de receitas, despesas e lucro em tempo real.
                    <span style="display:inline-block; margin-left:10px; font-size:0.8rem; padding:2px 6px; border-radius:4px; font-weight:bold; @(signalrStatus == "Conectado" ? "background:#27ae60;color:#fff;" : "background:#c0392b;color:#fff;")">
                        SignalR: @signalrStatus
                    </span>
                </p>
            </div>
            <div class="dash-header-right">
                <a href="/admin" class="dash-btn-nav">⚙️ Admin</a>
                <a href="/admin/estoque" class="dash-btn-nav">📦 Estoque</a>
                <button class="dash-btn-print" style="background:#8e44ad; color:#fff;" @onclick="@(() => mostrarModalDespesa = true)">💸 Lançar Despesa</button>
                <button class="dash-btn-print" style="background:#e74c3c; color:#fff;" @onclick="@(() => mostrarModalLimpar = true)">🗑️ Zerar</button>
                <button class="dash-btn-print" @onclick="@(() => ImprimirRelatorio())">🖨️ Fechar Caixa</button>
            </div>
        </div>

        <!-- ABAS UNIFICADAS -->
        <div class="dash-tabs no-print">
            <a href="/admin/dashboard" class="dash-tab active">📊 Visão Geral</a>
            <a href="/admin/dashboard-analytics" class="dash-tab">📈 Analytics Avançado</a>
        </div>

        <!-- MENSAGENS -->
        @if (!string.IsNullOrEmpty(msgSucesso)) { <div class="dash-msg-ok no-print">✅ @msgSucesso</div> }
        @if (!string.IsNullOrEmpty(msgErro))    { <div class="dash-msg-err no-print">❌ @msgErro</div> }

        <!-- FILTRO DE PERÍODO -->
        <div class="dash-filter-bar no-print">
            <div class="dash-filter-item">
                <label>De:</label>
                <input type="date" value="@filtroInicioStr" @onchange="@(e => filtroInicioStr = e.Value?.ToString() ?? "")" />
            </div>
            <div class="dash-filter-item">
                <label>Até:</label>
                <input type="date" value="@filtroFimStr" @onchange="@(e => filtroFimStr = e.Value?.ToString() ?? "")" />
            </div>
            <button class="dash-btn-filtrar" @onclick="@(() => AplicarFiltro())" disabled="@carregando">
                @(carregando ? "⌛" : "🔍 Filtrar")
            </button>
            @if (filtroAtivo)
            {
                <button class="dash-btn-limpar-filtro" @onclick="@(() => LimparFiltro())">✕ Limpar</button>
            }
            <div class="dash-filter-atalhos">
                <span style="font-size:11px; color:#555; text-transform:uppercase; letter-spacing:1px; align-self:center;">Atalhos:</span>
                <button class="dash-btn-atalho @(filtroAtalho == "hoje" ? "ativo" : "")" @onclick="@(() => AtalhoHoje())">Hoje</button>
                <button class="dash-btn-atalho @(filtroAtalho == "semana" ? "ativo" : "")" @onclick="@(() => AtalhoEstaSemana())">Esta Semana</button>
                <button class="dash-btn-atalho @(filtroAtalho == "mes" ? "ativo" : "")" @onclick="@(() => AtalhoEsteMes())">Este Mês</button>
            </div>
        </div>

        <!-- BLOCO 0: RESUMO DO PERÍODO SELECIONADO (Se houver filtro) -->
        @if (filtroAtivo && dados.DataInicioFiltro.HasValue)
        {
            <div class="dash-section dash-period-result">
                <h2 class="dash-section-title">📅 Resultado do Período (@(dados.DataInicioFiltro?.ToString("dd/MM/yyyy") ?? "-") até @(dados.DataFimFiltro?.ToString("dd/MM/yyyy") ?? "-"))</h2>
                
                <div class="dash-kpi-grid">
                    <div class="dash-kpi-card period-card">
                        <div class="dash-kpi-title">Vendas (Período)</div>
                        <div class="dash-kpi-value cor-receita">@dados.VendasPeriodo.ToString("C2")</div>
                        <div class="dash-kpi-sub">@dados.TotalPedidosPeriodo pedidos</div>
                    </div>
                    <div class="dash-kpi-card period-card">
                        <div class="dash-kpi-title">Compras (Período)</div>
                        <div class="dash-kpi-value cor-despesa">@dados.ComprasPeriodo.ToString("C2")</div>
                    </div>
                    <div class="dash-kpi-card period-card">
                        <div class="dash-kpi-title">Despesas (Período)</div>
                        <div class="dash-kpi-value cor-despesa" style="color:#d94bd9;">@dados.DespesasPeriodo.ToString("C2")</div>
                    </div>
                    <div class="dash-kpi-card period-card @(dados.LucroPeriodo >= 0 ? "lucro-positivo" : "lucro-negativo")">
                        <div class="dash-kpi-title">Lucro do Período</div>
                        <div class="dash-kpi-value text-shadow">@dados.LucroPeriodo.ToString("C2")</div>
                    </div>
                    <div class="dash-kpi-card period-card">
                        <div class="dash-kpi-title">💚 Cashback</div>
                        <div class="dash-kpi-value" style="color:#27ae60; font-size:1.1rem;">@dados.CashbackConcedidoPeriodo.ToString("C2")</div>
                        <div class="dash-kpi-sub">concedido</div>
                        <div class="dash-kpi-sub" style="color:#e67e22;">usado: @dados.CashbackUsadoPeriodo.ToString("C2")</div>
                    </div>
                </div>
                @if (dados.PedidosPorStatus.Any())
                {
                    <div style="margin-top:12px; display:flex; flex-wrap:wrap; gap:8px; font-size:12px;">
                        @foreach (var s in dados.PedidosPorStatus)
                        {
                            <span style="background:#1e1e1e; border:1px solid #333; border-radius:6px; padding:4px 10px;">
                                @StatusEmoji(s.Status) @s.Status.ToString(): <strong>@s.Quantidade</strong>
                            </span>
                        }
                    </div>
                }

                <div class="dash-card no-print" style="margin-top: -10px; margin-bottom: 30px;">
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; flex-wrap:wrap;">
                        <!-- Pagamentos do Período -->
                        <div>
                            <h4 style="margin:0 0 12px 0; font-size:13px; text-transform:uppercase; letter-spacing:1px; color:#888;">Entradas por Método</h4>
                            <div class="dash-pagamento-row" style="border-bottom:1px solid #2a2a2a; padding:8px 0;">
                                <span>📱 PIX</span><strong>@dados.PixPeriodo.ToString("C2")</strong>
                            </div>
                            <div class="dash-pagamento-row" style="border-bottom:1px solid #2a2a2a; padding:8px 0;">
                                <span>💳 Cartão</span><strong>@dados.CartaoPeriodo.ToString("C2")</strong>
                            </div>
                            <div class="dash-pagamento-row" style="padding:8px 0;">
                                <span>💵 Dinheiro</span><strong>@dados.DinheiroPeriodo.ToString("C2")</strong>
                            </div>
                        </div>
                        <!-- Despesas do Período por Categoria -->
                        <div>
                            <h4 style="margin:0 0 12px 0; font-size:13px; text-transform:uppercase; letter-spacing:1px; color:#888;">Despesas por Categoria</h4>
                            @if (dados.DespesasPeriodo == 0) {
                                <p style="color:#555; font-size:13px;">Nenhuma despesa no período.</p>
                            }
                            @if (dados.DespesaFuncionarioPeriodo > 0) {
                                <div class="dash-pagamento-row" style="border-bottom:1px solid #2a2a2a; padding:8px 0;">
                                    <span>👷 Funcionários</span><strong style="color:#d94bd9;">@dados.DespesaFuncionarioPeriodo.ToString("C2")</strong>
                                </div>
                            }
                            @if (dados.DespesaEnergiaAguaPeriodo > 0) {
                                <div class="dash-pagamento-row" style="border-bottom:1px solid #2a2a2a; padding:8px 0;">
                                    <span>⚡ Energia/Água/Net</span><strong style="color:#d94bd9;">@dados.DespesaEnergiaAguaPeriodo.ToString("C2")</strong>
                                </div>
                            }
                            @if (dados.DespesaImpostoPeriodo > 0) {
                                <div class="dash-pagamento-row" style="border-bottom:1px solid #2a2a2a; padding:8px 0;">
                                    <span>🏛️ Imposto/Taxa</span><strong style="color:#d94bd9;">@dados.DespesaImpostoPeriodo.ToString("C2")</strong>
                                </div>
                            }
                            @if (dados.DespesaOutrosPeriodo > 0) {
                                <div class="dash-pagamento-row" style="padding:8px 0;">
                                    <span>📋 Outras</span><strong style="color:#d94bd9;">@dados.DespesaOutrosPeriodo.ToString("C2")</strong>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- CABEÇALHO DE IMPRESSÃO (Oculto na tela normal) -->
        <div class="print-only print-header">
            <h2>Fechamento de Caixa - Batatas Fritas</h2>
            <p>Data: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
        </div>

        <!-- BLOCO 1: RESUMO DO DIA -->
        <div class="dash-section">
            <h2 class="dash-section-title">Acompanhamento do Dia (@DateTime.Now.ToString("dd/MM/yyyy"))</h2>
            
            <div class="dash-kpi-grid">
                <div class="dash-kpi-card">
                    <div class="dash-kpi-title">Vendas (Receitas)</div>
                    <div class="dash-kpi-value cor-receita">@dados.VendasHoje.ToString("C2")</div>
                    <div class="dash-kpi-sub">@dados.TotalPedidosHoje pedidos entregues</div>
                </div>
                
                <div class="dash-kpi-card">
                    <div class="dash-kpi-title">Compras (Estoque)</div>
                    <div class="dash-kpi-value cor-despesa">@dados.ComprasHoje.ToString("C2")</div>
                    <div class="dash-kpi-sub">Itens para produção</div>
                </div>

                <div class="dash-kpi-card">
                    <div class="dash-kpi-title">Despesas (Equipe/Op)</div>
                    <div class="dash-kpi-value cor-despesa" style="color:#d94bd9;">@dados.DespesasHoje.ToString("C2")</div>
                    <div class="dash-kpi-sub">Pagamento de funcionários </div>
                </div>

                <div class="dash-kpi-card @(dados.LucroHoje >= 0 ? "lucro-positivo" : "lucro-negativo")">
                    <div class="dash-kpi-title">Lucro Líquido</div>
                    <div class="dash-kpi-value text-shadow">@dados.LucroHoje.ToString("C2")</div>
                    <div class="dash-kpi-sub">Rec - Est - Desp</div>
                </div>
            </div>
        </div>

        <!-- BLOCO 2: DIVISÃO DE PAGAMENTOS E META -->
        <div class="dash-grid-2col">
            <!-- Coluna 1: Métodos de Pagamento -->
            <div class="dash-card">
                <h3>Divisão por Métodos de Pagamento (Hoje)</h3>
                
                <div class="dash-pagamento-row">
                    <span>📱 PIX</span>
                    <strong>@dados.PixHoje.ToString("C2")</strong>
                </div>
                <div class="dash-pagamento-row">
                    <span>💳 Cartões (Débito/Crédito)</span>
                    <strong>@dados.CartaoHoje.ToString("C2")</strong>
                </div>
                <div class="dash-pagamento-row">
                    <span>💵 Dinheiro</span>
                    <strong>@dados.DinheiroHoje.ToString("C2")</strong>
                </div>
                
                <div class="dash-pagamento-total">
                    <span>Total Recebido:</span>
                    <strong>@dados.VendasHoje.ToString("C2")</strong>
                </div>
            </div>

            <!-- Coluna 2: Meta e Resumo do Mês -->
            <div class="dash-card">
                <h3>Desempenho Geral</h3>
                
                <div class="dash-meta-box no-print">
                    <div class="dash-meta-header">
                        <span>Meta Diária</span>
                        @if(editandoMeta)
                        {
                            <div class="dash-meta-edit-group">
                                <input type="number" class="dash-input-meta" @bind="@novaMetaInput" placeholder="0.00" />
                                <button class="dash-btn-salvar-meta" @onclick="@(() => SalvarMeta())">✔</button>
                            </div>
                        }
                        else
                        {
                            <span class="dash-meta-valor" @onclick="@(() => HabilitarEdicaoMeta())">
                                🎯 @dados.MetaDiaria.ToString("C2") ✏️
                            </span>
                        }
                    </div>
                    
                    <div class="dash-progress-wrapper" style="position:relative; height:22px;">
                        <div class="dash-progress-bar" style="width: @(Math.Min(100, dados.ProgressoMeta))%; background: @(dados.ProgressoMeta >= 100 ? "linear-gradient(90deg,#4caf50,#81c784)" : dados.ProgressoMeta >= 75 ? "linear-gradient(90deg,#ffb347,#ffe066)" : "linear-gradient(90deg,#e74c3c,#ffb347)"); height:100%; display:flex; align-items:center; justify-content:flex-end; padding-right:6px; font-size:11px; font-weight:bold; color:#000; white-space:nowrap; transition: width 0.6s cubic-bezier(0.4,0,0.2,1);">
                            @if (dados.ProgressoMeta > 12) { <span>@dados.ProgressoMeta.ToString("F0")%</span> }
                        </div>
                        @foreach (var marker in new[] { 25, 50, 75 })
                        {
                            <div style="position:absolute; top:0; bottom:0; left:@(marker)%; width:1px; background:rgba(255,255,255,0.15);"></div>
                        }
                    </div>
                    <div style="display:flex; justify-content:space-between; margin-top:4px; font-size:11px; color:#555;">
                        <span>0%</span><span>25%</span><span>50%</span><span>75%</span><span>100%</span>
                    </div>
                    <p class="dash-meta-perc">@dados.ProgressoMeta.ToString("F1")% da meta de @dados.MetaDiaria.ToString("C2") atingida hoje</p>
                </div>

                <div class="dash-mes-group">
                    <h4>Acumulado do Mês Atual</h4>

                    <div class="dash-mes-row">
                        <span>📈 Faturamento Bruto:</span>
                        <strong class="cor-receita">@dados.VendasMes.ToString("C2")</strong>
                    </div>
                    <div class="dash-mes-sub-row">
                        <span>📱 PIX</span><strong>@dados.PixMes.ToString("C2")</strong>
                    </div>
                    <div class="dash-mes-sub-row">
                        <span>💳 Cartão</span><strong>@dados.CartaoMes.ToString("C2")</strong>
                    </div>
                    <div class="dash-mes-sub-row" style="margin-bottom:8px;">
                        <span>💵 Dinheiro</span><strong>@dados.DinheiroMes.ToString("C2")</strong>
                    </div>

                    <div class="dash-mes-row">
                        <span>📦 Gastos com Estoque:</span>
                        <strong class="cor-despesa">@dados.ComprasMes.ToString("C2")</strong>
                    </div>

                    <div class="dash-mes-row" style="margin-top:4px;">
                        <span>💸 Despesas Operacionais:</span>
                        <strong style="color:#d94bd9;">@dados.DespesasMes.ToString("C2")</strong>
                    </div>
                    @if (dados.DespesaFuncionarioMes > 0) {
                        <div class="dash-mes-sub-row"><span>👷 Funcionários</span><strong>@dados.DespesaFuncionarioMes.ToString("C2")</strong></div>
                    }
                    @if (dados.DespesaEnergiaAguaMes > 0) {
                        <div class="dash-mes-sub-row"><span>⚡ Energia/Água/Net</span><strong>@dados.DespesaEnergiaAguaMes.ToString("C2")</strong></div>
                    }
                    @if (dados.DespesaImpostoMes > 0) {
                        <div class="dash-mes-sub-row"><span>🏛️ Imposto/Taxa</span><strong>@dados.DespesaImpostoMes.ToString("C2")</strong></div>
                    }
                    @if (dados.DespesaOutrosMes > 0) {
                        <div class="dash-mes-sub-row" style="margin-bottom:8px;"><span>📋 Outras</span><strong>@dados.DespesaOutrosMes.ToString("C2")</strong></div>
                    }

                    <div class="dash-mes-row destaque">
                        <span>💰 Lucro Acumulado:</span>
                        <strong class="@(dados.LucroMes >= 0 ? "cor-receita" : "cor-despesa")">@dados.LucroMes.ToString("C2")</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="print-footer print-only">
            <p>Assinatura Responsável: _______________________________</p>
        </div>
    }
</div>

<!-- ============================
     MODAIS ADICIONAIS
     ============================ -->

@if (mostrarModalDespesa)
{
    <div class="modal-overlay" style="align-items: center; padding: 20px; background: rgba(0,0,0,0.8);">
        <div class="modal-content" style="max-width: 400px; width: 100%; max-height: 90vh; overflow-y: auto; padding: 30px; border-radius: 12px; background: #222; border: 1px solid #444; color: #fff; box-sizing: border-box;">
            <h3>Lançar Despesa (Funcionários etc)</h3>
            <p style="color: #aaa; margin-bottom: 20px;">Isso deduzirá do seu lucro no relatório de fechamento.</p>

            <label>Descrição</label>
            <input type="text" @bind="novaDespesaDescricao" placeholder="Ex: Diária Chapeiro Marcos" style="width: 100%; margin-bottom: 10px; padding: 10px; border-radius: 5px; background: #111; border: 1px solid #333; color: #fff;" />
            
            <label>Categoria</label>
            <select @bind="novaDespesaCategoria" style="width: 100%; margin-bottom: 10px; padding: 10px; border-radius: 5px; background: #111; border: 1px solid #333; color: #fff;">
                <option value="Funcionario">Funcionário / Mão de Obra</option>
                <option value="Energia/Agua">Energia / Água / Net</option>
                <option value="Imposto">Imposto / Taxa</option>
                <option value="Outros">Outras Despesas</option>
            </select>
            
            <label>Valor (R$)</label>
            <input type="number" step="0.01" min="0" @bind="novaDespesaValor" style="width: 100%; margin-bottom: 10px; padding: 10px; border-radius: 5px; background: #111; border: 1px solid #333; color: #fff;" />

            <label>Data da Despesa</label>
            <input type="date" value="@novaDespesaDataStr" @onchange="@(e => novaDespesaDataStr = e.Value?.ToString() ?? "")" style="width: 100%; margin-bottom: 10px; padding: 10px; border-radius: 5px; background: #111; border: 1px solid #333; color: #fff;" />

            <label>Observação (opcional)</label>
            <textarea @bind="novaDespesaObservacao" placeholder="Ex: Ref. semana 10/03 a 15/03..." rows="3" style="width: 100%; margin-bottom: 20px; padding: 10px; border-radius: 5px; background: #111; border: 1px solid #333; color: #fff; resize: none; box-sizing: border-box;"></textarea>

            <div style="display: flex; gap: 10px;">
                <button style="flex: 1; padding: 10px; background: #555; color: #fff; border: none; border-radius: 5px; cursor: pointer;" @onclick="@(() => mostrarModalDespesa = false)">Cancelar</button>
                <button style="flex: 1; padding: 10px; background: #8e44ad; color: #fff; border: none; border-radius: 5px; font-weight: bold; cursor: pointer;" @onclick="@(() => LancarDespesa())" disabled="@processandoAcao">Lançar</button>
            </div>
        </div>
    </div>
}

@if (mostrarModalLimpar)
{
    <div class="modal-overlay" style="align-items: center; padding: 20px; background: rgba(0,0,0,0.8);">
        <div class="modal-content" style="max-width: 450px; padding: 30px; border-radius: 12px; background: #222; border: 2px solid #e74c3c; color: #fff; text-align: center;">
            <div style="font-size: 3rem; margin-bottom: 10px;">⚠️</div>
            <h3 style="color: #e74c3c; margin-bottom: 10px;">Zerar Dados do Sistema</h3>
            <p style="color: #ccc; margin-bottom: 25px;">Escolha o período que deseja limpar e insira a senha. Essa ação não pode ser desfeita.</p>

            <div style="display: flex; gap: 15px; text-align: left; margin-bottom: 15px;">
                <div style="flex: 1;">
                    <label style="display:block; font-weight:bold; margin-bottom:5px; color:#aaa; font-size:0.8rem;">Data Inicial</label>
                    <input type="date" value="@dataInicioLimpezaStr" @onchange="@(e => dataInicioLimpezaStr = e.Value?.ToString() ?? "")" style="width:100%; padding: 10px; border: 1px solid #444; background: #111; color: #fff; border-radius: 6px;" />
                </div>
                <div style="flex: 1;">
                    <label style="display:block; font-weight:bold; margin-bottom:5px; color:#aaa; font-size:0.8rem;">Data Final</label>
                    <input type="date" value="@dataFimLimpezaStr" @onchange="@(e => dataFimLimpezaStr = e.Value?.ToString() ?? "")" style="width:100%; padding: 10px; border: 1px solid #444; background: #111; color: #fff; border-radius: 6px;" />
                </div>
            </div>

            <div style="text-align: left; margin-bottom: 25px;">
                <label style="display:block; font-weight:bold; margin-bottom:5px; color:#e74c3c; font-size:0.8rem;">Senha de Administrador</label>
                <input type="password" @bind="senhaAdminLimpeza" placeholder="Digite a senha..." style="width:100%; padding: 10px; border: 1px solid #444; background: #111; color: #fff; border-radius: 6px;" />
            </div>
            <button style="width: 100%; margin-bottom: 15px; padding: 15px; background: #ff9800; color: #fff; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; text-transform: uppercase;" @onclick="@(() => LimparDados("pedidos"))" disabled="@(string.IsNullOrWhiteSpace(senhaAdminLimpeza) || processandoAcao)">
                🧨 APAGAR PEDIDOS DO PERÍODO
            </button>
            
            <button style="width: 100%; margin-bottom: 15px; padding: 15px; background: #d32f2f; color: #fff; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; text-transform: uppercase;" @onclick="@(() => LimparDados("despesas"))" disabled="@(string.IsNullOrWhiteSpace(senhaAdminLimpeza) || processandoAcao)">
                🔥 APAGAR DESPESAS DO PERÍODO
            </button>

            <button style="width: 100%; margin-bottom: 25px; padding: 15px; background: #000; color: #ffb347; border: 2px solid #ffb347; border-radius: 5px; font-weight: bold; cursor: pointer; text-transform: uppercase;" @onclick="@(() => LimparDados("estoque"))" disabled="@(string.IsNullOrWhiteSpace(senhaAdminLimpeza) || processandoAcao)">
                📦 APAGAR MOVIMENTAÇÕES DE ESTOQUE (COMPRAS)
            </button>
            <button style="width: 100%; padding: 10px; background: #444; color: #fff; border: none; border-radius: 5px; cursor: pointer;" @onclick="@(() => mostrarModalLimpar = false)" disabled="@processandoAcao">Cancelar / Voltar</button>
        </div>
    </div>
}

<style>
/* ========================================================= 
   DASHBOARD STYLES (Glassmorphism & Brutal aesthetic)
========================================================= */
.dash-container {
    padding: 30px;
    background: #111;
    min-height: 100vh;
    color: #fff;
    font-family: 'Inter', 'Segoe UI', sans-serif;
}
.dash-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding-bottom: 20px;
    border-bottom: 1px solid #333;
}
.dash-header h1 { margin: 0; color: #ffb347; font-size: 32px; font-weight: 800; letter-spacing: -1px; }
.dash-header p { margin: 5px 0 0 0; color: #aaa; font-size: 16px; }

.dash-btn-nav {
    display: inline-block;
    padding: 10px 20px;
    background: #2a2a2a;
    color: #fff;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    margin-left: 10px;
    transition: 0.2s;
    border: 1px solid #444;
}
.dash-btn-nav:hover { background: #3a3a3a; transform: translateY(-2px); }
.dash-btn-print {
    padding: 10px 20px;
    background: #ffb347;
    color: #000;
    border: none;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
    margin-left: 10px;
    transition: 0.2s;
}
.dash-btn-print:hover { background: #e09e3f; transform: scale(1.05); }

/* Grid de KPIs (Top) */
.dash-kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 30px;
}
.dash-tabs {
    display: flex;
    gap: 20px;
    margin-bottom: 25px;
    border-bottom: 1px solid #333;
    padding-bottom: 0;
}
.dash-tab {
    padding: 10px 20px;
    color: #888;
    text-decoration: none;
    font-weight: 600;
    border-bottom: 3px solid transparent;
    transition: 0.2s;
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.dash-tab:hover {
    color: #ccc;
    background: rgba(255,255,255,0.03);
    border-radius: 6px 6px 0 0;
}
.dash-tab.active {
    color: #ffb347;
    border-bottom: 3px solid #ffb347;
}
.dash-kpi-card {
    background: rgba(40, 40, 40, 0.6);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px;
    padding: 25px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    position: relative;
    overflow: hidden;
}
.dash-kpi-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 4px;
    background: #444;
}
.dash-kpi-card.lucro-positivo::before { background: linear-gradient(90deg, #4caf50, #81c784); }
.dash-kpi-card.lucro-negativo::before { background: linear-gradient(90deg, #f44336, #e57373); }

.dash-kpi-title { font-size: 14px; text-transform: uppercase; letter-spacing: 1px; color: #888; font-weight: 600; margin-bottom: 10px; }
.dash-kpi-value { font-size: 42px; font-weight: 900; margin-bottom: 5px; letter-spacing: -2px; }
.dash-kpi-sub { color: #aaa; font-size: 13px; }

.cor-receita { color: #4caf50; }
.cor-despesa { color: #f44336; }
.text-shadow { text-shadow: 0 2px 10px rgba(0,0,0,0.5); }

/* Grid Inferior de 2 Colunas */
.dash-grid-2col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}
.dash-card {
    background: #1a1a1a;
    border: 1px solid #333;
    border-radius: 16px;
    padding: 25px;
}
.dash-card h3 {
    margin: 0 0 20px 0;
    font-size: 18px;
    color: #fff;
    border-bottom: 1px solid #333;
    padding-bottom: 10px;
}

/* Tabela de Pagamentos */
.dash-pagamento-row {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid #2a2a2a;
    font-size: 16px;
}
.dash-pagamento-total {
    display: flex;
    justify-content: space-between;
    padding: 16px 0 0 0;
    margin-top: 10px;
    font-size: 20px;
    color: #ffb347;
}

/* Meta Diária Widget */
.dash-meta-box {
    background: #222;
    padding: 15px;
    border-radius: 12px;
    margin-bottom: 25px;
}
.dash-meta-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
}
.dash-meta-valor {
    color: #ffb347;
    font-weight: bold;
    cursor: pointer;
    background: #333;
    padding: 4px 10px;
    border-radius: 6px;
    transition: 0.2s;
}
.dash-meta-valor:hover { background: #444; }

.dash-meta-edit-group { display: flex; gap: 5px; }
.dash-input-meta { width: 100px; padding: 5px; border-radius: 4px; border: 1px solid #ffb347; background: #000; color: #fff; }
.dash-btn-salvar-meta { background: #ffb347; color: #000; border: none; font-weight: bold; border-radius: 4px; cursor: pointer; }

.dash-progress-wrapper {
    height: 12px;
    background: #111;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid #333;
}
.dash-progress-bar {
    height: 100%;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}
.dash-meta-perc {
    margin: 8px 0 0 0;
    font-size: 12px;
    color: #888;
    text-align: right;
}

/* Resumo do Mês */
.dash-mes-row {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    font-size: 15px;
}
.dash-mes-sub-row {
    display: flex;
    justify-content: space-between;
    padding: 3px 0 3px 16px;
    font-size: 13px;
    color: #aaa;
    border-left: 2px solid #333;
    margin-left: 4px;
}
.dash-mes-row.destaque {
    font-size: 18px;
    padding-top: 12px;
    margin-top: 8px;
    border-top: 1px dashed #444;
}

.dash-msg-ok, .dash-msg-err {
    padding: 12px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-weight: bold;
}
.dash-msg-ok { background: rgba(76, 175, 80, 0.2); border: 1px solid #4caf50; color: #81c784; }
.dash-msg-err { background: rgba(244, 67, 54, 0.2); border: 1px solid #f44336; color: #e57373; }

/* ========================================================= 
   PRINT STYLES (Somente para "Fechar Caixa")
========================================================= */
.print-only { display: none; }
@@media print {
    body { background: #fff !important; color: #000 !important; }
    .dash-container { background: #fff !important; color: #000 !important; padding: 0 !important; }
    .no-print { display: none !important; }
    .print-only { display: block !important; }
    
    .print-header { text-align: center; border-bottom: 2px solid #000; padding-bottom: 10px; margin-bottom: 20px; }
    .print-footer { margin-top: 50px; text-align: center; font-size: 14px; }
    
    .dash-card, .dash-kpi-card { 
        border: 1px solid #000 !important; 
        background: #fff !important; 
        color: #000 !important;
        box-shadow: none !important;
        page-break-inside: avoid;
    }
    .cor-receita, .cor-despesa { color: #000 !important; }
    .dash-kpi-value { font-size: 24px !important; letter-spacing: normal !important; text-shadow: none !important; }
    .dash-kpi-grid { gap: 10px !important; }
    .dash-grid-2col { display: block !important; }
    .dash-card { margin-bottom: 20px !important; }
}

/* ========================================================= 
   MOBILE RESPONSIVENESS
========================================================= */
@@media (max-width: 768px) {
    .dash-container { padding: 12px; }
    .dash-header { flex-direction: column; align-items: flex-start; gap: 12px; }
    .dash-header h1 { font-size: 22px; }
    .dash-header-right { display: flex; flex-wrap: wrap; gap: 8px; }
    .dash-btn-nav, .dash-btn-print { margin-left: 0; font-size: 0.8rem; padding: 8px 12px; }
    .dash-kpi-grid { grid-template-columns: 1fr !important; gap: 12px; }
    .dash-kpi-value { font-size: 28px; }
    .dash-kpi-card { padding: 16px; }
    .dash-grid-2col { grid-template-columns: 1fr !important; }
    .dash-card { padding: 16px; }
    .dash-section-title { font-size: 1.1rem; }
}


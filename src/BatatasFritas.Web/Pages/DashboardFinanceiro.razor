</style>

@code {
    private bool carregando = true;
    private bool processandoAcao = false;
    private FinanceiroDashboardDto? dados;
    private string msgSucesso = "";
    private string msgErro = "";
    
    // Edição de Meta Dinâmica
    private bool editandoMeta = false;
    private decimal novaMetaInput = 0;
    
    // Modal e inputs Despesa
    private bool mostrarModalDespesa = false;
    private string novaDespesaDescricao = "";
    private string novaDespesaCategoria = "Funcionario";
    private decimal novaDespesaValor = 0;
    private string novaDespesaObservacao = "";
    private string novaDespesaDataStr = DateTime.Today.ToString("yyyy-MM-dd");
    
    // Modal Limpeza
    private bool mostrarModalLimpar = false;
    
    private HubConnection? _hubConnection;
    private string signalrStatus = "Conectando...";

    protected override async Task OnInitializedAsync()
    {
        if (!await KdsAuth.EstaAutenticadoAsync())
        {
            var returnUrl = Nav.ToBaseRelativePath(Nav.Uri);
            Nav.NavigateTo($"/kds/login?returnUrl={returnUrl}", replace: true);
            return;
        }
        await CarregarDados();
        await ConectarSignalR();
    }

    private async Task ConectarSignalR()
    {
        var apiBase = Http.BaseAddress?.ToString().TrimEnd('/') ?? "";
        string hubUrl;
        if (apiBase.EndsWith("/api", StringComparison.OrdinalIgnoreCase))
            hubUrl = apiBase.Substring(0, apiBase.Length - 4) + "/hubs/pedidos";
        else
            hubUrl = $"{apiBase}/hubs/pedidos";

        var token = KdsAuth.GetToken();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl, options =>
            {
                if (!string.IsNullOrEmpty(token))
                    options.AccessTokenProvider = () => Task.FromResult<string?>(token);
            })
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.Closed += (ex) => {
            signalrStatus = "Desconectado!";
            InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        };
        _hubConnection.Reconnecting += (ex) => {
            signalrStatus = "Reconectando...";
            InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        };
        _hubConnection.Reconnected += (id) => {
            signalrStatus = "Conectado";
            InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        };

        _hubConnection.On<int>("NovoPedido", async pedidoId =>
        {
            await CarregarDados();
            await InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<int, string>("StatusAtualizado", async (pedidoId, status) =>
        {
            await CarregarDados();
            await InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
            signalrStatus = "Conectado";
        }
        catch (Exception ex)
        {
            signalrStatus = "Erro de Conexão: " + ex.Message;
        }
    }

    private async Task CarregarDados()
    {
        carregando = true;
        msgErro = "";
        try
        {
            string url = "api/financeiro/dashboard";
            if (filtroAtivo && !string.IsNullOrEmpty(filtroInicioStr) && !string.IsNullOrEmpty(filtroFimStr))
            {
                url += $"?inicio={filtroInicioStr}&fim={filtroFimStr}";
            }
            dados = await Http.GetFromJsonAsync<FinanceiroDashboardDto>(url);
        }
        catch (Exception ex)
        {
            msgErro = "Erro ao carregar dados financeiros: " + ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }

    // Datas como string yyyy-MM-dd — evita o bug de DateTime.MinValue (ano 0001)
    // causado pelo Blazor tentar fazer parse com cultura pt-BR ao editar manualmente.
    private string filtroInicioStr = DateTime.Today.AddDays(-7).ToString("yyyy-MM-dd");
    private string filtroFimStr    = DateTime.Today.ToString("yyyy-MM-dd");
    private bool   filtroAtivo  = false;
    private string filtroAtalho = "";

    private async Task AplicarFiltro()
    {
        filtroAtalho = "";
        filtroAtivo  = true;
        await CarregarDados();
    }

    private async Task AtalhoHoje()
    {
        var hoje = DateTime.Today.ToString("yyyy-MM-dd");
        filtroInicioStr = hoje;
        filtroFimStr    = hoje;
        filtroAtalho    = "hoje";
        filtroAtivo     = true;
        await CarregarDados();
    }

    private async Task AtalhoEstaSemana()
    {
        var hoje = DateTime.Today;
        int diasDesdeSegunda = ((int)hoje.DayOfWeek - (int)DayOfWeek.Monday + 7) % 7;
        filtroInicioStr = hoje.AddDays(-diasDesdeSegunda).ToString("yyyy-MM-dd");
        filtroFimStr    = hoje.ToString("yyyy-MM-dd");
        filtroAtalho    = "semana";
        filtroAtivo     = true;
        await CarregarDados();
    }

    private async Task AtalhoEsteMes()
    {
        var hoje = DateTime.Today;
        filtroInicioStr = new DateTime(hoje.Year, hoje.Month, 1).ToString("yyyy-MM-dd");
        filtroFimStr    = hoje.ToString("yyyy-MM-dd");
        filtroAtalho    = "mes";
        filtroAtivo     = true;
        await CarregarDados();
    }

    private async Task LimparFiltro()
    {
        filtroInicioStr = DateTime.Today.AddDays(-7).ToString("yyyy-MM-dd");
        filtroFimStr    = DateTime.Today.ToString("yyyy-MM-dd");
        filtroAtivo     = false;
        filtroAtalho    = "";
        await CarregarDados();
    }

    private void HabilitarEdicaoMeta()
    {
        if (dados != null)
        {
            novaMetaInput = dados.MetaDiaria;
            editandoMeta = true;
        }
    }

    private async Task SalvarMeta()
    {
        msgSucesso = ""; msgErro = "";
        try
        {
            var r = await Http.PostAsJsonAsync("api/financeiro/meta", novaMetaInput);
            if (r.IsSuccessStatusCode)
            {
                msgSucesso = "Meta atualizada com sucesso!";
                editandoMeta = false;
                await CarregarDados();
            }
            else
            {
                msgErro = "Erro ao salvar meta.";
            }
        }
        catch (Exception ex)
        {
            msgErro = "Erro de conexão: " + ex.Message;
        }
    }

    private async Task ImprimirRelatorio()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task LancarDespesa()
    {
        if (string.IsNullOrWhiteSpace(novaDespesaDescricao) || novaDespesaValor <= 0)
        {
            msgErro = "Preencha a descrição e valor válidos!";
            return;
        }

        processandoAcao = true;
        msgErro = ""; msgSucesso = "";

        try
        {
            var despesa = new DespesaDto
            {
                Descricao = novaDespesaDescricao,
                Categoria = novaDespesaCategoria,
                Valor = novaDespesaValor,
                DataRegistro = DateTime.Parse(novaDespesaDataStr),
                Observacao = string.IsNullOrWhiteSpace(novaDespesaObservacao) ? null : novaDespesaObservacao
            };

            var r = await Http.PostAsJsonAsync("api/despesas", despesa);
            if (r.IsSuccessStatusCode)
            {
                mostrarModalDespesa = false;
                msgSucesso = "Despesa lançada com sucesso!";
                novaDespesaDescricao = "";
                novaDespesaValor = 0;
                novaDespesaObservacao = "";
                novaDespesaDataStr = DateTime.Today.ToString("yyyy-MM-dd");
                await CarregarDados();
            }
            else
            {
                msgErro = "Erro ao registrar despesa.";
            }
        }
        catch (Exception ex)
        {
            msgErro = "Erro: " + ex.Message;
        }
        finally
        {
            processandoAcao = false;
        }
    }

    private string dataInicioLimpezaStr = DateTime.Today.AddDays(-30).ToString("yyyy-MM-dd");
    private string dataFimLimpezaStr    = DateTime.Today.ToString("yyyy-MM-dd");
    private string senhaAdminLimpeza = "";

    private async Task LimparDados(string tipo)
    {
        if (string.IsNullOrWhiteSpace(senhaAdminLimpeza)) return;
        processandoAcao = true;
        msgErro = ""; msgSucesso = "";

        try
        {
            var dto = new LimparHistoricoDto
            {
                Tipo = tipo,
                DataInicio = DateTime.Parse(dataInicioLimpezaStr),
                DataFim    = DateTime.Parse(dataFimLimpezaStr),
                SenhaAdmin = senhaAdminLimpeza
            };

            var r = await Http.PostAsJsonAsync("api/financeiro/limpar-historico", dto);
            if (r.IsSuccessStatusCode)
            {
                mostrarModalLimpar = false;
                msgSucesso = "Histórico do período apagado com sucesso!";
                senhaAdminLimpeza = "";
                await CarregarDados();
            }
            else
            {
                msgErro = $"Falha ao apagar dados: {await r.Content.ReadAsStringAsync()}";
            }
        }
        catch (Exception ex)
        {
            msgErro = "Erro: " + ex.Message;
        }
        finally
        {
            processandoAcao = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }

    private static string StatusEmoji(BatatasFritas.Shared.Enums.StatusPedido status) => status switch
    {
        BatatasFritas.Shared.Enums.StatusPedido.Recebido    => "🟡",
        BatatasFritas.Shared.Enums.StatusPedido.EmPreparo   => "🔵",
        BatatasFritas.Shared.Enums.StatusPedido.Entregue    => "✅",
        BatatasFritas.Shared.Enums.StatusPedido.Cancelado   => "🔴",
        _                                                    => "⚪"
    };
}

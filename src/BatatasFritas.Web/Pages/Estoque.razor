@page "/admin/estoque"
@layout EmptyLayout
@using BatatasFritas.Shared.DTOs
@using BatatasFritas.Web.Services
@using System.Net.Http.Json
@inject HttpClient Http
@inject KdsAuthService KdsAuth
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="est-container">

    <!-- ── CABEÇALHO ─────────────────────────────────────────── -->
    <div class="est-header">
        <div class="est-header-left">
            <h1>📦 Estoque</h1>
            <span class="est-header-sub">Insumos, Compras e Movimentações</span>
        </div>
        <div class="est-header-right">
            <a href="/admin" class="est-btn-nav">⚙️ Admin</a>
            <a href="/admin/dashboard" class="est-btn-nav">📊 Dashboard</a>
        </div>
    </div>

    <!-- ── ABAS ───────────────────────────────────────────────── -->
    <div class="est-tabs">
        <button class="est-tab @(abaAtiva == "dashboard" ? "ativo" : "")" @onclick="@(() => abaAtiva = "dashboard")">
            🏠 Visão Geral
        </button>
        <button class="est-tab @(abaAtiva == "insumos" ? "ativo" : "")" @onclick="@(() => MudarAba("insumos"))">
            🧂 Insumos @(dashboard?.InsumosAbaixoMinimo > 0 ? $"⚠️{dashboard.InsumosAbaixoMinimo}" : "")
        </button>
        <button class="est-tab @(abaAtiva == "compras" ? "ativo" : "")" @onclick="@(() => MudarAba("compras"))">
            🛒 Compras / Entradas
        </button>
        <button class="est-tab @(abaAtiva == "saidas" ? "ativo" : "")" @onclick="@(() => MudarAba("saidas"))">
            📉 Movimentações
        </button>
    </div>

    <!-- ── BARRA DE FILTRO POR PERÍODO ────────────────────────── -->
    <div class="rel-filtro-bar" style="margin-top: 15px; margin-bottom: 20px;">
        <div class="rel-filtro-grupo">
            <label>De</label>
            <input type="date" value="@filtroInicioStr" @onchange="@(e => filtroInicioStr = e.Value?.ToString() ?? "")" class="rel-filtro-input" />
        </div>
        <div class="rel-filtro-grupo">
            <label>Até</label>
            <input type="date" value="@filtroFimStr" @onchange="@(e => filtroFimStr = e.Value?.ToString() ?? "")" class="rel-filtro-input" />
        </div>

        <div class="rel-filtro-atalhos">
            <button class="rel-btn-atalho" @onclick="@(() => AplicarAtalho("hoje"))">Hoje</button>
            <button class="rel-btn-atalho" @onclick="@(() => AplicarAtalho("7dias"))">7 dias</button>
            <button class="rel-btn-atalho" @onclick="@(() => AplicarAtalho("30dias"))">30 dias</button>
            <button class="rel-btn-atalho" @onclick="@(() => AplicarAtalho("mes"))">Este mês</button>
        </div>

        <button class="rel-btn-filtrar" @onclick="@(() => CarregarTudo())" disabled="@carregando">
            @(carregando ? "⏳" : "🔍 Filtrar")
        </button>
    </div>

    @if (carregando)
    {
        <div class="est-loading">⏳ Carregando...</div>
    }
    else
    {
        <!-- ================================================================
             ABA: VISÃO GERAL
             ================================================================ -->
        @if (abaAtiva == "dashboard" && dashboard != null)
        {
            <div class="est-section">
                <!-- KPIs -->
                <div class="est-kpi-grid">
                    <div class="est-kpi-card">
                        <div class="est-kpi-label">🧂 Total de Insumos</div>
                        <div class="est-kpi-valor">@dashboard.TotalInsumos</div>
                    </div>
                    <div class="est-kpi-card @(dashboard.InsumosAbaixoMinimo > 0 ? "est-kpi-alerta" : "")">
                        <div class="est-kpi-label">⚠️ Abaixo do Mínimo</div>
                        <div class="est-kpi-valor">@dashboard.InsumosAbaixoMinimo</div>
                    </div>
                    <div class="est-kpi-card">
                        <div class="est-kpi-label">💰 Valor do Estoque</div>
                        <div class="est-kpi-valor">@dashboard.ValorEstoqueAtual.ToString("C2")</div>
                    </div>
                    <div class="est-kpi-card">
                        <div class="est-kpi-label">🛒 Total Gasto em Compras</div>
                        <div class="est-kpi-valor">@dashboard.TotalGastosCompras.ToString("C2")</div>
                    </div>
                </div>

                <!-- Alertas -->
                @if (dashboard.AlertasEstoque.Any())
                {
                    <div class="est-card" style="margin-top:20px">
                        <div class="est-card-title">⚠️ Insumos Abaixo do Mínimo</div>
                        <div class="est-table-wrap">
                            <table class="est-table">
                                <thead><tr><th>Insumo</th><th>Atual</th><th>Mínimo</th><th>Ação</th></tr></thead>
                                <tbody>
                                @foreach (var i in dashboard.AlertasEstoque)
                                {
                                    <tr class="est-row-alerta">
                                        <td>@i.Nome</td>
                                        <td class="est-td-alerta">@i.EstoqueAtual.ToString("0.###") @i.Unidade</td>
                                        <td>@i.EstoqueMinimo.ToString("0.###") @i.Unidade</td>
                                        <td><button class="est-btn-entrada" @onclick="@(() => AbrirEntrada(i))">+ Entrada</button></td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <!-- Últimas movimentações -->
                @if (dashboard.UltimasMovimentacoes.Any())
                {
                    <div class="est-card" style="margin-top:20px">
                        <div class="est-card-title">🕐 Últimas Movimentações</div>
                        <div class="est-table-wrap">
                            <table class="est-table">
                                <thead><tr><th>Data</th><th>Insumo</th><th>Tipo</th><th>Qtd</th><th>Valor</th><th>Motivo</th></tr></thead>
                                <tbody>
                                @foreach (var m in dashboard.UltimasMovimentacoes)
                                {
                                    <tr>
                                        <td>@m.DataMovimentacao.ToString("dd/MM HH:mm")</td>
                                        <td>@m.InsumoNome</td>
                                        <td><span class="est-badge-tipo est-tipo-@m.Tipo.ToLower()">@m.Tipo</span></td>
                                        <td>@m.Quantidade</td>
                                        <td>@m.ValorTotal.ToString("C2")</td>
                                        <td class="est-td-motivo">@m.Motivo</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- ================================================================
             ABA: INSUMOS
             ================================================================ -->
        @if (abaAtiva == "insumos")
        {
            <div class="est-section">
                <!-- Mensagens -->
                @if (!string.IsNullOrEmpty(msgSucesso)) { <div class="est-msg-ok">✅ @msgSucesso</div> }
                @if (!string.IsNullOrEmpty(msgErro))    { <div class="est-msg-err">❌ @msgErro</div> }

                <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 20px;">
                    <label class="est-switch-label">
                        <input type="checkbox" @bind="mostrarInativos" @bind:after="CarregarTudo" />
                        🔍 Mostrar itens excluídos/antigos
                    </label>
                </div>

                <!-- Formulário novo/editar insumo -->
                <div class="est-card">
                    <div class="est-card-title">@(editandoInsumo?.Id > 0 ? "✏️ Editar Insumo" : "➕ Novo Insumo")</div>
                    <div class="est-form-grid">
                        <div class="est-form-grupo">
                            <label>Nome *</label>
                            <input @bind="editandoInsumo!.Nome" class="est-input" placeholder="Ex: Batata Rústica" />
                        </div>
                        <div class="est-form-grupo">
                            <label>Unidade</label>
                            <select @bind="editandoInsumo.Unidade" class="est-input">
                                <option value="kg">kg</option>
                                <option value="g">g</option>
                                <option value="L">L</option>
                                <option value="ml">ml</option>
                                <option value="un">un</option>
                                <option value="cx">cx</option>
                                <option value="pct">pct</option>
                            </select>
                        </div>
                        <div class="est-form-grupo">
                            <label>Estoque Mínimo</label>
                            <input type="number" step="0.01" @bind="editandoInsumo.EstoqueMinimo" class="est-input" />
                        </div>
                        <div class="est-form-grupo">
                            <label>Custo por Unidade (R$)</label>
                            <input type="number" step="0.01" @bind="editandoInsumo.CustoPorUnidade" class="est-input" />
                        </div>
                    </div>
                    <div class="est-form-btns">
                        <button class="est-btn-salvar" @onclick="@(() => SalvarInsumo())">💾 Salvar</button>
                        @if (editandoInsumo.Id > 0)
                        {
                            <button class="est-btn-cancelar" @onclick="@(() => NovoInsumo())">✕ Cancelar</button>
                        }
                    </div>
                </div>

                <!-- Lista de insumos -->
                <div class="est-card" style="margin-top:16px">
                    <div class="est-card-title">🧂 Todos os Insumos</div>
                    @if (insumos.Any())
                    {
                        <div class="est-table-wrap">
                            <table class="est-table">
                                <thead>
                                    <tr>
                                        <th>Nome</th>
                                        <th>Unidade</th>
                                        <th style="width: 120px;">Estoque</th>
                                        <th>Mínimo</th>
                                        <th>Custo/Un</th>
                                        <th>Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var i in insumos.OrderBy(x => x.Nome))
                                {
                                    <tr class="@(i.AbaixoDoMinimo ? "est-row-alerta" : "") @(!i.Ativo ? "est-row-inativo" : "")">
                                        <td>
                                            @i.Nome
                                            @if (i.AbaixoDoMinimo && i.Ativo) { <span class="est-badge-alerta">⚠️ Baixo</span> }
                                            @if (!i.Ativo) { <span class="est-badge-inativo">∅ Excluído</span> }
                                        </td>
                                        <td>@i.Unidade</td>
                                        <td>
                                            <div style="display:flex; align-items:center; gap:5px;">
                                                <strong>@i.EstoqueAtual.ToString("0.###")</strong>
                                                @if(i.Ativo) {
                                                    <button class="est-btn-ajustar-mini" @onclick="@(() => AbrirAjuste(i))" title="Ajustar saldo real">🔧</button>
                                                }
                                            </div>
                                        </td>
                                        <td>@i.EstoqueMinimo.ToString("0.###")</td>
                                        <td>@i.CustoPorUnidade.ToString("C2")</td>
                                        <td class="est-td-acoes">
                                            @if (i.Ativo)
                                            {
                                                <button class="est-btn-editar" @onclick="@(() => EditarInsumo(i))" title="Editar">✏️</button>
                                                <button class="est-btn-entrada" @onclick="@(() => AbrirEntrada(i))" title="Entrada">+ In</button>
                                                <button class="est-btn-deletar" @onclick="@(() => DeletarInsumo(i))" title="Excluir">🗑️</button>
                                            }
                                            else
                                            {
                                                <button class="est-btn-restaurar" @onclick="@(() => RestaurarInsumo(i))">♻️ Recuperar</button>
                                            }
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="est-empty">Nenhum insumo cadastrado. Adicione o primeiro acima.</p>
                    }
                </div>
            </div>
        }

        <!-- ================================================================
             ABA: COMPRAS / ENTRADAS
             ================================================================ -->
        @if (abaAtiva == "compras")
        {
            <div class="est-section">
                @if (!string.IsNullOrEmpty(msgSucesso)) { <div class="est-msg-ok">✅ @msgSucesso</div> }
                @if (!string.IsNullOrEmpty(msgErro))    { <div class="est-msg-err">❌ @msgErro</div> }

                <div class="est-card">
                    <div class="est-card-title">🛒 Registrar Compra / Entrada</div>
                    <div class="est-form-grid">
                        <div class="est-form-grupo">
                            <label>Insumo *</label>
                            <select @bind="novaMovimentacao.InsumoId" class="est-input">
                                <option value="0">— Selecione —</option>
                                @foreach (var i in insumos)
                                {
                                    <option value="@i.Id">@i.Nome (@i.Unidade)</option>
                                }
                            </select>
                        </div>
                        <div class="est-form-grupo">
                            <label>Quantidade</label>
                            <input type="number" step="0.01" @bind="novaMovimentacao.Quantidade" class="est-input" />
                        </div>
                        <div class="est-form-grupo">
                            <label>Valor Unitário (R$)</label>
                            <input type="number" step="0.01" @bind="novaMovimentacao.ValorUnitario" class="est-input" />
                        </div>
                        <div class="est-form-grupo">
                            <label>Fornecedor</label>
                            <input @bind="novaMovimentacao.Fornecedor" class="est-input" placeholder="Nome do fornecedor" />
                        </div>
                        <div class="est-form-grupo">
                            <label>Nº NF / Cupom</label>
                            <input @bind="novaMovimentacao.NumeroNF" class="est-input" placeholder="Opcional" />
                        </div>
                        <div class="est-form-grupo">
                            <label>Motivo / Observação</label>
                            <input @bind="novaMovimentacao.Motivo" class="est-input" placeholder="Ex: Compra semanal" />
                        </div>
                    </div>
                    @if (novaMovimentacao.Quantidade > 0 && novaMovimentacao.ValorUnitario > 0)
                    {
                        <div class="est-total-compra">
                            Total da compra: <strong>@((novaMovimentacao.Quantidade * novaMovimentacao.ValorUnitario).ToString("C2"))</strong>
                        </div>
                    }
                    <div class="est-form-btns">
                        <button class="est-btn-salvar" @onclick="@(() => RegistrarEntrada())">✅ Registrar Entrada</button>
                    </div>
                </div>

                <!-- Histórico de entradas -->
                <div class="est-card" style="margin-top:16px">
                    <div class="est-card-title">📋 Histórico de Compras</div>
                    @if (movimentacoes.Any(m => m.Tipo == "Entrada"))
                    {
                        var entradas = movimentacoes.Where(m => m.Tipo == "Entrada").ToList();
                        <div class="est-resumo-bar">
                            Total gasto: <strong>@entradas.Sum(e => e.ValorTotal).ToString("C2")</strong>
                            em @entradas.Count compras
                        </div>
                        <div class="est-table-wrap">
                            <table class="est-table">
                                <thead><tr><th>Data</th><th>Insumo</th><th>Qtd</th><th>Unit.</th><th>Total</th><th>Fornecedor</th><th>NF</th></tr></thead>
                                <tbody>
                                @foreach (var m in entradas)
                                {
                                    <tr>
                                        <td>@m.DataMovimentacao.ToString("dd/MM/yy HH:mm")</td>
                                        <td>@m.InsumoNome</td>
                                        <td>@m.Quantidade</td>
                                        <td>@m.ValorUnitario.ToString("C2")</td>
                                        <td><strong>@m.ValorTotal.ToString("C2")</strong></td>
                                        <td>@(string.IsNullOrEmpty(m.Fornecedor) ? "—" : m.Fornecedor)</td>
                                        <td>@(string.IsNullOrEmpty(m.NumeroNF) ? "—" : m.NumeroNF)</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="est-empty">Nenhuma compra registrada ainda.</p>
                    }
                </div>
            </div>
        }

        <!-- ================================================================
             ABA: TODAS AS MOVIMENTAÇÕES
             ================================================================ -->
        @if (abaAtiva == "saidas")
        {
            <div class="est-section">
                <!-- Ajuste manual de estoque -->
                <div class="est-card">
                    <div class="est-card-title">🔧 Ajuste Manual de Estoque</div>
                    <div class="est-form-grid">
                        <div class="est-form-grupo">
                            <label>Insumo</label>
                            <select @bind="ajuste.InsumoId" class="est-input">
                                <option value="0">— Selecione —</option>
                                @foreach (var i in insumos)
                                {
                                    <option value="@i.Id">@i.Nome (@i.EstoqueAtual.ToString("0.###") @i.Unidade)</option>
                                }
                            </select>
                        </div>
                        <div class="est-form-grupo">
                            <label>Tipo</label>
                            <select @bind="ajuste.Tipo" class="est-input">
                                <option value="Ajuste">Ajuste (+ ou -)</option>
                                <option value="Saida">Saída Manual</option>
                            </select>
                        </div>
                        <div class="est-form-grupo">
                            <label>Quantidade @(ajuste.Tipo == "Ajuste" ? "(use − para reduzir)" : "")</label>
                            <input type="number" step="0.01" @bind="ajuste.Quantidade" class="est-input" />
                        </div>
                        <div class="est-form-grupo">
                            <label>Motivo</label>
                            <input @bind="ajuste.Motivo" class="est-input" placeholder="Ex: Perda, vencimento, inventário" />
                        </div>
                    </div>
                    <div class="est-form-btns">
                        <button class="est-btn-salvar" @onclick="@(() => RegistrarAjuste())">✅ Registrar Ajuste</button>
                    </div>
                </div>

                <!-- Histórico completo -->
                <div class="est-card" style="margin-top:16px">
                    <div class="est-card-title">📋 Todas as Movimentações</div>
                    @if (movimentacoes.Any())
                    {
                        <div class="est-table-wrap">
                            <table class="est-table">
                                <thead><tr><th>Data</th><th>Insumo</th><th>Tipo</th><th>Qtd</th><th>Valor</th><th>Motivo</th></tr></thead>
                                <tbody>
                                @foreach (var m in movimentacoes)
                                {
                                    <tr>
                                        <td>@m.DataMovimentacao.ToString("dd/MM HH:mm")</td>
                                        <td>@m.InsumoNome</td>
                                        <td><span class="est-badge-tipo est-tipo-@m.Tipo.ToLower()">@m.Tipo</span></td>
                                        <td>@m.Quantidade</td>
                                        <td>@m.ValorTotal.ToString("C2")</td>
                                        <td class="est-td-motivo">@m.Motivo</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="est-empty">Sem movimentações registradas.</p>
                    }
                </div>
            </div>
        }
    }

    <!-- ── MODAL DE ENTRADA RÁPIDA ──────────────────────────────── -->
    @if (mostrarModalEntrada && insumoEntrada != null)
    {
        <div class="est-modal-overlay" @onclick="@(() => FecharModalEntrada())">
            <div class="est-modal" @onclick:stopPropagation="true">
                <h3>📦 Entrada de Estoque</h3>
                <p class="est-modal-sub">Insumo: <strong>@insumoEntrada.Nome</strong> (Atual: @insumoEntrada.EstoqueAtual.ToString("0.###") @insumoEntrada.Unidade)</p>
                <div class="est-form-grid">
                    <div class="est-form-grupo">
                        <label>Quantidade *</label>
                        <input type="number" step="0.01" @bind="entradaRapida.Quantidade" class="est-input" />
                    </div>
                    <div class="est-form-grupo">
                        <label>Valor Unitário (R$)</label>
                        <input type="number" step="0.01" @bind="entradaRapida.ValorUnitario" class="est-input" />
                    </div>
                    <div class="est-form-grupo">
                        <label>Fornecedor</label>
                        <input @bind="entradaRapida.Fornecedor" class="est-input" placeholder="Opcional" />
                    </div>
                    <div class="est-form-grupo">
                        <label>Nº NF</label>
                        <input @bind="entradaRapida.NumeroNF" class="est-input" placeholder="Opcional" />
                    </div>
                </div>
                <div class="est-modal-btns">
                    <button class="est-btn-cancelar" @onclick="@(() => FecharModalEntrada())">Cancelar</button>
                    <button class="est-btn-salvar" @onclick="@(() => ConfirmarEntradaRapida())">✅ Confirmar</button>
                </div>
            </div>
        </div>
    }

    <!-- ── MODAL DE AJUSTE DIRETO ────────────────────────────── -->
    @if (mostrarModalAjuste && insumoAjuste != null)
    {
        <div class="est-modal-overlay" @onclick="@(() => FecharModalAjuste())">
            <div class="est-modal" @onclick:stopPropagation="true" style="max-width: 350px;">
                <h3>🔧 Ajustar Saldo Real</h3>
                <p class="est-modal-sub">Insumo: <strong>@insumoAjuste.Nome</strong></p>
                
                <div class="est-form-grupo" style="margin-bottom: 20px;">
                    <label>Saldo físico agora (@insumoAjuste.Unidade)</label>
                    <input type="number" step="0.01" @bind="novoSaldoDesejado" class="est-input" style="font-size: 1.5rem; text-align: center;" />
                </div>

                <div class="est-form-grupo">
                    <label>Motivo do ajuste</label>
                    <input @bind="motivoAjuste" class="est-input" placeholder="Ex: Inventário, Correção" />
                </div>

                <div class="est-modal-btns">
                    <button class="est-btn-cancelar" @onclick="@(() => FecharModalAjuste())">Cancelar</button>
                    <button class="est-btn-salvar" @onclick="@(() => ConfirmarAjusteSaldo())">💾 Salvar</button>
                </div>
            </div>
        </div>
    }

    <style>
        .est-switch-label { display: flex; align-items: center; gap: 8px; color: #ffb347; cursor: pointer; font-size: 0.9rem; }
        .est-row-inativo { opacity: 0.5; background: rgba(0,0,0,0.2); }
        .est-badge-inativo { background: #444; color: #aaa; padding: 2px 6px; border-radius: 4px; font-size: 0.7rem; margin-left: 5px; }
        .est-btn-restaurar { background: #4caf50; color: #fff; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; font-size: 0.8rem; }
        .est-btn-ajustar-mini { background: #555; color: #fff; border: none; padding: 2px 6px; border-radius: 4px; cursor: pointer; }
        .est-btn-ajustar-mini:hover { background: #777; }
    </style>

</div>

@code {
    private string abaAtiva = "dashboard";
    private bool carregando = true;
    private string msgSucesso = string.Empty;
    private string msgErro    = string.Empty;

    // Insumos e Movimentações
    private EstoqueDashboardDto? dashboard;
    private List<InsumoDto> insumos = new();
    private List<MovimentacaoDto> movimentacoes = new();

    private InsumoDto editandoInsumo = new();
    private NovaMovimentacaoRequest novaMovimentacao = new() { Tipo = "Entrada" };
    private NovaMovimentacaoRequest ajuste           = new() { Tipo = "Ajuste" };

    private bool mostrarInativos = false;

    // Modal entrada rápida
    private bool mostrarModalEntrada = false;
    private InsumoDto? insumoEntrada;
    private NovaMovimentacaoRequest entradaRapida = new() { Tipo = "Entrada" };

    // Modal Ajuste Direto
    private bool mostrarModalAjuste = false;
    private InsumoDto? insumoAjuste;
    private decimal novoSaldoDesejado = 0;
    private string motivoAjuste = "Ajuste de inventário";

    // Filtros de data como string para evitar bugs de compilação no Linux/Docker
    private string filtroInicioStr = DateTime.Today.AddDays(-6).ToString("yyyy-MM-dd");
    private string filtroFimStr    = DateTime.Today.ToString("yyyy-MM-dd");

    protected override async Task OnInitializedAsync()
    {
        if (!await KdsAuth.EstaAutenticadoAsync())
        {
            var returnUrl = Nav.ToBaseRelativePath(Nav.Uri);
            Nav.NavigateTo($"/kds/login?returnUrl={returnUrl}", replace: true);
            return;
        }
        await CarregarTudo();
    }

    private async Task CarregarTudo()
    {
        carregando = true;
        try
        {
            var de  = filtroInicioStr;
            var ate = filtroFimStr;

            // Verifica autenticação antes de carregar
            var dashResp = await Http.GetAsync($"api/insumos/dashboard?de={de}&ate={ate}");
            if (dashResp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                // Sessão expirada — redireciona para login
                Nav.NavigateTo("/kds/login?returnUrl=/admin/estoque", replace: true);
                return;
            }
            if (dashResp.IsSuccessStatusCode)
                dashboard = await dashResp.Content.ReadFromJsonAsync<EstoqueDashboardDto>();

            var endpoint = mostrarInativos ? "api/insumos/todos" : "api/insumos";
            var insumosResp = await Http.GetAsync(endpoint);
            if (insumosResp.IsSuccessStatusCode)
                insumos = await insumosResp.Content.ReadFromJsonAsync<List<InsumoDto>>() ?? new();

            var movsResp = await Http.GetAsync($"api/insumos/movimentacoes?de={de}&ate={ate}");
            if (movsResp.IsSuccessStatusCode)
                movimentacoes = await movsResp.Content.ReadFromJsonAsync<List<MovimentacaoDto>>() ?? new();
        }
        catch (Exception ex)
        {
            msgErro = $"Erro ao carregar dados: {ex.Message}";
        }
        finally { carregando = false; }
    }

    private void AplicarAtalho(string atalho)
    {
        var hoje = DateTime.Today;
        var (inicio, fim) = atalho switch
        {
            "hoje"   => (hoje, hoje),
            "7dias"  => (hoje.AddDays(-6), hoje),
            "30dias" => (hoje.AddDays(-29), hoje),
            "mes"    => (new DateTime(hoje.Year, hoje.Month, 1), hoje),
            _        => (DateTime.Parse(filtroInicioStr), DateTime.Parse(filtroFimStr))
        };
        filtroInicioStr = inicio.ToString("yyyy-MM-dd");
        filtroFimStr = fim.ToString("yyyy-MM-dd");
    }

    private async Task MudarAba(string aba)
    {
        abaAtiva = aba;
        await CarregarTudo();
    }

    // ── Insumos ───────────────────────────────────────────────────────────
    private void NovoInsumo() => editandoInsumo = new();
    private void EditarInsumo(InsumoDto i) => editandoInsumo = new InsumoDto
    {
        Id = i.Id, Nome = i.Nome, Unidade = i.Unidade,
        EstoqueMinimo = i.EstoqueMinimo, CustoPorUnidade = i.CustoPorUnidade
    };

    private async Task SalvarInsumo()
    {
        LimparMensagens();
        if (string.IsNullOrWhiteSpace(editandoInsumo.Nome))
        { msgErro = "Informe o nome do insumo."; return; }

        HttpResponseMessage resp;
        if (editandoInsumo.Id == 0)
            resp = await Http.PostAsJsonAsync("api/insumos", editandoInsumo);
        else
            resp = await Http.PutAsJsonAsync($"api/insumos/{editandoInsumo.Id}", editandoInsumo);

        if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            // Sessão expirada — avisa e redireciona
            await JS.InvokeVoidAsync("alert", "Sessão expirada! Você será redirecionado para o login.");
            Nav.NavigateTo("/kds/login?returnUrl=/admin/estoque", replace: true);
            return;
        }

        if (resp.IsSuccessStatusCode)
        {
            msgSucesso = "Insumo salvo com sucesso!";
            editandoInsumo = new();
            await CarregarTudo();
        }
        else
        {
            var erro = await resp.Content.ReadAsStringAsync();
            msgErro = string.IsNullOrWhiteSpace(erro) ? $"Erro {(int)resp.StatusCode} ao salvar insumo." : erro;
            await JS.InvokeVoidAsync("alert", $"Erro ao salvar: {msgErro}");
        }
    }

    private async Task DeletarInsumo(InsumoDto i)
    {
        LimparMensagens();
        if (!await JS.InvokeAsync<bool>("confirm", $"Deseja realmente excluir '{i.Nome}'? Ele sumirá da lista principal, mas poderá ser recuperado depois.")) return;
        
        var r = await Http.DeleteAsync($"api/insumos/{i.Id}");
        if (r.IsSuccessStatusCode) { msgSucesso = $"'{i.Nome}' removido."; await CarregarTudo(); }
        else msgErro = "Erro ao remover.";
    }

    private async Task RestaurarInsumo(InsumoDto i)
    {
        LimparMensagens();
        var r = await Http.PostAsync($"api/insumos/{i.Id}/restaurar", null);
        if (r.IsSuccessStatusCode) { msgSucesso = $"'{i.Nome}' restaurado!"; await CarregarTudo(); }
        else msgErro = "Erro ao restaurar.";
    }

    // ── Movimentações ─────────────────────────────────────────────────────
    private async Task RegistrarEntrada()
    {
        LimparMensagens();
        novaMovimentacao.Tipo = "Entrada";
        if (novaMovimentacao.InsumoId == 0) { msgErro = "Selecione o insumo."; return; }
        if (novaMovimentacao.Quantidade <= 0) { msgErro = "Informe a quantidade."; return; }

        var r = await Http.PostAsJsonAsync("api/insumos/movimentar", novaMovimentacao);
        if (r.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await JS.InvokeVoidAsync("alert", "Sessão expirada! Você será redirecionado para o login.");
            Nav.NavigateTo("/kds/login?returnUrl=/admin/estoque", replace: true);
            return;
        }
        if (r.IsSuccessStatusCode)
        {
            msgSucesso = "Entrada registrada com sucesso!";
            novaMovimentacao = new() { Tipo = "Entrada" };
            await CarregarTudo();
        }
        else msgErro = await r.Content.ReadAsStringAsync();
    }

    private async Task RegistrarAjuste()
    {
        LimparMensagens();
        if (ajuste.InsumoId == 0) { msgErro = "Selecione o insumo."; return; }
        if (ajuste.Quantidade == 0) { msgErro = "Informe a quantidade."; return; }

        var r = await Http.PostAsJsonAsync("api/insumos/movimentar", ajuste);
        if (r.IsSuccessStatusCode)
        {
            msgSucesso = "Ajuste registrado!";
            ajuste = new() { Tipo = "Ajuste" };
            await CarregarTudo();
        }
        else msgErro = await r.Content.ReadAsStringAsync();
    }

    // ── Modal entrada rápida ──────────────────────────────────────────────
    private void AbrirEntrada(InsumoDto i)
    {
        insumoEntrada = i;
        entradaRapida = new() { Tipo = "Entrada", InsumoId = i.Id, ValorUnitario = i.CustoPorUnidade };
        mostrarModalEntrada = true;
    }

    private void FecharModalEntrada() { mostrarModalEntrada = false; insumoEntrada = null; }

    private async Task ConfirmarEntradaRapida()
    {
        LimparMensagens();
        if (entradaRapida.Quantidade <= 0) { msgErro = "Informe a quantidade."; return; }
        var r = await Http.PostAsJsonAsync("api/insumos/movimentar", entradaRapida);
        if (r.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await JS.InvokeVoidAsync("alert", "Sessão expirada! Você será redirecionado para o login.");
            Nav.NavigateTo("/kds/login?returnUrl=/admin/estoque", replace: true);
            return;
        }
        if (r.IsSuccessStatusCode)
        {
            msgSucesso = $"Entrada de {entradaRapida.Quantidade} {insumoEntrada?.Unidade} registrada!";
            FecharModalEntrada();
            await CarregarTudo();
        }
        else msgErro = await r.Content.ReadAsStringAsync();
    }

    // ── Modal Ajuste Direto ─────────────────────────────────────────────
    private void AbrirAjuste(InsumoDto i)
    {
        insumoAjuste = i;
        novoSaldoDesejado = i.EstoqueAtual;
        motivoAjuste = "Ajuste de inventário";
        mostrarModalAjuste = true;
    }

    private void FecharModalAjuste() { mostrarModalAjuste = false; insumoAjuste = null; }

    private async Task ConfirmarAjusteSaldo()
    {
        LimparMensagens();
        if (insumoAjuste == null) return;

        var req = new AjusteSaldoRequest { NovoSaldo = novoSaldoDesejado, Motivo = motivoAjuste };
        var r = await Http.PatchAsJsonAsync($"api/insumos/{insumoAjuste.Id}/ajustar-saldo", req);

        if (r.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await JS.InvokeVoidAsync("alert", "Sessão expirada! Você será redirecionado para o login.");
            Nav.NavigateTo("/kds/login?returnUrl=/admin/estoque", replace: true);
            return;
        }

        if (r.IsSuccessStatusCode)
        {
            msgSucesso = "Saldo ajustado com sucesso!";
            FecharModalAjuste();
            await CarregarTudo();
        }
        else msgErro = await r.Content.ReadAsStringAsync();
    }

    private void LimparMensagens() { msgSucesso = string.Empty; msgErro = string.Empty; }
}

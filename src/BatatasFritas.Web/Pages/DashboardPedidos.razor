@page "/dashboard/pedidos"
@inject HttpClient Http
@using BatatasFritas.Shared.DTOs
@using System.Globalization

<h3>Pedidos por Período</h3>
<div class="mb-3">
    <label>Data Início:</label>
    <InputDate @bind-Value="StartDate" class="form-control" />
</div>
<div class="mb-3">
    <label>Data Fim:</label>
    <InputDate @bind-Value="EndDate" class="form-control" />
</div>
<button class="btn btn-primary" @onclick="() => LoadPedidos(1)">Buscar</button>

@if (Carregando)
{
    <p>Carregando...</p>
}
else if (Resultado == null || !Resultado.Items.Any())
{
    <p>Nenhum pedido encontrado.</p>
}
else
{
    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>ID</th>
                <th>Cliente</th>
                <th>Telefone</th>
                <th>Valor Total</th>
                <th>Cashback Usado</th>
                <th>Data</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Resultado.Items)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.NomeCliente</td>
                    <td>@p.TelefoneCliente</td>
                    <td>@p.ValorTotal.ToString("C", CultureInfo.CurrentCulture)</td>
                    <td>@p.ValorCashbackUsado.ToString("C", CultureInfo.CurrentCulture)</td>
                    <td>@p.DataHoraPedido.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>

    <PaginacaoComponent PaginaAtual="@Resultado.Page"
                        TotalPaginas="@Resultado.TotalPages"
                        TotalRegistros="@Resultado.TotalCount"
                        OnPaginaMudou="@LoadPedidos" />
}

@code {
    private PagedResult<ListaPedidosDto>? Resultado;
    private bool Carregando;
    private DateTime? StartDate;
    private DateTime? EndDate;

    private async Task LoadPedidos(int pagina = 1)
    {
        Carregando = true;
        var query = $"api/pedidos/bydate?page={pagina}&pageSize=20";
        if (StartDate.HasValue) query += $"&start={StartDate.Value:yyyy-MM-dd}";
        if (EndDate.HasValue)   query += $"&end={EndDate.Value:yyyy-MM-dd}";
        Resultado  = await Http.GetFromJsonAsync<PagedResult<ListaPedidosDto>>(query);
        Carregando = false;
    }
}

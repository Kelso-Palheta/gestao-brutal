@page "/"
@using BatatasFritas.Shared.DTOs
@using BatatasFritas.Shared.Enums
@inject HttpClient Http
@inject BatatasFritas.Web.Services.CarrinhoState Carrinho

<PageTitle>Cardápio — Palheta Brutal</PageTitle>

@if (!menuDigitalAtivo)
{
    <div style="position:fixed; inset:0; z-index:9999; background:#111; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:40px;">
        <div style="font-size:6rem; margin-bottom:24px; animation: pulse 2s infinite;">🍟</div>
        <h1 style="font-size:2.4rem; font-weight:900; color:#ffb347; margin:0 0 16px 0; letter-spacing:-1px;">Palheta Brutal</h1>
        <div style="background:#1a1a1a; border:1px solid #333; border-radius:16px; padding:32px 40px; max-width:500px;">
            <div style="font-size:2.5rem; margin-bottom:12px;">🔴</div>
            <h2 style="color:#e74c3c; font-size:1.5rem; margin:0 0 12px 0;">Atendimento Encerrado</h2>
            <p style="color:#ccc; font-size:1.1rem; line-height:1.6; margin:0;">@menuDigitalMensagem</p>
        </div>
        <p style="color:#444; margin-top:32px; font-size:0.85rem;">Obrigado pela preferência! 💛</p>
    </div>
    <style>
        @@keyframes pulse { 0%,100%{transform:scale(1);} 50%{transform:scale(1.08);} }
    </style>
}
else
{
    <!-- =====================================================================
         HERO / BANNER
         ===================================================================== -->
    <section class="cardapio-hero">
        <div class="cardapio-hero-inner">
            <h1>🍟 Cardápio Palheta Brutal</h1>
            <p>Batatas artesanais com ingredientes frescos. Feito na hora, entregue na sua porta.</p>
        </div>
    </section>

    @if (produtos == null)
    {
        <!-- Skeleton Loading Grid -->
        <div class="skeleton-grid">
            @for (int i = 0; i < 8; i++)
            {
                <div class="skeleton-card">
                    <div class="skeleton-img shimmer"></div>
                    <div class="skeleton-body">
                        <div class="skeleton-line tag shimmer"></div>
                        <div class="skeleton-line shimmer"></div>
                        <div class="skeleton-line short shimmer"></div>
                        <div class="skeleton-footer">
                            <div class="skeleton-price shimmer"></div>
                            <div class="skeleton-btn shimmer"></div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (!produtos.Any())
    {
        <div class="cardapio-vazio">
            <p>😔 Cardápio indisponível no momento. Tente novamente em breve.</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(erroCarregamento))
    {
        <div class="cardapio-vazio" style="color: #e74c3c;">
            <p>❌ @erroCarregamento</p>
            <button class="btn-confirmar" style="margin-top: 20px; padding: 10px 20px;" @onclick="CarregarDados">Tentar Novamente</button>
        </div>
    }
    else
    {
        <!-- =====================================================================
             FILTROS DE CATEGORIA
             ===================================================================== -->
        var categorias = produtos.Select(p => p.CategoriaId).Distinct().OrderBy(c => c).ToList();

        <div class="cardapio-filtros">
            <button class="filtro-btn @(categoriaSelecionada == null ? "ativo" : "")"
                    @onclick="() => categoriaSelecionada = null">
                Tudo
            </button>
            @foreach (var cat in categorias)
            {
                var c = cat;
                <button class="filtro-btn @(categoriaSelecionada == c ? "ativo" : "")"
                        @onclick="() => categoriaSelecionada = c">
                    @NomeCategoria(c)
                </button>
            }
        </div>

        <!-- =====================================================================
             GRID DE PRODUTOS
             ===================================================================== -->
        var produtosFiltrados = categoriaSelecionada == null
            ? produtos
            : produtos.Where(p => p.CategoriaId == categoriaSelecionada).ToArray();

        @if (categoriaSelecionada != null)
        {
            <h2 class="cardapio-secao-titulo">@NomeCategoria(categoriaSelecionada.Value)</h2>
        }

        <div class="cardapio-grid">
            @foreach (var p in produtosFiltrados)
            {
                <div class="produto-card @(p.CategoriaId == CategoriaEnum.Bebidas ? "produto-card-bebida" : "")">
                    @if (!string.IsNullOrWhiteSpace(p.ImagemUrl))
                    {
                        <div class="produto-img-wrap">
                            <img src="@p.ImagemUrl" alt="@p.Nome" class="produto-img" loading="lazy" />
                        </div>
                    }
                    else
                    {
                        <div class="produto-img-placeholder">
                            @(p.CategoriaId == CategoriaEnum.Bebidas ? "🥤" : "🍟")
                        </div>
                    }

                    <div class="produto-body">
                        <div class="produto-categoria-tag">@NomeCategoria(p.CategoriaId)</div>
                        <h3 class="produto-nome">@p.Nome</h3>
                        @if (!string.IsNullOrWhiteSpace(p.Descricao))
                        {
                            <p class="produto-desc">@p.Descricao</p>
                        }
                        <div class="produto-footer">
                            <span class="preco">R$ @p.PrecoBase.ToString("F2")</span>
                            <button class="btn-adicionar" @onclick="() => AbrirModal(p)" id="btn-add-@p.Id">
                                @(p.CategoriaId == CategoriaEnum.Bebidas ? "Adicionar" : "Personalizar")
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- =====================================================================
         MODAL DE PERSONALIZAÇÃO
         ===================================================================== -->
    @if (mostrarModal && produtoSelecionado != null)
    {
        <div class="modal-overlay" @onclick="FecharModal">
            <div class="modal-content" @onclick:stopPropagation="true">
                <button class="modal-close-btn" @onclick="FecharModal">✕</button>
                <h2>🍟 Personalize seu pedido</h2>
                <p class="modal-nome-produto">@produtoSelecionado.Nome</p>

                @* Componente compartilhado de customização (mesmo do Totem) *@
                <CustomizadorItem 
                    Complementos="@complementosAtivos.ToList()"
                    TituloMolhos="Molhos incluídos — toque para retirar"
                    TituloIngredientes="Ingredientes — toque para retirar"
                    TituloAdicionais="Adicionais Pagos (+ R$)"
                    SelecionadosIds="@selecionadosIds"
                    QuantidadesAdicionais="@quantidadesAdicionais"
                    OnToggleComplemento="@ToggleComplemento"
                    OnAlterarQuantidade="@AlterarQuantidade" />

                <div class="modal-footer">
                    <span class="preco-destaque">Total: R$ @PrecoTotalAtual.ToString("F2")</span>
                    <div class="modal-footer-btns">
                        <button class="btn-cancelar" @onclick="FecharModal">Cancelar</button>
                        <button class="btn-confirmar" @onclick="ConfirmarAdicao">✅ Adicionar ao Carrinho</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private ProdutoDto[]? produtos;
    private CategoriaEnum? categoriaSelecionada = null;

    // Status do cardápio digital
    private bool menuDigitalAtivo = true;
    private string menuDigitalMensagem = "Atendimento encerrado. Voltamos em breve! 🍟";
    private string? erroCarregamento;

    // Modal State
    private bool mostrarModal = false;
    private ProdutoDto? produtoSelecionado;

    private List<ComplementoDto> todosComplementos = new();
    private IEnumerable<ComplementoDto> complementosAtivos 
    {
        get
        {
            if (produtoSelecionado == null) return Array.Empty<ComplementoDto>();
            
            if (!string.IsNullOrWhiteSpace(produtoSelecionado.ComplementosPermitidos))
            {
                var ids = produtoSelecionado.ComplementosPermitidos.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(int.Parse);
                return todosComplementos.Where(c => ids.Contains(c.Id) && c.Ativo);
            }
            
            return todosComplementos.Where(c => c.Ativo && (c.CategoriaAlvo == "Todas" || c.CategoriaAlvo == produtoSelecionado.CategoriaId.ToString()));
        }
    }

    // Variáveis para o CustomizadorItem (componente compartilhado)
    private HashSet<int> selecionadosIds = new();
    private Dictionary<int, int> quantidadesAdicionais = new();

    // Legado: mantido para compatibilidade (não usado mais)
    private HashSet<int> ativosGratuitosERemocao = new();

    private decimal precoAdicionais => todosComplementos
        .Where(c => c.TipoAcao == "AdicionalPago" && quantidadesAdicionais.ContainsKey(c.Id))
        .Sum(c => c.Preco * quantidadesAdicionais[c.Id]);

    private decimal PrecoTotalAtual => ((produtoSelecionado?.PrecoBase ?? 0) + precoAdicionais);

    private void ToggleComplemento(ComplementoDto c)
    {
        if (selecionadosIds.Contains(c.Id))
            selecionadosIds.Remove(c.Id);
        else
            selecionadosIds.Add(c.Id);
    }

    private void AlterarQuantidade(int id, int delta)
    {
        if (!quantidadesAdicionais.ContainsKey(id))
            quantidadesAdicionais[id] = 0;
        quantidadesAdicionais[id] += delta;
        if (quantidadesAdicionais[id] <= 0)
            quantidadesAdicionais.Remove(id);
    }

    protected override async Task OnInitializedAsync()
    {
        // Verifica se o cardápio está ativo antes de exibir produtos
        try
        {
            var menuStatus = await Http.GetFromJsonAsync<DeliveryStatusDto>("api/configuracoes/delivery-status");
            if (menuStatus != null)
            {
                menuDigitalAtivo    = menuStatus.Ativo;
                menuDigitalMensagem = menuStatus.Mensagem;
            }
        }
        catch { }

        if (menuDigitalAtivo)
        {
            await CarregarDados();
        }
    }

    private async Task CarregarDados()
    {
        try
        {
            erroCarregamento = null;
            // Busca produtos e complementos em paralelo para ganhar tempo na primeira carga
            var produtosTask = Http.GetFromJsonAsync<ProdutoDto[]>("api/produtos");
            var complementosTask = Http.GetFromJsonAsync<List<ComplementoDto>>("api/complementos/ativos");

            await Task.WhenAll(produtosTask, complementosTask);

            var plist = await produtosTask;
            if (plist != null) produtos = plist.Where(p => p.Ativo).OrderBy(x => x.Ordem).ToArray();

            var clist = await complementosTask;
            if (clist != null) todosComplementos = clist;
        }
        catch (Exception ex)
        {
            erroCarregamento = "Não foi possível carregar o cardápio. Verifique sua conexão.";
            Console.WriteLine($"Erro ao carregar dados: {ex.Message}");
        }
    }

    private void ToggleGratuito(int id, bool ativo)
    {
        if (ativo) ativosGratuitosERemocao.Add(id);
        else ativosGratuitosERemocao.Remove(id);
    }

    private void AbrirModal(ProdutoDto produto)
    {
        if (produto.CategoriaId == CategoriaEnum.Bebidas)
        {
            Carrinho.AdicionarItemComOpcoes(produto, 1, produto.PrecoBase, "");
            return;
        }
        produtoSelecionado = produto;
        selecionadosIds.Clear();
        quantidadesAdicionais.Clear();
        
        // Pré-selecionar molhos e ingredientes: verde = incluído por padrão
        foreach (var comp in complementosAtivos.Where(x => x.TipoAcao == "MolhoGratuito" || x.TipoAcao == "Remocao"))
            selecionadosIds.Add(comp.Id);
        
        mostrarModal = true;
    }

    private void FecharModal()
    {
        mostrarModal = false;
        produtoSelecionado = null;
    }

    private void ConfirmarAdicao()
    {
        if (produtoSelecionado == null) return;

        var partes = new List<string>();

        // Molhos retirados (desmarcados = vermelhos)
        var molhosRetirados = complementosAtivos
            .Where(c => c.TipoAcao == "MolhoGratuito" && !selecionadosIds.Contains(c.Id))
            .Select(c => $"Sem {c.Nome}");
        partes.AddRange(molhosRetirados);

        // Ingredientes retirados (desmarcados = vermelhos)
        var ingredientesRetirados = complementosAtivos
            .Where(c => c.TipoAcao == "Remocao" && !selecionadosIds.Contains(c.Id))
            .Select(c => $"Sem {c.Nome}");
        partes.AddRange(ingredientesRetirados);

        // Adicionais pagos incluídos
        var pagos = complementosAtivos
            .Where(c => c.TipoAcao == "AdicionalPago" && quantidadesAdicionais.ContainsKey(c.Id))
            .Select(c => $"{quantidadesAdicionais[c.Id]}x {c.Nome}");
        partes.AddRange(pagos);

        var observacaoFinal = string.Join(", ", partes);

        Carrinho.AdicionarItemComOpcoes(produtoSelecionado, 1, PrecoTotalAtual, observacaoFinal);
        FecharModal();
    }

    private static string NomeCategoria(CategoriaEnum cat) => cat switch
    {
        CategoriaEnum.Batatas    => "🍟 Batatas",
        CategoriaEnum.Bebidas    => "🥤 Bebidas",
        CategoriaEnum.Porcoes    => "🍗 Porções",
        CategoriaEnum.Sobremesas => "🍰 Sobremesas",
        _                        => cat.ToString()
    };
}
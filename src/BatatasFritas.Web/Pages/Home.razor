@page "/"
@using BatatasFritas.Shared.DTOs
@using BatatasFritas.Shared.Enums
@inject HttpClient Http
@inject BatatasFritas.Web.Services.CarrinhoState Carrinho

<PageTitle>Cardápio — Palheta Brutal</PageTitle>

<!-- =====================================================================
     HERO / BANNER
     ===================================================================== -->
<section class="cardapio-hero">
    <div class="cardapio-hero-inner">
        <h1>🍟 Cardápio Palheta Brutal</h1>
        <p>Batatas artesanais com ingredientes frescos. Feito na hora, entregue na sua porta.</p>
    </div>
</section>

@if (produtos == null)
{
    <div class="cardapio-loading">
        <div class="cardapio-spinner"></div>
        <p>Carregando o cardápio...</p>
    </div>
}
else if (!produtos.Any())
{
    <div class="cardapio-vazio">
        <p>😔 Cardápio indisponível no momento. Tente novamente em breve.</p>
    </div>
}
else
{
    <!-- =====================================================================
         FILTROS DE CATEGORIA
         ===================================================================== -->
    var categorias = produtos.Select(p => p.CategoriaId).Distinct().OrderBy(c => c).ToList();

    <div class="cardapio-filtros">
        <button class="filtro-btn @(categoriaSelecionada == null ? "ativo" : "")"
                @onclick="() => categoriaSelecionada = null">
            Tudo
        </button>
        @foreach (var cat in categorias)
        {
            var c = cat;
            <button class="filtro-btn @(categoriaSelecionada == c ? "ativo" : "")"
                    @onclick="() => categoriaSelecionada = c">
                @NomeCategoria(c)
            </button>
        }
    </div>

    <!-- =====================================================================
         GRID DE PRODUTOS
         ===================================================================== -->
    var produtosFiltrados = categoriaSelecionada == null
        ? produtos
        : produtos.Where(p => p.CategoriaId == categoriaSelecionada).ToArray();

    @if (categoriaSelecionada != null)
    {
        <h2 class="cardapio-secao-titulo">@NomeCategoria(categoriaSelecionada.Value)</h2>
    }

    <div class="cardapio-grid">
        @foreach (var p in produtosFiltrados)
        {
            <div class="produto-card @(p.CategoriaId == CategoriaEnum.Bebidas ? "produto-card-bebida" : "")">
                @if (!string.IsNullOrWhiteSpace(p.ImagemUrl))
                {
                    <div class="produto-img-wrap">
                        <img src="@p.ImagemUrl" alt="@p.Nome" class="produto-img" loading="lazy" />
                    </div>
                }
                else
                {
                    <div class="produto-img-placeholder">
                        @(p.CategoriaId == CategoriaEnum.Bebidas ? "🥤" : "🍟")
                    </div>
                }

                <div class="produto-body">
                    <div class="produto-categoria-tag">@NomeCategoria(p.CategoriaId)</div>
                    <h3 class="produto-nome">@p.Nome</h3>
                    @if (!string.IsNullOrWhiteSpace(p.Descricao))
                    {
                        <p class="produto-desc">@p.Descricao</p>
                    }
                    <div class="produto-footer">
                        <span class="preco">R$ @p.PrecoBase.ToString("F2")</span>
                        <button class="btn-adicionar" @onclick="() => AbrirModal(p)" id="btn-add-@p.Id">
                            @(p.CategoriaId == CategoriaEnum.Bebidas ? "Adicionar" : "Personalizar")
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- =====================================================================
     MODAL DE PERSONALIZAÇÃO
     ===================================================================== -->
@if (mostrarModal && produtoSelecionado != null)
{
    <div class="modal-overlay" @onclick="FecharModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <button class="modal-close-btn" @onclick="FecharModal">✕</button>
            <h2>🍟 Personalize seu pedido</h2>
            <p class="modal-nome-produto">@produtoSelecionado.Nome</p>

            @if (complementosAtivos.Any(x => x.TipoAcao == "MolhoGratuito"))
            {
                <div class="opcoes-secao">
                    <h4>Complementos Gratuitos (Molhos)</h4>
                    <div class="checkbox-grid">
                        @foreach (var c in complementosAtivos.Where(x => x.TipoAcao == "MolhoGratuito"))
                        {
                            <label class="checkbox-item @(ativosGratuitosERemocao.Contains(c.Id) ? "selecionado" : "")">
                                <input type="checkbox" checked="@ativosGratuitosERemocao.Contains(c.Id)" @onchange="@(e => ToggleGratuito(c.Id, (bool)e.Value!))" /> @c.Nome
                            </label>
                        }
                    </div>
                </div>
            }

            @if (complementosAtivos.Any(x => x.TipoAcao == "Remocao"))
            {
                <div class="opcoes-secao">
                    <h4>Remoções / Sem</h4>
                    <div class="checkbox-grid">
                        @foreach (var c in complementosAtivos.Where(x => x.TipoAcao == "Remocao"))
                        {
                            <label class="checkbox-item @(ativosGratuitosERemocao.Contains(c.Id) ? "selecionado" : "")">
                                <input type="checkbox" checked="@ativosGratuitosERemocao.Contains(c.Id)" @onchange="@(e => ToggleGratuito(c.Id, (bool)e.Value!))" /> @c.Nome
                            </label>
                        }
                    </div>
                </div>
            }

            @if (complementosAtivos.Any(x => x.TipoAcao == "AdicionalPago"))
            {
                <div class="opcoes-secao">
                    <h4>Adicionais (+R$)</h4>
                    <div class="addon-lista">
                        @foreach (var c in complementosAtivos.Where(x => x.TipoAcao == "AdicionalPago"))
                        {
                            int qtd = quantidadesAdicionais.ContainsKey(c.Id) ? quantidadesAdicionais[c.Id] : 0;
                            <div class="addon-contador">
                                <span class="addon-nome">@c.Nome</span>
                                <span class="addon-preco">@c.Preco.ToString("C2")</span>
                                <div class="contador-controles">
                                    <button @onclick="() => { if (qtd > 0) quantidadesAdicionais[c.Id] = qtd - 1; }">−</button>
                                    <span>@qtd</span>
                                    <button @onclick="() => quantidadesAdicionais[c.Id] = qtd + 1">+</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="modal-footer">
                <span class="preco-destaque">Total: R$ @PrecoTotalAtual.ToString("F2")</span>
                <div class="modal-footer-btns">
                    <button class="btn-cancelar" @onclick="FecharModal">Cancelar</button>
                    <button class="btn-confirmar" @onclick="ConfirmarAdicao">✅ Adicionar ao Carrinho</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private ProdutoDto[]? produtos;
    private CategoriaEnum? categoriaSelecionada = null;

    // Modal State
    private bool mostrarModal = false;
    private ProdutoDto? produtoSelecionado;

    private List<ComplementoDto> todosComplementos = new();
    private IEnumerable<ComplementoDto> complementosAtivos 
    {
        get
        {
            if (produtoSelecionado == null) return Array.Empty<ComplementoDto>();
            
            if (!string.IsNullOrWhiteSpace(produtoSelecionado.ComplementosPermitidos))
            {
                var ids = produtoSelecionado.ComplementosPermitidos.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(int.Parse);
                return todosComplementos.Where(c => ids.Contains(c.Id) && c.Ativo);
            }
            
            return todosComplementos.Where(c => c.Ativo && (c.CategoriaAlvo == "Todas" || c.CategoriaAlvo == produtoSelecionado.CategoriaId.ToString()));
        }
    }

    private HashSet<int> ativosGratuitosERemocao = new();
    private Dictionary<int, int> quantidadesAdicionais = new();

    private decimal PrecoTotalAtual
    {
        get
        {
            var basico = produtoSelecionado?.PrecoBase ?? 0;
            var addPreco = quantidadesAdicionais.Sum(kv => kv.Value * (todosComplementos.FirstOrDefault(c => c.Id == kv.Key)?.Preco ?? 0));
            return basico + addPreco;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var plist = await Http.GetFromJsonAsync<ProdutoDto[]>("api/produtos");
        if (plist != null) produtos = plist.Where(p => p.Ativo).OrderBy(x => x.Ordem).ToArray();

        var clist = await Http.GetFromJsonAsync<List<ComplementoDto>>("api/complementos/ativos");
        if (clist != null) todosComplementos = clist;
    }

    private void ToggleGratuito(int id, bool ativo)
    {
        if (ativo) ativosGratuitosERemocao.Add(id);
        else ativosGratuitosERemocao.Remove(id);
    }

    private void AbrirModal(ProdutoDto produto)
    {
        if (produto.CategoriaId == CategoriaEnum.Bebidas)
        {
            Carrinho.AdicionarItemComOpcoes(produto, 1, produto.PrecoBase, "");
            return;
        }
        produtoSelecionado = produto;
        ativosGratuitosERemocao.Clear();
        quantidadesAdicionais.Clear();
        mostrarModal = true;
    }

    private void FecharModal()
    {
        mostrarModal = false;
        produtoSelecionado = null;
    }

    private void ConfirmarAdicao()
    {
        if (produtoSelecionado == null) return;

        var objAdics = quantidadesAdicionais
            .Where(kv => kv.Value > 0)
            .Select(kv => $"{kv.Value}x {todosComplementos.First(c => c.Id == kv.Key).Nome}")
            .ToList();

        var objMolhos = ativosGratuitosERemocao
            .Select(id => todosComplementos.First(c => c.Id == id).Nome)
            .ToList();

        var obsPartes = new List<string>();
        if (objMolhos.Any()) obsPartes.Add(string.Join(", ", objMolhos));
        if (objAdics.Any()) obsPartes.Add(string.Join(", ", objAdics));

        Carrinho.AdicionarItemComOpcoes(
            produtoSelecionado,
            1,
            PrecoTotalAtual,
            string.Join(" | ", obsPartes)
        );

        FecharModal();
    }

    private static string NomeCategoria(CategoriaEnum cat) => cat switch
    {
        CategoriaEnum.Batatas    => "🍟 Batatas",
        CategoriaEnum.Bebidas    => "🥤 Bebidas",
        CategoriaEnum.Porcoes    => "🍗 Porções",
        CategoriaEnum.Sobremesas => "🍰 Sobremesas",
        _                        => cat.ToString()
    };
}

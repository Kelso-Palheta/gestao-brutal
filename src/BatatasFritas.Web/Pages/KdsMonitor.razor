@page "/kds"
@layout KdsLayout
@using BatatasFritas.Shared.DTOs
@using BatatasFritas.Shared.Enums
@using Microsoft.AspNetCore.SignalR.Client
@using System.Net.Http.Json
@implements IAsyncDisposable
@inject HttpClient Http
@inject IJSRuntime JS
@inject BatatasFritas.Web.Services.KdsAuthService KdsAuth
@inject NavigationManager Nav

<!-- ============================
     KANBAN PRINCIPAL
     ============================ -->
<div style="display:flex; justify-content:flex-end; padding:0 10px 5px 0;">
    <span style="font-size:0.8rem; padding:4px 8px; border-radius:4px; font-weight:bold; @(signalrStatus == "Conectado" ? "background:#27ae60;color:#fff;" : "background:#c0392b;color:#fff;")">
        SignalR: @signalrStatus
    </span>
</div>
<div class="kds-kanban">

    <!-- Coluna: Recebidos -->
    <div class="kds-column">
        <div class="kds-column-header bg-recebido">
            <h2>
                Novos (Avaliar)
                @if (pedidosRecebidos.Any())
                {
                    <span class="kds-badge-count">@pedidosRecebidos.Count()</span>
                }
            </h2>
        </div>
        <div class="kds-column-body">
            @foreach (var p in pedidosRecebidos)
            {
                <div class="kds-card @(idsNovos.Contains(p.Id) ? "kds-card-novo" : "")">
                    <div class="kds-card-header">
                        <span>#@p.Id — @p.NomeCliente</span>
                        <span class="kds-time">@p.DataHoraPedido.ToString("HH:mm")</span>
                    </div>
                    <div style="display:flex; gap:6px; flex-wrap:wrap; padding:4px 10px;">
                        @ExibirBadgesPedido(p)
                    </div>
                    <ul class="kds-card-items">
                        @foreach (var i in p.Itens)
                        {
                            <li style="margin-bottom: 5px;">
                                <strong>@i.Quantidade</strong>x @i.NomeProduto
                                @if (!string.IsNullOrWhiteSpace(i.Observacao))
                                {
                                    <div class="kds-obs">@i.Observacao</div>
                                }
                            </li>
                        }
                    </ul>
                    <div class="kds-card-actions">
                        <button class="kds-btn kds-btn-aceitar" @onclick="() => MoverStatus(p.Id, StatusPedido.Aceito)">
                            Aceitar 👍
                        </button>
                        @ExibirBotoesPagamento(p)
                        <button class="kds-btn kds-btn-cancelar-pedido" @onclick="() => AbrirCancelamento(p)" title="Cancelar pedido">
                            ✕
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Coluna: Fila (Aceitos) -->
    <div class="kds-column">
        <div class="kds-column-header bg-aceito">
            <h2>
                Na Fila (Aceitos)
                @if (pedidosAceitos.Any())
                {
                    <span class="kds-badge-count">@pedidosAceitos.Count()</span>
                }
            </h2>
        </div>
        <div class="kds-column-body">
            @foreach (var p in pedidosAceitos)
            {
                <div class="kds-card border-aceito">
                    <div class="kds-card-header">
                        <span>#@p.Id — @p.NomeCliente</span>
                    </div>
                    <div style="display:flex; gap:6px; flex-wrap:wrap; padding:4px 10px;">
                        @ExibirBadgesPedido(p)
                    </div>
                    <ul class="kds-card-items">
                        @foreach (var i in p.Itens)
                        {
                            <li style="margin-bottom: 5px;">
                                <strong>@i.Quantidade</strong>x @i.NomeProduto
                                @if (!string.IsNullOrWhiteSpace(i.Observacao))
                                {
                                    <div class="kds-obs">@i.Observacao</div>
                                }
                            </li>
                        }
                    </ul>
                    <div class="kds-card-actions">
                        <button class="kds-btn kds-btn-preparo" @onclick="() => MoverStatus(p.Id, StatusPedido.EmPreparo)">
                            Cozinhar 👨‍🍳
                        </button>
                        @ExibirBotoesPagamento(p)
                        <button class="kds-btn" style="background:#fff; flex: 0 0 44px;" @onclick="() => ImprimirCupom(p)" title="Imprimir">
                            🖨️
                        </button>
                        <button class="kds-btn kds-btn-cancelar-pedido" @onclick="() => AbrirCancelamento(p)" title="Cancelar pedido">
                            ✕
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Coluna: Em Preparo -->
    <div class="kds-column">
        <div class="kds-column-header bg-preparo">
            <h2>
                Fritando 🔥
                @if (pedidosEmPreparo.Any())
                {
                    <span class="kds-badge-count">@pedidosEmPreparo.Count()</span>
                }
            </h2>
        </div>
        <div class="kds-column-body">
            @foreach (var p in pedidosEmPreparo)
            {
                <div class="kds-card border-preparo">
                    <div class="kds-card-header">
                        <span>#@p.Id — @p.NomeCliente</span>
                    </div>
                    <div style="display:flex; gap:6px; flex-wrap:wrap; padding:4px 10px;">
                        @ExibirBadgesPedido(p)
                    </div>
                    <ul class="kds-card-items">
                        @foreach (var i in p.Itens)
                        {
                            <li style="margin-bottom: 5px;">
                                <strong>@i.Quantidade</strong>x @i.NomeProduto
                                @if (!string.IsNullOrWhiteSpace(i.Observacao))
                                {
                                    <div class="kds-obs">@i.Observacao</div>
                                }
                            </li>
                        }
                    </ul>
                    <div class="kds-card-actions">
                        <button class="kds-btn kds-btn-pronto" @onclick="() => MoverStatus(p.Id, StatusPedido.ProntoParaEntrega)">
                            Pronto ✅
                        </button>
                        @ExibirBotoesPagamento(p)
                        <button class="kds-btn kds-btn-cancelar-pedido" @onclick="() => AbrirCancelamento(p)" title="Cancelar pedido">
                            ✕
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Coluna: Prontos (Despache) -->
    <div class="kds-column">
        <div class="kds-column-header bg-pronto">
            <h2>
                Despache 🛵
                @if (pedidosProntos.Any())
                {
                    <span class="kds-badge-count">@pedidosProntos.Count()</span>
                }
            </h2>
        </div>
        <div class="kds-column-body">
            @foreach (var p in pedidosProntos)
            {
                <div class="kds-card border-pronto">
                    <div class="kds-card-header">
                        <span>#@p.Id — @p.NomeCliente</span>
                    </div>
                    <div style="display:flex; gap:6px; flex-wrap:wrap; padding:4px 10px; margin-bottom:4px;">
                        @ExibirBadgesPedido(p)
                    </div>
                    <div class="kds-delivery-info">
                        📞 @p.TelefoneCliente<br />
                        🏠 <strong>@p.NomeBairro</strong> — @p.EnderecoEntrega<br />
                        💰 <strong>Total: @p.ValorTotal.ToString("C2")</strong>
                        @if (p.MetodoPagamento == MetodoPagamento.Dinheiro)
                        {
                            var trocoReal = (p.TrocoPara ?? 0) - p.ValorTotal;
                            var exibirTroco = trocoReal > 0 ? trocoReal.ToString("C2") : "Nenhum";
                            <br /><span class="kds-troco">💵 Levar Troco: @exibirTroco</span>
                        }
                    </div>
                    <ul class="kds-card-items">
                        @foreach (var i in p.Itens)
                        {
                            <li style="margin-bottom: 5px;">
                                <strong>@i.Quantidade</strong>x @i.NomeProduto
                                @if (!string.IsNullOrWhiteSpace(i.Observacao))
                                {
                                    <div class="kds-obs">@i.Observacao</div>
                                }
                            </li>
                        }
                    </ul>
                    <div class="kds-card-actions">
                        @if (p.Status == StatusPedido.Entregue)
                        {
                            <button class="kds-btn" style="background:#111; color:#888; border-color:#444; cursor:not-allowed; box-shadow:none;" title="Aguardando retorno do pagamento" disabled>
                                🛵 Aguarda Motoboy
                            </button>
                        }
                        else if (p.StatusPagamento == StatusPagamento.Aprovado || p.StatusPagamento == StatusPagamento.Presencial)
                        {
                            <button class="kds-btn kds-btn-entregue" @onclick="() => MoverStatus(p.Id, StatusPedido.Entregue)">
                                Despachar ✅
                            </button>
                        }
                        else if (p.MetodoPagamento == MetodoPagamento.Dinheiro || p.MetodoPagamento == MetodoPagamento.InfiniteTap)
                        {
                            <button class="kds-btn kds-btn-entregue" style="border-color: #ff9800; color: #ff9800;" title="Pagamento será realizado na entrega" @onclick="() => MoverStatus(p.Id, StatusPedido.Entregue)">
                                Despachar no Motoboy 🛵
                            </button>
                        }
                        else
                        {
                            <button class="kds-btn" style="background:#111; color:#555; border-color:#333; cursor:not-allowed;" title="Aguardando Pagamento Online" disabled>
                                🚫 Aguarda Pagto
                            </button>
                        }
                        
                        @ExibirBotoesPagamento(p)
                        <button class="kds-btn" style="background:#fff; flex: 0 0 44px;" @onclick="() => ImprimirCupom(p)" title="Imprimir">
                            🖨️
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- ============================
     MODAL — CANCELAR PEDIDO
     ============================ -->
@if (pedidoParaCancelar != null)
{
    <div class="modal-overlay" @onclick="FecharCancelamento">
        <div class="kds-cancel-modal" @onclick:stopPropagation="true">
            <div class="kds-cancel-modal-header">
                ⚠️ Cancelar Pedido #@pedidoParaCancelar.Id
            </div>
            <div class="kds-cancel-modal-body">
                <p><strong>Cliente:</strong> @pedidoParaCancelar.NomeCliente</p>
                <p class="kds-cancel-aviso">Esta ação não pode ser desfeita. Informe o motivo:</p>
                <div class="kds-cancel-field">
                    <label>Motivo do Cancelamento</label>
                    <textarea @bind="motivoCancelamento"
                              rows="3"
                              placeholder="Ex: Cliente desistiu, item indisponível..."
                              class="kds-cancel-textarea"></textarea>
                </div>
                @if (!string.IsNullOrEmpty(erroCancelamento))
                {
                    <div class="kds-cancel-erro">❌ @erroCancelamento</div>
                }
            </div>
            <div class="kds-cancel-modal-footer">
                <button class="kds-btn" style="background:#eee; flex:1;" @onclick="FecharCancelamento" disabled="@cancelando">
                    Voltar
                </button>
                <button class="kds-btn kds-btn-confirmar-cancelar" @onclick="ConfirmarCancelamento" disabled="@cancelando">
                    @(cancelando ? "Cancelando..." : "🗑️ Confirmar Cancelamento")
                </button>
            </div>
        </div>
    </div>
}

<!-- ============================
     CONTAINER DE IMPRESSÃO (OCULTO)
     ============================ -->
@if (pedidoAtualParaImpressao != null)
{
    <div id="cupomFritaria" class="cupom-termico">
        <h2>BATATA</h2>
        <h2>PALHETA BRUTAL</h2>
        <p>Pedido #@pedidoAtualParaImpressao.Id</p>
        <p>@pedidoAtualParaImpressao.DataHoraPedido.ToString("dd/MM/yyyy HH:mm")</p>
        <hr />
        <p><strong>CLIENTE:</strong> @pedidoAtualParaImpressao.NomeCliente</p>
        <p>📞 @pedidoAtualParaImpressao.TelefoneCliente</p>
        <p><strong>ENTREGA:</strong></p>
        <p>@pedidoAtualParaImpressao.NomeBairro</p>
        <p>@pedidoAtualParaImpressao.EnderecoEntrega</p>
        <hr />
        <table class="cupom-tabela">
            <thead>
                <tr>
                    <th>Qtd</th>
                    <th>Item</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in pedidoAtualParaImpressao.Itens)
                {
                    <tr>
                        <td>@i.Quantidade</td>
                        <td>
                            @i.NomeProduto
                            @if (!string.IsNullOrWhiteSpace(i.Observacao))
                            {
                                <div style="font-size: 0.8em; margin-top: 2px;">OBS: @i.Observacao</div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <hr />
        <p>PAGAMENTO: @NomeMetodo(pedidoAtualParaImpressao.MetodoPagamento)</p>
        <p style="font-weight:900; font-size:14px; border:2px solid #000; padding:4px; text-align:center;">@(pedidoAtualParaImpressao.StatusPagamento == StatusPagamento.Aprovado || pedidoAtualParaImpressao.StatusPagamento == StatusPagamento.Presencial ? "✅ PAGO" : "⚠️ PAGAMENTO PENDENTE")</p>
        <div class="cupom-total">TOTAL: @pedidoAtualParaImpressao.ValorTotal.ToString("C2")</div>
        @if (pedidoAtualParaImpressao.MetodoPagamento == MetodoPagamento.Dinheiro && pedidoAtualParaImpressao.TrocoPara != null)
        {
            var troco = pedidoAtualParaImpressao.TrocoPara.Value - pedidoAtualParaImpressao.ValorTotal;
            if (troco > 0)
            {
                <div class="cupom-total" style="font-size: 14px; margin-top: 5px;">TROCO P/: @pedidoAtualParaImpressao.TrocoPara.Value.ToString("C2")</div>
                <div class="cupom-total" style="font-size: 14px;">LEVAR: @troco.ToString("C2")</div>
            }
        }
        <hr />
        <p style="margin-top: 15px;">Obrigado pela preferência!</p>
        <p>Palheta Brutal Delivery</p>
    </div>
}

@code {
    // ── Estado dos pedidos ──────────────────────────────────────────────
    private List<PedidoDetalheDto> todosAbertos = new();

    private IEnumerable<PedidoDetalheDto> pedidosRecebidos  => todosAbertos.Where(p => p.Status == StatusPedido.Recebido);
    private IEnumerable<PedidoDetalheDto> pedidosAceitos    => todosAbertos.Where(p => p.Status == StatusPedido.Aceito);
    private IEnumerable<PedidoDetalheDto> pedidosEmPreparo  => todosAbertos.Where(p => p.Status == StatusPedido.EmPreparo);
    private IEnumerable<PedidoDetalheDto> pedidosProntos    => todosAbertos.Where(p =>
        p.Status == StatusPedido.ProntoParaEntrega || p.Status == StatusPedido.SaiuParaEntrega || p.Status == StatusPedido.Entregue);

    // ── Alerta Sonoro (rastreia IDs que já existiam) ─────────────────────
    /// IDs dos pedidos recebidos conhecidos pelo front. Se aparecer um ID novo → toca o beep.
    private HashSet<int> idsConhecidos = new();
    /// IDs que chegaram NESTA rodada de polling (para piscar o card brevemente).
    private HashSet<int> idsNovos = new();

    // ── Impressão ────────────────────────────────────────────────────────
    private PedidoDetalheDto? pedidoAtualParaImpressao;

    // ── SignalR ───────────────────────────────────────────────────────────
    private HubConnection? _hubConnection;
    private string signalrStatus = "Conectando...";

    private RenderFragment ExibirBadgesPedido(PedidoDetalheDto p) => __builder =>
    {
        var badge = BadgePagamento(p);
        <span style="@badge.estilo">@badge.texto</span>
        <span style="background:#333; color:#fff; padding:2px 8px; border-radius:4px; font-size:0.75rem; font-weight:bold;">@NomeMetodo(p.MetodoPagamento)</span>
        @if (p.TipoAtendimento == TipoAtendimento.Totem)
        {
            <span style="background:#7c3aed; color:#fff; padding:2px 8px; border-radius:4px; font-size:0.75rem; font-weight:bold;">📱 TOTEM</span>
        }
        else if (p.TipoAtendimento == TipoAtendimento.Delivery)
        {
            <span style="background:#e67e22; color:#fff; padding:2px 8px; border-radius:4px; font-size:0.75rem; font-weight:bold;">🛵 DELIVERY</span>
        }
        else if (p.TipoAtendimento == TipoAtendimento.Balcao)
        {
            <span style="background:#2980b9; color:#fff; padding:2px 8px; border-radius:4px; font-size:0.75rem; font-weight:bold;">💼 BALCÃO</span>
        }
    };

    private RenderFragment ExibirBotoesPagamento(PedidoDetalheDto p) => __builder =>
    {
        @if (p.StatusPagamento != StatusPagamento.Aprovado && p.StatusPagamento != StatusPagamento.Presencial)
        {
            <button class="kds-btn" style="background:#f39c12; color:#fff; flex: 0 0 auto; border-color:#d68910;" @onclick="() => MarcarPago(p.Id)" title="Marcar como Pago">
                ⚠️ Pendente
            </button>
        }
        else
        {
            <button class="kds-btn" style="background:#27ae60; color:#fff; flex: 0 0 auto; border-color:#229954;" @onclick="() => DesfazerPagamento(p.Id)" title="Desfazer Pagamento">
                ✅ Pago
            </button>
        }
    };

    // ── Cancelamento ─────────────────────────────────────────────────────
    private PedidoDetalheDto? pedidoParaCancelar;
    private string motivoCancelamento = string.Empty;
    private string erroCancelamento = string.Empty;
    private bool cancelando = false;

    // ────────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        if (!await KdsAuth.EstaAutenticadoAsync())
        {
            var returnUrl = Nav.ToBaseRelativePath(Nav.Uri);
            Nav.NavigateTo($"/kds/login?returnUrl={returnUrl}", replace: true);
            return;
        }

        await LoadPedidos(primeiraVez: true);
        await ConectarSignalR();
    }

    private async Task ConectarSignalR()
    {
        // Monta a URL do hub a partir da BaseAddress do HttpClient
        var apiBase = Http.BaseAddress?.ToString().TrimEnd('/') ?? "";
        string hubUrl;
        if (apiBase.EndsWith("/api", StringComparison.OrdinalIgnoreCase))
            hubUrl = apiBase.Substring(0, apiBase.Length - 4) + "/hubs/pedidos";
        else
            hubUrl = $"{apiBase}/hubs/pedidos";

        var token = KdsAuth.GetToken();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl, options =>
            {
                if (!string.IsNullOrEmpty(token))
                    options.AccessTokenProvider = () => Task.FromResult<string?>(token);
            })
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.Closed += (ex) => {
            signalrStatus = "Desconectado!";
            InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        };
        _hubConnection.Reconnecting += (ex) => {
            signalrStatus = "Reconectando...";
            InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        };
        _hubConnection.Reconnected += (id) => {
            signalrStatus = "Conectado";
            InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        };

        // Novo pedido: recarrega e toca alerta
        _hubConnection.On<int>("NovoPedido", async pedidoId =>
        {
            await LoadPedidos(primeiraVez: false);
            await InvokeAsync(StateHasChanged);
        });

        // Status mudou: recarrega silenciosamente
        _hubConnection.On<int, string>("StatusAtualizado", async (pedidoId, status) =>
        {
            await LoadPedidos(primeiraVez: false);
            await InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
            signalrStatus = "Conectado";
        }
        catch (Exception ex)
        {
            signalrStatus = "Erro: " + ex.Message;
        }
    }

    private async Task LoadPedidos(bool primeiraVez = false)
    {
        try
        {
            var ativos = await Http.GetFromJsonAsync<List<PedidoDetalheDto>>("api/kds/ativos");
            if (ativos == null) return;

            todosAbertos = ativos.OrderBy(p => p.DataHoraPedido).ToList();

            // Detectar pedidos NOVOS (presentes na coluna Recebido, ainda não conhecidos)
            var idsRecebidosAgora = ativos
                .Where(p => p.Status == StatusPedido.Recebido)
                .Select(p => p.Id)
                .ToHashSet();

            if (!primeiraVez)
            {
                var novosDessaRodada = idsRecebidosAgora.Except(idsConhecidos).ToHashSet();
                if (novosDessaRodada.Any())
                {
                    idsNovos = novosDessaRodada;
                    // Toca o beep de alerta — novo pedido!
                    await JS.InvokeVoidAsync("kdsInterop.tocarAlerta", "novo");

                    // Piscar por 4 segundos e depois remover destaque
                    _ = Task.Delay(4000).ContinueWith(async _ =>
                    {
                        idsNovos.Clear();
                        await InvokeAsync(StateHasChanged);
                    });
                }
            }

            // Atualiza os IDs conhecidos (apenas "Recebido" — as outras colunas não alertam)
            idsConhecidos = idsRecebidosAgora;
        }
        catch
        {
            // Falha passageira de rede — ignora para não travar o polling
        }
    }

    private async Task MoverStatus(int id, StatusPedido novoStatus)
    {
        try
        {
            var response = await Http.PutAsJsonAsync($"api/kds/{id}/status", novoStatus);
            if (response.IsSuccessStatusCode)
                await LoadPedidos();
        }
        catch { }
    }

    // ────────────────────────────────────────────────────────────────────
    // CANCELAMENTO
    // ────────────────────────────────────────────────────────────────────

    private void AbrirCancelamento(PedidoDetalheDto pedido)
    {
        pedidoParaCancelar = pedido;
        motivoCancelamento = string.Empty;
        erroCancelamento = string.Empty;
        cancelando = false;
    }

    private void FecharCancelamento()
    {
        pedidoParaCancelar = null;
        motivoCancelamento = string.Empty;
        erroCancelamento = string.Empty;
    }

    private async Task ConfirmarCancelamento()
    {
        if (pedidoParaCancelar == null) return;

        if (string.IsNullOrWhiteSpace(motivoCancelamento))
        {
            erroCancelamento = "Informe o motivo do cancelamento.";
            return;
        }

        cancelando = true;
        erroCancelamento = string.Empty;

        try
        {
            var body = new { motivo = motivoCancelamento.Trim() };
            var response = await Http.PostAsJsonAsync($"api/kds/{pedidoParaCancelar.Id}/cancelar", body);

            if (response.IsSuccessStatusCode)
            {
                // Toca beep de cancelamento
                await JS.InvokeVoidAsync("kdsInterop.tocarAlerta", "cancelar");
                FecharCancelamento();
                await LoadPedidos();
            }
            else
            {
                erroCancelamento = $"Erro: {await response.Content.ReadAsStringAsync()}";
            }
        }
        catch (Exception ex)
        {
            erroCancelamento = $"Erro de conexão: {ex.Message}";
        }
        finally
        {
            cancelando = false;
        }
    }

    // ────────────────────────────────────────────────────────────────────
    // IMPRESSÃO
    // ────────────────────────────────────────────────────────────────────

    private async Task ImprimirCupom(PedidoDetalheDto pedido)
    {
        pedidoAtualParaImpressao = pedido;
        StateHasChanged();
        await Task.Delay(50);
        await JS.InvokeVoidAsync("printInterop.printCupom", "cupomFritaria");
    }

    // ────────────────────────────────────────────────────────────────────
    // MARCAR COMO PAGO / DESFAZER PAGAMENTO
    // ────────────────────────────────────────────────────────────────────
    private async Task MarcarPago(int id)
    {
        try
        {
            var response = await Http.PutAsync($"api/kds/{id}/pagar", null);
            if (response.IsSuccessStatusCode)
                await LoadPedidos();
        }
        catch { }
    }

    private async Task DesfazerPagamento(int id)
    {
        try
        {
            var response = await Http.PutAsync($"api/kds/{id}/desfazer-pagamento", null);
            if (response.IsSuccessStatusCode)
                await LoadPedidos();
        }
        catch { }
    }

    // ────────────────────────────────────────────────────────────────────
    // HELPERS
    // ────────────────────────────────────────────────────────────────────
    private static (string texto, string estilo) BadgePagamento(PedidoDetalheDto p)
    {
        if (p.StatusPagamento == StatusPagamento.Aprovado || p.StatusPagamento == StatusPagamento.Presencial)
            return ("✅ PAGO", "background:#27ae60; color:#fff; padding:2px 8px; border-radius:4px; font-size:0.75rem; font-weight:bold;");
        return ("⏳ PENDENTE", "background:#f39c12; color:#fff; padding:2px 8px; border-radius:4px; font-size:0.75rem; font-weight:bold;");
    }

    private static string NomeMetodo(MetodoPagamento m) => m switch
    {
        MetodoPagamento.Pix => "PIX",
        MetodoPagamento.Dinheiro => "DINHEIRO",
        MetodoPagamento.InfiniteTap => "CARTÃO",
        MetodoPagamento.InfinitePayOnline => "ONLINE",
        _ => m.ToString().ToUpper()
    };

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }
}

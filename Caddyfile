# Configurações globais opcionais
# {
#     email seu-email@dominio.com.br
# }

# ===== CONFIGURAÇÃO COM DOMÍNIO (HTTPS AUTOMÁTICO) =====
# Quando você apontar o DNS do seu domínio para a Hetzner,
# descomente as linhas abaixo e comente o bloco ":80".

# batatasfritas.com.br {
#     reverse_proxy web:80
# }

# api.batatasfritas.com.br {
#     reverse_proxy api:8080
# }

# ===== CONFIGURAÇÃO SEM DOMÍNIO (TESTES / IP) =====
:80 {
    # Redireciona tudo que começa com /api para o backend (C#)
    handle /api/* {
        reverse_proxy api:8080
    }
    
    # Redireciona o resto para o frontend (Blazor/Nginx)
    handle /* {
        reverse_proxy web:80
    }
}

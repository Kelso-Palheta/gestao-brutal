# ────────────────────────────────────────────────────────────────────
# BatatasFritas — variáveis de ambiente (template)
# Copie para .env (local) ou cole no painel do Coolify (produção).
# .env é gitignored. Nunca commite valores reais.
# ────────────────────────────────────────────────────────────────────

# ── JWT (obrigatório) ───────────────────────────────────────────────
# Mínimo 32 caracteres. Gere com: openssl rand -base64 48
Jwt__SecretKey=

# ── Banco de dados ──────────────────────────────────────────────────
# sqlite (dev) | postgres (prod)
DatabaseProvider=sqlite

# Dev (SQLite):
ConnectionStrings__DefaultConnection=Data Source=batatasfritas.db;Version=3;
# Prod (Postgres) — exemplo:
# ConnectionStrings__DefaultConnection=Host=db;Database=batatasfritasdb;Username=postgres;Password=__TROCAR__

# ── Mercado Pago ────────────────────────────────────────────────────
MercadoPago__AccessToken=
MercadoPago__DeviceId=
# WebhookSecret é OBRIGATÓRIO em ASPNETCORE_ENVIRONMENT=Production
MercadoPago__WebhookSecret=
MercadoPago__NotificationUrl=

# ── KDS (operador) ──────────────────────────────────────────────────
# Senha de primeiro acesso. Após primeiro login válido, a senha persistida
# no banco (BCrypt) tem prioridade. Gere algo aleatório e troque no app.
KDS_DEFAULT_PASSWORD=

# ── ASP.NET Core ────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5255
